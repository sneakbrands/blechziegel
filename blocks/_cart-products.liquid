

{% render 'cart-products' %}

{% stylesheet %}
  .cart-page__title + .cart-page__items {
    margin-block-start: var(--margin-lg);
  }

  /* Blechziegel cart optimization: improve cart item readability without changing cart JS events. */
  .cart-page .cart-items__table {
    border-collapse: separate;
    border-spacing: 0 14px;
  }

  .cart-page .cart-items--dividers .cart-items__table-row,
  .cart-page .cart-items__table-row {
    padding: 16px;
    margin-bottom: 0;
    border: 1px solid rgb(7 26 51 / 0.08);
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 10px 26px rgb(7 26 51 / 0.08);
  }

  .cart-page .cart-items__media-container {
    border-radius: 14px;
    background: #f4f6f8;
  }

  .cart-page .cart-items__media-image {
    object-fit: cover;
  }

  .cart-page .cart-items__title {
    color: #071a33;
    font-weight: 700;
    line-height: 1.25;
  }

  .cart-page .cart-items__variants-wrapper {
    margin-top: 6px;
    color: rgb(7 26 51 / 0.72);
    line-height: 1.4;
  }

  .cart-page .cart-items__variant dd {
    font-size: var(--font-size--sm);
  }

  .cart-page .cart-items__variants-wrapper::after {
    content: 'Made in Germany · 1–3 Werktage · Kostenloser Versand ab 100 €';
    display: block;
    margin-top: 8px;
    color: rgb(7 26 51 / 0.58);
    font-size: var(--font-size--2xs);
    line-height: 1.35;
  }

  .cart-page .cart-items__quantity-controls {
    gap: 8px;
  }

  .cart-page .cart-items__remove {
    border-radius: 999px;
    color: rgb(7 26 51 / 0.72);
  }

  .cart-page .cart-items__remove:hover {
    background: rgb(7 26 51 / 0.06);
    color: #071a33;
  }

  .cart-page .cart-items__price {
    color: #071a33;
    font-weight: 700;
  }

  @container cart-items (min-width: 720px) {
    .cart-page .cart-items__table-row {
      grid-template-columns: 8rem minmax(0, 1fr) auto minmax(6rem, auto);
      column-gap: 22px;
      align-items: center;
    }

    .cart-page .cart-items__price {
      justify-content: center;
    }
  }

  @container cart-items (max-width: 719px) {
    .cart-page .cart-items__table-row {
      grid-template-columns: 5.5rem minmax(0, 1fr) auto;
      column-gap: 14px;
      padding: 14px;
    }

    .cart-page .cart-items__quantity {
      margin-top: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.cart_products",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 8,
      "max": 36,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "dividers",
      "label": "t:settings.dividers",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.cart_items"
    }
  ]
}
{% endschema %}