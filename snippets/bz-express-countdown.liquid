{%- comment -%}
  blechziegel.de — Express-Versand Countdown
  Schwebendes Popup links unten mit Live-Countdown bis zum Tages-Cutoff.
  CI: Navy #0a2240 · Orange #ffa500 · Montserrat/Open Sans
  Cutoff: täglich 12:00 lokale Zeit (DE) für Versand am selben Tag.
  Versteckt via Cookie (24h) nach Schließen.
{%- endcomment -%}

{% style %}
  .bz-express {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 1040;
    width: min(340px, calc(100vw - 32px));
    background: linear-gradient(160deg, #0a2240 0%, #163660 100%);
    border: 1px solid rgba(255, 165, 0, 0.25);
    border-top: 3px solid #ffa500;
    border-radius: 14px;
    padding: 18px 20px 20px;
    box-shadow: 0 18px 50px rgba(10, 34, 64, 0.35),
                0 4px 12px rgba(10, 34, 64, 0.12);
    color: #ffffff;
    font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .bz-express.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .bz-express[hidden] { display: none !important; }

  .bz-express__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }
  .bz-express__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #ffa500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
  }
  .bz-express__title svg {
    width: 16px;
    height: 16px;
    fill: #ffa500;
    flex-shrink: 0;
  }
  .bz-express__close {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: none;
    color: #ffffff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    flex-shrink: 0;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .bz-express__close:hover {
    background: rgba(255, 165, 0, 0.25);
    transform: rotate(90deg);
  }
  .bz-express__close svg { width: 12px; height: 12px; fill: currentColor; }

  .bz-express__intro {
    font-size: 13px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 12px;
  }

  .bz-express__timer {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-bottom: 12px;
  }
  .bz-express__unit {
    text-align: center;
  }
  .bz-express__num {
    display: flex;
    justify-content: center;
    gap: 3px;
    margin-bottom: 4px;
  }
  .bz-express__digit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    padding: 6px 4px;
    background: #ffffff;
    color: #0a2240;
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 22px;
    line-height: 1;
    border-radius: 6px;
    box-shadow: inset 0 -2px 0 rgba(10, 34, 64, 0.08);
    font-variant-numeric: tabular-nums;
  }
  .bz-express__label {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
  }

  .bz-express__msg {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 10px;
  }
  .bz-express__msg strong { color: #ffa500; font-weight: 700; }

  .bz-express__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12.5px;
    font-weight: 700;
    color: #ffa500;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.18s ease;
  }
  .bz-express__link:hover { color: #ffffff; }
  .bz-express__link svg { width: 12px; height: 12px; fill: currentColor; }

  /* Cutoff-vorbei Zustand — Versand morgen */
  .bz-express.is-tomorrow .bz-express__msg {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 640px) {
    .bz-express {
      left: 8px;
      right: 8px;
      bottom: 8px;
      width: auto;
      padding: 14px 16px 16px;
    }
    /* Bottom spacing gegen Cookie-Banner (links unten) */
    .bz-express__digit {
      min-width: 24px;
      font-size: 19px;
      padding: 5px 3px;
    }
  }
{% endstyle %}

<aside
  class="bz-express"
  id="bz-express-countdown"
  role="complementary"
  aria-label="Express-Versand Countdown"
  hidden
  data-cutoff-hour="13"
  data-cutoff-min="0"
  data-show-from-hour="8"
  data-hide-days="1"
>
  <div class="bz-express__header">
    <h2 class="bz-express__title">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h7v8l10-12h-7V2z"/></svg>
      Express-Versand
    </h2>
    <button
      type="button"
      class="bz-express__close"
      aria-label="Hinweis schließen"
      data-bz-express-close
    >
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
  </div>

  <div class="bz-express__intro" data-bz-express-intro>
    Bestellen Sie in den nächsten:
  </div>

  <div class="bz-express__timer" aria-live="polite" data-bz-express-timer>
    <div class="bz-express__unit">
      <div class="bz-express__num" data-unit="h">
        <span class="bz-express__digit">0</span><span class="bz-express__digit">0</span>
      </div>
      <div class="bz-express__label">Stunden</div>
    </div>
    <div class="bz-express__unit">
      <div class="bz-express__num" data-unit="m">
        <span class="bz-express__digit">0</span><span class="bz-express__digit">0</span>
      </div>
      <div class="bz-express__label">Minuten</div>
    </div>
    <div class="bz-express__unit">
      <div class="bz-express__num" data-unit="s">
        <span class="bz-express__digit">0</span><span class="bz-express__digit">0</span>
      </div>
      <div class="bz-express__label">Sekunden</div>
    </div>
  </div>

  <p class="bz-express__msg" data-bz-express-msg>
    und Sie erhalten Ihre Ware schon <strong>morgen</strong> — bei Lagerware bis 13 Uhr bestellt, DHL-Versand Deutschland.
  </p>

  <a href="{{ routes.root_url }}policies/shipping-policy" class="bz-express__link">
    Unsere Versand-Services ansehen
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
  </a>
</aside>

<script>
  (function(){
    var el = document.getElementById('bz-express-countdown');
    if (!el) return;

    var COOKIE = 'bz_express_dismissed';
    var hideDays = parseInt(el.dataset.hideDays || '1', 10);
    var cutoffH = parseInt(el.dataset.cutoffHour || '12', 10);
    var cutoffM = parseInt(el.dataset.cutoffMin || '0', 10);
    var showFromH = parseInt(el.dataset.showFromHour || '8', 10);

    // Nur Montag–Freitag, 08:00–12:00 lokal anzeigen
    function inWindow(){
      var d = new Date();
      var dow = d.getDay();             // 0=So, 1-5=Mo-Fr, 6=Sa
      if (dow < 1 || dow > 5) return false;
      var hm = d.getHours() * 60 + d.getMinutes();
      return hm >= showFromH * 60 && hm < cutoffH * 60 + cutoffM;
    }
    if (!inWindow()) return;

    function getCookie(n){
      var m = document.cookie.match(new RegExp('(?:^|;\\s*)' + n + '=([^;]*)'));
      return m ? decodeURIComponent(m[1]) : '';
    }
    function setCookie(n, v, days){
      var d = new Date(); d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
      document.cookie = n + '=' + encodeURIComponent(v) + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
    }

    if (getCookie(COOKIE) === '1') return;

    var timer = el.querySelector('[data-bz-express-timer]');
    var intro = el.querySelector('[data-bz-express-intro]');
    var msg   = el.querySelector('[data-bz-express-msg]');
    var closeBtn = el.querySelector('[data-bz-express-close]');

    function setDigits(unit, val){
      var wrap = timer.querySelector('[data-unit="' + unit + '"]');
      if (!wrap) return;
      var str = String(Math.max(0, val)).padStart(2, '0');
      var digits = wrap.querySelectorAll('.bz-express__digit');
      digits[0].textContent = str[0];
      digits[1].textContent = str[1];
    }

    function render(){
      var now = new Date();
      var cutoff = new Date(now.getFullYear(), now.getMonth(), now.getDate(), cutoffH, cutoffM, 0, 0);
      var afterCutoff = now >= cutoff;
      var dow = now.getDay();
      // Samstag/Sonntag: morgen nicht geliefert → Hinweis auf Montag
      var isWeekend = (dow === 6) || (dow === 0);

      if (afterCutoff || isWeekend) {
        el.classList.add('is-tomorrow');
        intro.textContent = 'Express heute nicht mehr möglich.';
        // Zeig verbleibende Zeit bis nächster Cutoff (nächster Werktag)
        var next = new Date(cutoff);
        next.setDate(next.getDate() + 1);
        while (next.getDay() === 6 || next.getDay() === 0) {
          next.setDate(next.getDate() + 1);
        }
        var diff = next - now;
        renderDiff(diff);
        msg.innerHTML = 'Bestellen Sie vor <strong>' + pad(cutoffH) + ':' + pad(cutoffM) + ' Uhr</strong> am nächsten Werktag für Versand noch am selben Tag.';
      } else {
        el.classList.remove('is-tomorrow');
        intro.textContent = 'Bestellen Sie in den nächsten:';
        renderDiff(cutoff - now);
        msg.innerHTML = 'und Sie erhalten Ihre Ware schon <strong>morgen</strong> — bei Lagerware bis 13 Uhr bestellt, DHL-Versand Deutschland.';
      }
    }
    function pad(n){ return String(n).padStart(2, '0'); }
    function renderDiff(ms){
      if (ms < 0) ms = 0;
      var totalS = Math.floor(ms / 1000);
      var h = Math.floor(totalS / 3600);
      var m = Math.floor((totalS % 3600) / 60);
      var s = totalS % 60;
      if (h > 99) h = 99;
      setDigits('h', h);
      setDigits('m', m);
      setDigits('s', s);
    }

    closeBtn.addEventListener('click', function(){
      setCookie(COOKIE, '1', hideDays);
      el.classList.remove('is-visible');
      setTimeout(function(){ el.hidden = true; }, 400);
    });

    // Erste Anzeige leicht verzögern für ruhigere UX
    setTimeout(function(){
      el.hidden = false;
      render();
      // Reflow trigger, damit transition greift
      void el.offsetWidth;
      el.classList.add('is-visible');
    }, 800);

    setInterval(function(){
      if (!inWindow()) {
        el.classList.remove('is-visible');
        setTimeout(function(){ el.hidden = true; }, 400);
        return;
      }
      render();
    }, 1000);
  })();
</script>
