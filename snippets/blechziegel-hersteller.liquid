{% comment %}
  ============================================================
  BLECHZIEGEL.DE — Hersteller-Übersichtsseite
  Section: blechziegel-hersteller.liquid
  Version: 2.0 (Gewerbe-Style Enterprise + SEO-Max)
  Layout-DNA: Navy-Hero, Orange-Akzente, Montserrat/Open Sans
  Struktur-Parität zu /pages/gewerbe:
    Hero → Vorteile → 3-Step → Brand-Grid → Mengenstaffel →
    Modell-Tabelle → Tech-Specs → Social-Proof → FAQ → CTA
  SEO: BreadcrumbList, WebPage, FAQPage, ItemList (Organization via theme.liquid)
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
.hp {
  --bz-navy:#0a2240; --bz-navy-light:#0d2d54;
  --bz-orange:#ffa500; --bz-orange-dark:#e69400; --bz-orange-bg:rgba(255,165,0,.12);
  --bz-white:#fff; --bz-gray:#f5f5f5; --bz-gray-mid:#e8eaed;
  --bz-text:#333; --bz-text-light:#666; --bz-border:#e5e7eb;
  --bz-green:#16a34a; --bz-green-bg:#f0fdf4;
  --bz-head:'Montserrat',sans-serif; --bz-body:'Open Sans',sans-serif;
  --bz-radius:8px; --bz-radius-lg:14px; --bz-max:1200px;
  --bz-shadow:0 4px 20px rgba(10,34,64,.10);
  --bz-shadow-lg:0 12px 40px rgba(10,34,64,.18);
  font-family:var(--bz-body); color:var(--bz-text);
}
.hp *, .hp *::before, .hp *::after { box-sizing:border-box; margin:0; padding:0; }
.hp a { text-decoration:none; color:inherit; }
.hp img { max-width:100%; display:block; }
.hp ul { list-style:none; }
.hp-wrap { max-width:var(--bz-max); margin:0 auto; padding:0 20px; }

/* HERO */
.hp-hero {
  background:var(--bz-navy);
  color:var(--bz-white); padding:72px 20px 64px; position:relative; overflow:hidden;
  min-height:500px;
}
.hp-hero__media { position:absolute; inset:0; z-index:0; }
.hp-hero__media img { width:100%; height:100%; object-fit:contain; object-position:center; display:block; }
.hp-hero::before {
  content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
  background:rgba(13,30,53,0.6);
}
.hp-hero__inner { position:relative; z-index:2; max-width:var(--bz-max); margin:0 auto;
  display:grid; grid-template-columns:1.1fr .9fr; gap:56px; align-items:center; }
.hp-kicker {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--bz-orange-bg); border:1px solid rgba(255,165,0,.35);
  color:var(--bz-orange); font-family:var(--bz-head);
  font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  padding:5px 13px; border-radius:20px; margin-bottom:20px;
}
.hp-kicker svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-hero h1 {
  font-family:var(--bz-head); font-size:clamp(26px,3.8vw,44px);
  font-weight:800; line-height:1.2; margin-bottom:18px; color:var(--bz-white);
}
.hp-hero h1 span { color:var(--bz-orange); }
.hp-hero__sub { font-size:16px; line-height:1.75; color:rgba(255,255,255,.82); margin-bottom:32px; max-width:520px; }
.hp-hero__cta { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:36px; }
.hp-hero__trust { display:flex; flex-wrap:wrap; gap:20px; }
.hp-hero__trust-item { display:flex; align-items:center; gap:7px;
  font-size:12.5px; color:rgba(255,255,255,.72); font-weight:600; }
.hp-hero__trust-item svg { width:14px; height:14px; fill:var(--bz-green); flex-shrink:0; }

.hp-hero__box {
  background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.12);
  border-radius:var(--bz-radius-lg); padding:28px; backdrop-filter:blur(6px);
}
.hp-hero__box-title { font-family:var(--bz-head); font-size:13px; font-weight:700;
  color:var(--bz-white); margin-bottom:18px; display:flex; align-items:center; gap:8px;
  text-transform:uppercase; letter-spacing:.08em; }
.hp-hero__box-title svg { width:16px; height:16px; fill:var(--bz-orange); }
.hp-hero__brands { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.hp-hero__brand {
  display:flex; align-items:center; justify-content:space-between; gap:10px;
  padding:12px 14px; background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.08); border-radius:var(--bz-radius);
  font-family:var(--bz-head); font-size:13.5px; font-weight:700; color:var(--bz-white);
  transition:all .18s;
}
.hp-hero__brand:hover { background:rgba(255,255,255,.11); border-color:rgba(255,165,0,.4); transform:translateY(-1px); }
.hp-hero__brand-dot { width:8px; height:8px; border-radius:50%; background:var(--bz-green); flex-shrink:0; box-shadow:0 0 0 3px rgba(22,163,74,.2); }

/* BUTTONS */
.hp-btn {
  display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:14px 26px; border-radius:var(--bz-radius);
  font-family:var(--bz-head); font-size:14px; font-weight:700;
  cursor:pointer; transition:all .2s; border:2px solid transparent; white-space:nowrap;
}
.hp-btn svg { width:16px; height:16px; fill:currentColor; flex-shrink:0; }
.hp-btn--primary { background:var(--bz-orange); color:var(--bz-navy); border-color:var(--bz-orange); }
.hp-btn--primary:hover { background:var(--bz-orange-dark); border-color:var(--bz-orange-dark); transform:translateY(-1px); box-shadow:0 6px 20px rgba(255,165,0,.3); }
.hp-btn--outline { background:transparent; color:var(--bz-white); border-color:rgba(255,255,255,.4); }
.hp-btn--outline:hover { border-color:var(--bz-white); background:rgba(255,255,255,.08); }
.hp-btn--navy { background:var(--bz-navy); color:var(--bz-white); border-color:var(--bz-navy); }
.hp-btn--navy:hover { background:var(--bz-navy-light); transform:translateY(-1px); box-shadow:var(--bz-shadow); }

/* SECTIONS */
.hp-section { padding:64px 0; }
.hp-section--gray { background:var(--bz-gray); }
.hp-section--white { background:var(--bz-white); }
.hp-section--navy { background:var(--bz-navy); color:var(--bz-white); }
.hp-section-label { font-family:var(--bz-head); font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.12em; color:var(--bz-orange);
  margin-bottom:8px; display:block; }
.hp-section-title { font-family:var(--bz-head); font-size:clamp(22px,2.8vw,32px);
  font-weight:800; color:var(--bz-navy); line-height:1.25; margin-bottom:12px; }
.hp-section--navy .hp-section-title { color:var(--bz-white); }
.hp-section-sub { font-size:15px; line-height:1.72; color:var(--bz-text-light); max-width:640px; margin-bottom:40px; }
.hp-section--navy .hp-section-sub { color:rgba(255,255,255,.72); }

/* VORTEILE-GRID */
.hp-benefits { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; }
.hp-benefit {
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px 24px; transition:all .2s;
}
.hp-benefit:hover { border-color:var(--bz-orange); box-shadow:var(--bz-shadow-lg); transform:translateY(-3px); }
.hp-benefit__icon { width:48px; height:48px; background:var(--bz-orange-bg); border-radius:12px;
  display:flex; align-items:center; justify-content:center; margin-bottom:18px; }
.hp-benefit__icon svg { width:22px; height:22px; fill:var(--bz-orange); }
.hp-benefit h3 { font-family:var(--bz-head); font-size:16px; font-weight:800; color:var(--bz-navy); margin-bottom:8px; line-height:1.3; }
.hp-benefit p { font-size:14px; line-height:1.7; color:var(--bz-text-light); }

/* 3-STEP FINDEN */
.hp-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; margin-top:40px; }
.hp-step {
  position:relative; background:var(--bz-white);
  border:1.5px solid var(--bz-border); border-radius:var(--bz-radius-lg);
  padding:32px 26px 28px; transition:all .2s;
}
.hp-step:hover { border-color:var(--bz-orange); box-shadow:var(--bz-shadow-lg); transform:translateY(-3px); }
.hp-step__num { position:absolute; top:-14px; left:26px;
  width:34px; height:34px; border-radius:50%;
  background:var(--bz-orange); color:var(--bz-navy);
  font-family:var(--bz-head); font-size:15px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 14px rgba(255,165,0,.35); }
.hp-step__icon { width:44px; height:44px; background:var(--bz-orange-bg); border-radius:10px;
  display:flex; align-items:center; justify-content:center; margin-bottom:18px; }
.hp-step__icon svg { width:20px; height:20px; fill:var(--bz-orange); }
.hp-step h3 { font-family:var(--bz-head); font-size:16px; font-weight:700; color:var(--bz-navy); margin-bottom:8px; line-height:1.3; }
.hp-step p { font-size:14px; line-height:1.7; color:var(--bz-text-light); }

/* FOTO-TIPP */
.hp-tipp {
  background:linear-gradient(135deg,var(--bz-navy) 0%,#163660 100%);
  border-radius:var(--bz-radius-lg); padding:32px 36px; margin:48px 0 0;
  display:flex; align-items:center; gap:24px; position:relative; overflow:hidden; color:var(--bz-white);
}
.hp-tipp::before { content:''; position:absolute; right:-20px; top:-20px; width:160px; height:160px;
  background:radial-gradient(circle,rgba(255,165,0,.15) 0%,transparent 70%); }
.hp-tipp__icon { width:56px; height:56px; background:var(--bz-orange); border-radius:12px;
  display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.hp-tipp__icon svg { width:26px; height:26px; fill:var(--bz-navy); }
.hp-tipp__body { flex:1; position:relative; }
.hp-tipp__label { font-family:var(--bz-head); font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.1em; color:var(--bz-orange); margin-bottom:6px; }
.hp-tipp__title { font-family:var(--bz-head); font-size:18px; font-weight:800;
  color:var(--bz-white); margin-bottom:6px; line-height:1.3; }
.hp-tipp__desc { font-size:14px; color:rgba(255,255,255,.78); line-height:1.6; }
.hp-tipp__cta { position:relative; flex-shrink:0; }

/* BRAND GRID */
.hp-brand-head {
  display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:20px;
  margin-bottom:32px;
}
.hp-brand-legend { display:flex; gap:18px; flex-wrap:wrap; align-items:center; }
.hp-legend-item { display:inline-flex; align-items:center; gap:7px;
  font-family:var(--bz-head); font-size:12px; font-weight:700; color:var(--bz-text-light);
  text-transform:uppercase; letter-spacing:.06em; }
.hp-legend-dot { width:10px; height:10px; border-radius:50%; }
.hp-legend-dot--stock { background:var(--bz-green); box-shadow:0 0 0 3px rgba(22,163,74,.18); }
.hp-legend-dot--custom { background:#b8bec7; box-shadow:0 0 0 3px rgba(184,190,199,.25); }

.hp-brands { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; }
.hp-brand-card {
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:26px 22px 22px;
  display:flex; flex-direction:column; gap:12px;
  transition:all .2s; position:relative; overflow:hidden;
}
.hp-brand-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:var(--bz-orange); transform:scaleX(0); transform-origin:left; transition:transform .2s;
}
.hp-brand-card:hover { box-shadow:var(--bz-shadow-lg); border-color:var(--bz-orange); transform:translateY(-3px); }
.hp-brand-card:hover::before { transform:scaleX(1); }
.hp-brand-card__top { display:flex; align-items:center; justify-content:space-between; gap:12px; }
.hp-brand-card__name { font-family:var(--bz-head); font-size:17px; font-weight:800; color:var(--bz-navy); }
.hp-badge {
  display:inline-flex; align-items:center; gap:5px;
  font-family:var(--bz-head); font-size:10.5px; font-weight:700;
  text-transform:uppercase; letter-spacing:.06em;
  padding:4px 9px; border-radius:20px;
}
.hp-badge--stock { background:var(--bz-green-bg); color:#166534; border:1px solid #bbf7d0; }
.hp-badge--custom { background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb; }
.hp-badge-dot { width:6px; height:6px; border-radius:50%; }
.hp-badge--stock .hp-badge-dot { background:var(--bz-green); }
.hp-badge--custom .hp-badge-dot { background:#9ca3af; }
.hp-brand-card__models { font-size:13.5px; line-height:1.65; color:var(--bz-text-light); }
.hp-brand-card__link {
  margin-top:auto; display:inline-flex; align-items:center; gap:6px;
  font-family:var(--bz-head); font-size:12.5px; font-weight:700;
  color:var(--bz-orange); text-transform:uppercase; letter-spacing:.06em;
}
.hp-brand-card__link svg { width:12px; height:12px; fill:var(--bz-orange); transition:transform .18s; }
.hp-brand-card:hover .hp-brand-card__link svg { transform:translateX(3px); }

/* MENGENSTAFFEL */
.hp-pricing { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:40px; }
.hp-price {
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px 24px; text-align:center;
  transition:all .2s; position:relative;
}
.hp-price:hover { border-color:var(--bz-orange); box-shadow:var(--bz-shadow-lg); transform:translateY(-3px); }
.hp-price--featured { border-color:var(--bz-orange); background:linear-gradient(180deg,#fff 0%,#fff9ee 100%); }
.hp-price--featured::before {
  content:'Beliebt'; position:absolute; top:-12px; left:50%; transform:translateX(-50%);
  background:var(--bz-orange); color:var(--bz-navy); font-family:var(--bz-head);
  font-size:10.5px; font-weight:800; text-transform:uppercase; letter-spacing:.08em;
  padding:4px 11px; border-radius:20px;
}
.hp-price__tier { font-family:var(--bz-head); font-size:12px; font-weight:700;
  text-transform:uppercase; letter-spacing:.1em; color:var(--bz-text-light); margin-bottom:10px; }
.hp-price__amount { font-family:var(--bz-head); font-size:34px; font-weight:800; color:var(--bz-navy); line-height:1; margin-bottom:4px; }
.hp-price__unit { font-size:13px; color:var(--bz-text-light); margin-bottom:14px; }
.hp-price__note { font-size:13px; color:var(--bz-text); line-height:1.6; }
.hp-pricing-note { margin-top:20px; font-size:13px; color:var(--bz-text-light); text-align:center; }
.hp-pricing-note a { color:var(--bz-orange); font-weight:700; text-decoration:underline; }

/* MODELL-TABELLE */
.hp-table-wrap { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); overflow:hidden; margin-top:40px; box-shadow:var(--bz-shadow); }
.hp-table { width:100%; border-collapse:collapse; font-size:14px; }
.hp-table thead { background:var(--bz-navy); color:var(--bz-white); }
.hp-table th { padding:16px 20px; text-align:left;
  font-family:var(--bz-head); font-size:12px; font-weight:700;
  text-transform:uppercase; letter-spacing:.08em; }
.hp-table td { padding:16px 20px; border-top:1px solid var(--bz-border); vertical-align:top; }
.hp-table tbody tr:hover { background:var(--bz-gray); }
.hp-table__brand { font-family:var(--bz-head); font-weight:800; color:var(--bz-navy); white-space:nowrap; }
.hp-table__models { color:var(--bz-text); line-height:1.6; }
.hp-table__status { white-space:nowrap; }

/* TECH SPECS */
.hp-specs { display:grid; grid-template-columns:1.15fr .85fr; gap:40px; margin-top:40px; align-items:start; }
.hp-spec-list { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:8px 24px; box-shadow:var(--bz-shadow); }
.hp-spec-row { display:flex; justify-content:space-between; gap:20px; padding:16px 0;
  border-bottom:1px solid var(--bz-border); font-size:14px; line-height:1.5; }
.hp-spec-row:last-child { border-bottom:none; }
.hp-spec-row__k { font-family:var(--bz-head); font-weight:700; color:var(--bz-navy); min-width:140px; }
.hp-spec-row__v { color:var(--bz-text); text-align:right; }
.hp-colors {
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px; box-shadow:var(--bz-shadow);
}
.hp-colors h3 { font-family:var(--bz-head); font-size:15px; font-weight:800; color:var(--bz-navy);
  text-transform:uppercase; letter-spacing:.06em; margin-bottom:18px; }
.hp-color-grid { display:flex; flex-direction:column; gap:14px; }
.hp-color { display:flex; align-items:center; gap:14px; }
.hp-color__chip { width:50px; height:50px; border-radius:var(--bz-radius);
  border:1.5px solid var(--bz-border); flex-shrink:0; box-shadow:inset 0 -3px 8px rgba(0,0,0,.08); }
.hp-color__chip--alu { background:linear-gradient(135deg,#c7ccd1 0%,#a6abb2 100%); }
.hp-color__chip--anthrazit { background:#383d42; }
.hp-color__chip--ziegelrot { background:#8b3a2b; }
.hp-color__meta { font-size:14px; line-height:1.4; }
.hp-color__name { font-family:var(--bz-head); font-weight:700; color:var(--bz-navy); }
.hp-color__ral { font-size:12.5px; color:var(--bz-text-light); }

/* TESTIMONIALS */
.hp-testimonials { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; margin-top:40px; }
.hp-testimonial {
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px 26px;
  display:flex; flex-direction:column; gap:14px; transition:all .2s;
}
.hp-testimonial:hover { box-shadow:var(--bz-shadow-lg); transform:translateY(-3px); border-color:var(--bz-orange); }
.hp-stars { display:flex; gap:2px; }
.hp-stars svg { width:16px; height:16px; fill:var(--bz-orange); }
.hp-testimonial__quote { font-size:14.5px; line-height:1.7; color:var(--bz-text); font-style:italic; }
.hp-testimonial__author { display:flex; align-items:center; gap:12px; margin-top:auto;
  padding-top:14px; border-top:1px solid var(--bz-border); }
.hp-testimonial__avatar { width:38px; height:38px; border-radius:50%;
  background:var(--bz-orange-bg); display:flex; align-items:center; justify-content:center;
  font-family:var(--bz-head); font-weight:800; color:var(--bz-orange); font-size:14px; }
.hp-testimonial__meta { font-size:13px; line-height:1.4; }
.hp-testimonial__name { font-family:var(--bz-head); font-weight:700; color:var(--bz-navy); }
.hp-testimonial__role { font-size:12px; color:var(--bz-text-light); }

/* FAQ */
.hp-faq-layout { display:grid; grid-template-columns:1fr 2fr; gap:56px; align-items:start; }
.hp-faq-list { display:flex; flex-direction:column; gap:12px; }
.hp-faq-item { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius); overflow:hidden; transition:border-color .18s; }
.hp-faq-item.open { border-color:var(--bz-orange); }
.hp-faq-item__q { display:flex; align-items:center; justify-content:space-between; gap:12px;
  padding:18px 20px; cursor:pointer; font-family:var(--bz-head); font-size:14.5px; font-weight:700;
  color:var(--bz-navy); user-select:none; transition:background .15s; list-style:none; }
.hp-faq-item__q::-webkit-details-marker { display:none; }
.hp-faq-item__q:hover, .hp-faq-item.open .hp-faq-item__q { background:var(--bz-gray); }
.hp-faq-item__icon { width:22px; height:22px; background:var(--bz-orange-bg);
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  flex-shrink:0; transition:transform .25s; }
.hp-faq-item.open .hp-faq-item__icon { transform:rotate(45deg); background:var(--bz-orange); }
.hp-faq-item__icon svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-faq-item.open .hp-faq-item__icon svg { fill:var(--bz-navy); }
.hp-faq-item__a { display:none; padding:0 20px 18px; font-size:14px; line-height:1.7; color:var(--bz-text-light); }
.hp-faq-item.open .hp-faq-item__a { display:block; }
.hp-faq-item__a a { color:var(--bz-orange); font-weight:700; text-decoration:underline; }

/* CONTACT CTA */
.hp-cta-final { text-align:center; }
.hp-cta-final .hp-section-sub { margin-left:auto; margin-right:auto; }
.hp-cta-final__buttons { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:28px; }

/* RESPONSIVE */
@media (max-width:1024px) {
  .hp-hero__inner { grid-template-columns:1fr; gap:36px; }
  .hp-brands { grid-template-columns:repeat(2,1fr); }
  .hp-benefits { grid-template-columns:repeat(2,1fr); }
  .hp-pricing { grid-template-columns:1fr; }
  .hp-specs { grid-template-columns:1fr; gap:24px; }
  .hp-testimonials { grid-template-columns:1fr; }
  .hp-faq-layout { grid-template-columns:1fr; gap:24px; }
  .hp-steps { grid-template-columns:1fr; }
}
@media (max-width:640px) {
