<script>
  (function(){
    var drop   = document.getElementById('hp-file-drop');
    var input  = document.getElementById('af-bild');
    var prev   = document.getElementById('hp-file-preview');
    var thumb  = document.getElementById('hp-file-thumb');
    var name   = document.getElementById('hp-file-name');
    var size   = document.getElementById('hp-file-size');
    var remove = document.getElementById('hp-file-remove');
    var form   = document.getElementById('hp-anfrage-form');
    var status = document.getElementById('hp-form-status');
    var submit = document.getElementById('hp-form-submit');
    if (!form) return;

    var MAX = 8 * 1024 * 1024; // 8 MB

    function fmtSize(b){
      if (b < 1024) return b + ' B';
      if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
      return (b/1048576).toFixed(1) + ' MB';
    }
    function showError(msg){
      status.className = 'hp-form-status hp-form-status--error is-visible';
      status.textContent = msg;
      status.scrollIntoView({ behavior:'smooth', block:'center' });
    }
    function clearStatus(){ status.className = 'hp-form-status'; status.textContent = ''; }

    function handleFile(file){
      clearStatus();
      if (!file) return;
      if (file.size > MAX) {
        showError('Datei ist zu groß (' + fmtSize(file.size) + '). Maximal 8 MB.');
        input.value = '';
        return;
      }
      name.textContent = file.name;
      size.textContent = fmtSize(file.size);
      thumb.style.backgroundImage = '';
      if (file.type && file.type.indexOf('image/') === 0) {
        var reader = new FileReader();
        reader.onload = function(e){ thumb.style.backgroundImage = 'url("' + e.target.result + '")'; };
        reader.readAsDataURL(file);
      }
      prev.classList.add('is-visible');
    }

    input.addEventListener('change', function(){ handleFile(input.files[0]); });
    remove.addEventListener('click', function(){
      input.value = ''; prev.classList.remove('is-visible');
      thumb.style.backgroundImage = ''; clearStatus();
    });

    // Drag & drop
    ['dragover','dragenter'].forEach(function(ev){
      drop.addEventListener(ev, function(e){ e.preventDefault(); drop.classList.add('is-drag'); });
    });
    ['dragleave','dragend','drop'].forEach(function(ev){
      drop.addEventListener(ev, function(e){ e.preventDefault(); drop.classList.remove('is-drag'); });
    });
    drop.addEventListener('drop', function(e){
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) {
        input.files = e.dataTransfer.files;
        handleFile(input.files[0]);
      }
    });

    form.addEventListener('submit', function(e){
      clearStatus();
      var ok = form.checkValidity();
      if (!ok) {
        e.preventDefault();
        showError('Bitte alle Pflichtfelder ausfüllen und die Datenschutz-Checkbox bestätigen.');
        var inv = form.querySelector(':invalid'); if (inv) inv.focus();
        return;
      }
      if (input.files[0] && input.files[0].size > MAX) {
        e.preventDefault();
        showError('Bilddatei zu groß. Maximal 8 MB.');
        return;
      }
      submit.disabled = true;
      submit.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v4m0 12v4M6 12H2m20 0h-4m-2.81-6.36l-2.83 2.83m-5.66 5.66l-2.83 2.83m11.32 0l-2.83-2.83m-5.66-5.66L5.64 5.64" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg> Wird gesendet …';
    });
  })();
</script>

