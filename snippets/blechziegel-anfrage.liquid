{% comment %}
  ============================================================
  BLECHZIEGEL.DE — Ziegel-Anfrage Formular
  Snippet: blechziegel-anfrage.liquid
  Layout-DNA: Dachdecker/Gewerbe (hp-* class system)
  Backend: FormSubmit.co (kostenfrei, E-Mail + Datei-Anhang an web@blechziegel.de)
  Eingebunden via sections/main-page.liquid wenn page.handle == 'ziegel-anfrage'
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
.hp {
  --bz-navy:#0a2240; --bz-navy-light:#0d2d54;
  --bz-orange:#ffa500; --bz-orange-dark:#e69400; --bz-orange-bg:rgba(255,165,0,.12);
  --bz-white:#fff; --bz-gray:#f5f5f5; --bz-gray-mid:#e8eaed;
  --bz-text:#333; --bz-text-light:#666; --bz-border:#e5e7eb;
  --bz-green:#16a34a; --bz-red:#dc2626;
  --bz-head:'Montserrat',sans-serif; --bz-body:'Open Sans',sans-serif;
  --bz-radius:8px; --bz-radius-lg:14px; --bz-max:1200px;
  --bz-shadow:0 4px 20px rgba(10,34,64,.10);
  --bz-shadow-lg:0 12px 40px rgba(10,34,64,.18);
  font-family:var(--bz-body); color:var(--bz-text);
}
.hp *, .hp *::before, .hp *::after { box-sizing:border-box; margin:0; padding:0; }
.hp a { text-decoration:none; color:inherit; }
.hp img { max-width:100%; display:block; }
.hp-wrap { max-width:var(--bz-max); margin:0 auto; padding:0 20px; }

/* HERO */
.hp-hero { background:linear-gradient(135deg,var(--bz-navy) 0%,#163660 100%);
  color:var(--bz-white); padding:64px 20px 56px; position:relative; overflow:hidden; }
.hp-hero::before { content:''; position:absolute; inset:0; pointer-events:none;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
.hp-hero__inner { position:relative; max-width:var(--bz-max); margin:0 auto; }
.hp-kicker { display:inline-flex; align-items:center; gap:8px;
  background:var(--bz-orange-bg); border:1px solid rgba(255,165,0,.35);
  color:var(--bz-orange); font-family:var(--bz-head);
  font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  padding:5px 13px; border-radius:20px; margin-bottom:18px; }
.hp-kicker svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-hero h1 { font-family:var(--bz-head); font-size:clamp(26px,3.8vw,42px);
  font-weight:800; line-height:1.2; margin-bottom:16px; color:var(--bz-white); max-width:780px; }
.hp-hero h1 span { color:var(--bz-orange); }
.hp-hero__sub { font-size:16px; line-height:1.7; color:rgba(255,255,255,.85); margin-bottom:24px; max-width:640px; }
.hp-hero__trust { display:flex; flex-wrap:wrap; gap:18px; }
.hp-hero__trust-item { display:flex; align-items:center; gap:7px;
  font-size:12.5px; color:rgba(255,255,255,.78); font-weight:600; }
.hp-hero__trust-item svg { width:14px; height:14px; fill:var(--bz-green); flex-shrink:0; }

/* SECTIONS */
.hp-section { padding:64px 0; }
.hp-section--gray { background:var(--bz-gray); }
.hp-section--white { background:var(--bz-white); }
.hp-section--navy { background:var(--bz-navy); color:var(--bz-white); }
.hp-section-label { font-family:var(--bz-head); font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.12em; color:var(--bz-orange); margin-bottom:8px; display:block; }
.hp-section-title { font-family:var(--bz-head); font-size:clamp(22px,2.8vw,32px);
  font-weight:800; color:var(--bz-navy); line-height:1.25; margin-bottom:10px; }
.hp-section--navy .hp-section-title { color:var(--bz-white); }
.hp-section-sub { font-size:15px; line-height:1.7; color:var(--bz-text-light); max-width:680px; margin-bottom:32px; }
.hp-section--navy .hp-section-sub { color:rgba(255,255,255,.72); max-width:640px; margin:0 auto 28px; }

/* FORM LAYOUT */
.hp-form-layout { display:grid; grid-template-columns:1.4fr .6fr; gap:40px; align-items:start; }
.hp-form-card { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); box-shadow:var(--bz-shadow); overflow:hidden; }
.hp-form-card__head { background:linear-gradient(135deg,var(--bz-navy) 0%,#163660 100%);
  color:var(--bz-white); padding:22px 28px; }
.hp-form-card__head h3 { font-family:var(--bz-head); font-size:18px; font-weight:800; margin-bottom:2px; }
.hp-form-card__head p { font-size:13.5px; color:rgba(255,255,255,.75); }
.hp-form-card__body { padding:32px 32px 28px; }

.hp-form__group { margin-bottom:20px; }
.hp-form__group--span { grid-column:1 / -1; }
.hp-form__grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:0; }
.hp-form__grid-3 { display:grid; grid-template-columns:1.3fr .5fr 1.2fr; gap:16px; margin-bottom:0; }
.hp-form__label { display:block; font-family:var(--bz-head); font-size:12px; font-weight:700;
  text-transform:uppercase; letter-spacing:.06em; color:var(--bz-navy); margin-bottom:6px; }
.hp-form__label .hp-req { color:var(--bz-orange); margin-left:2px; }
.hp-form__input,
.hp-form__textarea,
.hp-form__select {
  width:100%; padding:11px 14px; border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius); font-family:var(--bz-body); font-size:14.5px;
  color:var(--bz-text); background:var(--bz-white);
  transition:border-color .15s, box-shadow .15s; min-height:44px;
}
.hp-form__input:focus,
.hp-form__textarea:focus,
.hp-form__select:focus {
  outline:none; border-color:var(--bz-orange);
  box-shadow:0 0 0 3px rgba(255,165,0,.15);
}
.hp-form__textarea { resize:vertical; min-height:110px; line-height:1.6; }
.hp-form__hint { font-size:12.5px; color:var(--bz-text-light); margin-top:5px; line-height:1.5; }
.hp-form__input-suffix { position:relative; }
.hp-form__input-suffix::after { content:attr(data-suffix); position:absolute;
  right:14px; top:50%; transform:translateY(-50%);
  font-size:13px; color:var(--bz-text-light); font-weight:600; pointer-events:none; }
.hp-form__input-suffix input { padding-right:44px; }

/* FILE UPLOAD */
.hp-file-drop { position:relative; border:2px dashed var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px 22px; text-align:center;
  background:var(--bz-gray); transition:all .2s; cursor:pointer; }
.hp-file-drop:hover,
.hp-file-drop.is-drag { border-color:var(--bz-orange); background:var(--bz-orange-bg); }
.hp-file-drop input[type="file"] { position:absolute; inset:0; opacity:0; cursor:pointer; }
.hp-file-drop__icon { width:48px; height:48px; margin:0 auto 10px;
  background:var(--bz-orange-bg); border-radius:50%;
  display:flex; align-items:center; justify-content:center; }
.hp-file-drop__icon svg { width:22px; height:22px; fill:var(--bz-orange); }
.hp-file-drop__title { font-family:var(--bz-head); font-size:14px; font-weight:800;
  color:var(--bz-navy); margin-bottom:4px; }
.hp-file-drop__hint { font-size:12.5px; color:var(--bz-text-light); line-height:1.45; }
.hp-file-drop__hint strong { color:var(--bz-orange); font-weight:700; }
.hp-file-preview { display:none; margin-top:14px; display:none;
  align-items:center; gap:14px; padding:12px 14px;
  background:var(--bz-white); border:1.5px solid var(--bz-border); border-radius:var(--bz-radius); }
.hp-file-preview.is-visible { display:flex; }
.hp-file-preview__thumb { width:52px; height:52px; background:var(--bz-gray);
  border-radius:6px; background-size:cover; background-position:center; flex-shrink:0; }
.hp-file-preview__meta { flex:1; min-width:0; }
.hp-file-preview__name { font-family:var(--bz-head); font-weight:700; font-size:13.5px;
  color:var(--bz-navy); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.hp-file-preview__size { font-size:12px; color:var(--bz-text-light); }
.hp-file-preview__remove { width:28px; height:28px; border:none; background:var(--bz-gray);
  border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center;
  color:var(--bz-text-light); font-size:18px; line-height:1; flex-shrink:0;
  transition:background .15s, color .15s; padding:0; }
.hp-file-preview__remove:hover { background:var(--bz-red); color:#fff; }

/* CHECKBOX + SUBMIT */
.hp-form__check { display:flex; align-items:flex-start; gap:10px; font-size:13.5px;
  line-height:1.6; color:var(--bz-text); }
.hp-form__check input[type="checkbox"] {
  width:18px; height:18px; margin-top:2px; accent-color:var(--bz-orange); flex-shrink:0;
}
.hp-form__check a { color:var(--bz-orange-dark); font-weight:700; text-decoration:underline; }

.hp-btn { display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:14px 28px; border-radius:var(--bz-radius);
  font-family:var(--bz-head); font-size:14.5px; font-weight:700;
  cursor:pointer; transition:all .2s; border:2px solid transparent; white-space:nowrap;
  min-height:48px; }
.hp-btn svg { width:16px; height:16px; fill:currentColor; flex-shrink:0; }
.hp-btn--primary { background:var(--bz-orange); color:var(--bz-navy); border-color:var(--bz-orange); width:100%; }
.hp-btn--primary:hover { background:var(--bz-orange-dark); border-color:var(--bz-orange-dark); transform:translateY(-1px); box-shadow:0 6px 20px rgba(255,165,0,.3); }
.hp-btn--outline { background:transparent; color:var(--bz-white); border-color:rgba(255,255,255,.4); }
.hp-btn--outline:hover { border-color:var(--bz-white); background:rgba(255,255,255,.08); }

/* SIDE-INFO (right column) */
.hp-info-stack { display:flex; flex-direction:column; gap:16px; position:sticky; top:24px; }
.hp-info-box { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-left:4px solid var(--bz-orange); border-radius:var(--bz-radius-lg);
  padding:22px 24px; box-shadow:var(--bz-shadow); }
.hp-info-box__label { font-family:var(--bz-head); font-size:10.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.1em; color:var(--bz-orange); margin-bottom:6px; }
.hp-info-box__title { font-family:var(--bz-head); font-size:15px; font-weight:800;
  color:var(--bz-navy); margin-bottom:6px; }
.hp-info-box__text { font-size:13.5px; line-height:1.6; color:var(--bz-text-light); }
.hp-info-box__text strong { color:var(--bz-navy); font-weight:700; }
.hp-info-list { display:flex; flex-direction:column; gap:10px; margin-top:10px; }
.hp-info-list li { display:flex; align-items:flex-start; gap:9px; font-size:13.5px; line-height:1.55; color:var(--bz-text); }
.hp-info-list li svg { width:16px; height:16px; fill:var(--bz-orange); flex-shrink:0; margin-top:2px; }

/* SUCCESS / ERROR STATE */
.hp-form-status { display:none; margin-bottom:20px; padding:14px 18px; border-radius:var(--bz-radius);
  font-size:14px; font-weight:600; line-height:1.5; }
.hp-form-status.is-visible { display:block; }
.hp-form-status--success { background:#f0fdf4; border:1.5px solid #86efac; color:#14532d; }
.hp-form-status--error { background:#fef2f2; border:1.5px solid #fca5a5; color:#7f1d1d; }

/* STEPS / HOW-IT-WORKS */
.hp-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; margin-top:36px; }
.hp-step { position:relative; background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:32px 24px 26px; transition:all .2s; }
.hp-step:hover { border-color:var(--bz-orange); box-shadow:var(--bz-shadow-lg); transform:translateY(-3px); }
.hp-step__num { position:absolute; top:-14px; left:24px;
  width:34px; height:34px; border-radius:50%;
  background:var(--bz-orange); color:var(--bz-navy);
  font-family:var(--bz-head); font-size:15px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 14px rgba(255,165,0,.35); }
.hp-step__icon { width:44px; height:44px; background:var(--bz-orange-bg); border-radius:10px;
  display:flex; align-items:center; justify-content:center; margin-bottom:18px; }
.hp-step__icon svg { width:20px; height:20px; fill:var(--bz-orange); }
.hp-step h3 { font-family:var(--bz-head); font-size:16px; font-weight:800; color:var(--bz-navy); margin-bottom:8px; line-height:1.3; }
.hp-step p { font-size:14px; line-height:1.65; color:var(--bz-text-light); }

/* CTA */
.hp-cta-final { text-align:center; }
.hp-cta-final__buttons { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:24px; }

/* RESPONSIVE */
@media (max-width:1024px) {
  .hp-form-layout { grid-template-columns:1fr; gap:28px; }
  .hp-info-stack { position:static; }
  .hp-steps { grid-template-columns:1fr; }
}
@media (max-width:640px) {
  .hp-hero { padding:40px 16px 44px; }
  .hp-hero h1 { font-size:24px; line-height:1.2; }
  .hp-hero__sub { font-size:14.5px; }
  .hp-hero__trust { gap:10px 14px; }
  .hp-hero__trust-item { font-size:12px; }
  .hp-section { padding:36px 0; }
  .hp-section-title { font-size:22px; }
  .hp-wrap { padding:0 16px; }
  .hp-form-card__head { padding:18px 20px; }
  .hp-form-card__body { padding:22px 20px 20px; }
  .hp-form__grid-2 { grid-template-columns:1fr; gap:20px; }
  .hp-form__grid-3 { grid-template-columns:1fr; gap:20px; }
  .hp-info-box { padding:18px 20px; }
  .hp-cta-final__buttons .hp-btn { width:100%; }
}
</style>

{%- liquid
  assign email_raw = 'web@blechziegel.de'
  assign agb_url = '/pages/agb'
  assign datenschutz_url = '/pages/datenschutz'
  assign canonical = shop.url | append: '/pages/ziegel-anfrage'
-%}

<div class="hp">

  <!-- HERO -->
  <section class="hp-hero" aria-labelledby="an-hero-title">
    <div class="hp-wrap hp-hero__inner">
      <div class="hp-kicker">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 0 0-5.5-1.65l-.5.67-.5-.68C11 2.51 10.04 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/></svg>
        Ziegel-Anfrage
      </div>
      <h1 id="an-hero-title">Ihren Ziegel <span>per Foto</span><br>prüfen lassen.</h1>
      <p class="hp-hero__sub">
        Foto und Maße senden — wir identifizieren das passende Profil und melden uns
        mit Angebot und Lieferzeit. Kein Kauf-Druck, keine Registrierung.
      </p>
      <div class="hp-hero__trust">
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>In der Regel Antwort in 24 Std. (Werktage)</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Kostenfrei &amp; unverbindlich</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Prüfung per Foto</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>In Deutschland gelasert</div>
      </div>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section class="hp-section hp-section--gray" aria-labelledby="an-form-title">
    <div class="hp-wrap">
      <span class="hp-section-label">Anfrage-Formular</span>
      <h2 class="hp-section-title" id="an-form-title">Daten eingeben, Foto anhängen — fertig.</h2>
      <p class="hp-section-sub">Alle Pflichtfelder sind mit <span style="color:var(--bz-orange);font-weight:700;">*</span> markiert. Bild bis 8&nbsp;MB in den Formaten JPG, PNG oder HEIC.</p>

      <div class="hp-form-layout">

        <!-- FORM CARD -->
        <div class="hp-form-card">
          <div class="hp-form-card__head">
            <h3>Ziegel-Anfrage</h3>
            <p>Ihre Daten werden ausschließlich zur Bearbeitung dieser Anfrage verwendet.</p>
          </div>
          <div class="hp-form-card__body">

            <div id="hp-form-status" class="hp-form-status" role="status" aria-live="polite"></div>

            <form
              id="hp-anfrage-form"
              action="https://formsubmit.co/{{ email_raw }}"
              method="POST"
              enctype="multipart/form-data"
              novalidate
            >
              <!-- FormSubmit meta -->
              <input type="hidden" name="_subject" value="Neue Ziegel-Anfrage via Website">
              <input type="hidden" name="_captcha" value="false">
              <input type="hidden" name="_template" value="table">
              <input type="hidden" name="_next" value="{{ shop.url }}/pages/anfrage-erfolg">
              <input type="text" name="_honey" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;">

              <!-- Block 1: Foto + Maße (Trigger-first) -->
              <div class="hp-form__group">
                <label class="hp-form__label" for="af-bild">Foto des Ziegels<span class="hp-req">*</span></label>
                <div class="hp-file-drop" id="hp-file-drop">
                  <div class="hp-file-drop__icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                  </div>
                  <div class="hp-file-drop__title">Foto hier ablegen oder <strong>auswählen</strong></div>
                  <div class="hp-file-drop__hint">JPG, PNG oder HEIC · max. 8&nbsp;MB · <strong>Ober- und Unterseite</strong> hilft bei der Identifikation</div>
                  <input type="file" id="af-bild" name="attachment" accept="image/*,.heic,.heif" required>
                </div>
                <div class="hp-file-preview" id="hp-file-preview">
                  <div class="hp-file-preview__thumb" id="hp-file-thumb" aria-hidden="true"></div>
                  <div class="hp-file-preview__meta">
                    <div class="hp-file-preview__name" id="hp-file-name"></div>
                    <div class="hp-file-preview__size" id="hp-file-size"></div>
                  </div>
                  <button type="button" class="hp-file-preview__remove" id="hp-file-remove" aria-label="Datei entfernen">×</button>
                </div>
              </div>

              <div class="hp-form__group hp-form__grid-2">
                <div>
                  <label class="hp-form__label" for="af-laenge">Länge des Ziegels<span class="hp-req">*</span></label>
                  <div class="hp-form__input-suffix" data-suffix="cm">
                    <input class="hp-form__input" id="af-laenge" name="Laenge_cm" type="number" required min="10" max="200" step="0.1" inputmode="decimal" placeholder="42">
                  </div>
                  <div class="hp-form__hint">Längste Seite, gemessen in cm</div>
                </div>
                <div>
                  <label class="hp-form__label" for="af-breite">Breite des Ziegels<span class="hp-req">*</span></label>
                  <div class="hp-form__input-suffix" data-suffix="cm">
                    <input class="hp-form__input" id="af-breite" name="Breite_cm" type="number" required min="10" max="200" step="0.1" inputmode="decimal" placeholder="33">
                  </div>
                  <div class="hp-form__hint">Kürzeste Seite, gemessen in cm</div>
                </div>
              </div>

              <div class="hp-form__group">
                <label class="hp-form__label" for="af-hersteller">Hersteller / Profil <span style="color:var(--bz-text-light);font-weight:600;text-transform:none;letter-spacing:0;font-size:11px;">(optional, falls bekannt)</span></label>
                <input class="hp-form__input" id="af-hersteller" name="Hersteller_Profil" type="text" placeholder="z. B. Braas Frankfurter Pfanne">
                <div class="hp-form__hint">Steht meistens auf der Unterseite des Ziegels.</div>
              </div>

              <!-- Block 2: Kontakt -->
              <div class="hp-form__group hp-form__grid-2">
                <div>
                  <label class="hp-form__label" for="af-vorname">Vorname<span class="hp-req">*</span></label>
                  <input class="hp-form__input" id="af-vorname" name="Vorname" type="text" required autocomplete="given-name">
                </div>
                <div>
