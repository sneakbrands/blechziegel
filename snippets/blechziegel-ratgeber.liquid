<style>
.hp {
  --bz-navy:#0a2240; --bz-navy-light:#0d2d54;
  --bz-orange:#ffa500; --bz-orange-dark:#e69400; --bz-orange-bg:rgba(255,165,0,.12);
  --bz-white:#fff; --bz-gray:#f5f5f5; --bz-gray-mid:#e8eaed;
  --bz-text:#333; --bz-text-light:#666; --bz-border:#e5e7eb;
  --bz-green:#16a34a; --bz-green-bg:#f0fdf4;
  --bz-head:'Montserrat',sans-serif; --bz-body:'Open Sans',sans-serif;
  --bz-radius:8px; --bz-radius-lg:14px; --bz-max:1200px;
  --bz-shadow:0 4px 20px rgba(10,34,64,.10);
  --bz-shadow-lg:0 12px 40px rgba(10,34,64,.18);
  font-family:var(--bz-body); color:var(--bz-text);
}
.hp *, .hp *::before, .hp *::after { box-sizing:border-box; margin:0; padding:0; }
.hp a { text-decoration:none; color:inherit; }
.hp img { max-width:100%; display:block; }
.hp ul { list-style:none; }
.hp-wrap { max-width:var(--bz-max); margin:0 auto; padding:0 20px; }

/* HERO · Foto-Banner mit Navy-Overlay fuer Lesbarkeit */
.hp-hero { background:var(--bz-navy); color:var(--bz-white);
  padding:88px 20px 72px; position:relative; overflow:hidden; min-height:420px; }
.hp-hero__media { position:absolute; inset:0; z-index:0; }
.hp-hero__media img { width:100%; height:100%; object-fit:contain; object-position:center; display:block; }
.hp-hero::before { content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
  background:linear-gradient(135deg, rgba(10,34,64,.82) 0%, rgba(10,34,64,.58) 50%, rgba(10,34,64,.72) 100%); }
.hp-hero::after { content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
.hp-hero__inner { position:relative; z-index:2; max-width:var(--bz-max); margin:0 auto; text-align:left; }
.hp-kicker { display:inline-flex; align-items:center; gap:8px;
  background:var(--bz-orange-bg); border:1px solid rgba(255,165,0,.35);
  color:var(--bz-orange); font-family:var(--bz-head);
  font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  padding:5px 13px; border-radius:20px; margin-bottom:20px; }
.hp-kicker svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-hero h1 { font-family:var(--bz-head); font-size:clamp(28px,4vw,46px);
  font-weight:800; line-height:1.15; margin-bottom:18px; color:var(--bz-white); max-width:820px; }
.hp-hero h1 span { color:var(--bz-orange); }
.hp-hero__sub { font-size:17px; line-height:1.7; color:rgba(255,255,255,.85); margin-bottom:24px; max-width:720px; }
.hp-hero__meta { display:flex; flex-wrap:wrap; gap:22px; font-size:13px; color:rgba(255,255,255,.7); font-family:var(--bz-head); font-weight:600; text-transform:uppercase; letter-spacing:.08em; }
.hp-hero__meta-item { display:inline-flex; align-items:center; gap:7px; }
.hp-hero__meta-item svg { width:14px; height:14px; fill:var(--bz-orange); }

/* SECTIONS */
.hp-section { padding:56px 0; }
.hp-section--gray { background:var(--bz-gray); }
.hp-section--white { background:var(--bz-white); }
.hp-section--navy { background:var(--bz-navy); color:var(--bz-white); }

/* ARTICLE LAYOUT (TOC sidebar + content) */
.hp-article-layout { display:grid; grid-template-columns:260px 1fr; gap:56px; align-items:start; }
.hp-toc { position:sticky; top:24px; background:var(--bz-white);
