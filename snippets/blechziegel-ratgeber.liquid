.hp-cta-bg > .hp-wrap { position:relative; z-index:2; }

/* KEYBOX — highlight for important facts */
.hp-keybox { background:linear-gradient(180deg,#fff9ee 0%,#fff 100%);
  border:1.5px solid rgba(255,165,0,.45); border-left:4px solid var(--bz-orange);
