.hp-toc ol { list-style:none; counter-reset:toc; display:flex; flex-direction:column; gap:3px; }
.hp-toc li { counter-increment:toc; }
.hp-toc a { display:flex; align-items:flex-start; gap:10px;
  padding:8px 10px; border-radius:8px; font-size:13.5px; line-height:1.45; color:var(--bz-text);
  transition:background .16s ease, color .16s ease; font-weight:500; }
.hp-toc a::before { content:counter(toc,decimal-leading-zero); font-family:var(--bz-head);
  font-size:11px; font-weight:800; color:var(--bz-orange); flex-shrink:0; margin-top:2px; }
.hp-toc a:hover { background:var(--bz-orange-bg); color:var(--bz-navy); }

/* ARTICLE CONTENT */
.hp-article { max-width:780px; }
.hp-article > section { margin-bottom:48px; scroll-margin-top:20px; }
.hp-article h2 { font-family:var(--bz-head); font-size:clamp(22px,2.4vw,28px);
