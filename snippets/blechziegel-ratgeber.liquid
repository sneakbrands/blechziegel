      { "@type": "Question", "name": "Wie lange halten Aluminium-Blechziegel?", "acceptedAnswer": { "@type": "Answer", "text": "Bei Qualitätsware aus 1,0 mm pulverbeschichtetem Aluminium: 25 Jahre und mehr." } },
