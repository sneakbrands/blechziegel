{%- comment -%}
  Rendert FAQ-Sektion + FAQPage-JSON-LD fuer eine Produktseite.
  Quelle: product.metafields.custom.faqs (list.metaobject_reference → faq_item).
  faq_item-Felder: question, answer, order.

  Usage:
    {%- render 'bz-product-faq', product: product -%}

  Multilang: alle Felder sind via translationsRegister uebersetzbar.
{%- endcomment -%}

{%- assign faq_list = product.metafields.custom.faqs.value -%}
{%- if faq_list != blank and faq_list.size > 0 -%}

{%- assign faqs_sorted = faq_list | sort: 'order' -%}

<section class="bz-faq" aria-labelledby="bz-faq-title">
  <h2 id="bz-faq-title" class="bz-faq__title">Häufige Fragen</h2>
  <div class="bz-faq__list">
    {%- for faq in faqs_sorted -%}
      <div class="bz-faq__item">
        <h3 class="bz-faq__q">{{ faq.question }}</h3>
        <div class="bz-faq__a">{{ faq.answer }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for faq in faqs_sorted -%}
      {
        "@type": "Question",
        "name": {{ faq.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ faq.answer | strip_html | strip_newlines | json }}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>

<style>
.bz-faq { max-width: 820px; margin: 48px auto; padding: 0 20px; font-family: Inter, system-ui, Arial, sans-serif; color: #000; }
.bz-faq__title { font-family: Montserrat, Arial, sans-serif; letter-spacing: 0.15em; text-transform: uppercase; font-size: 18px; margin: 0 0 24px; padding-bottom: 12px; border-bottom: 1px solid #DFDFDF; }
.bz-faq__item { border-bottom: 1px solid #DFDFDF; padding: 20px 0; }
.bz-faq__item:last-child { border-bottom: none; }
.bz-faq__q { font-family: Inter, Arial, sans-serif; font-size: 16px; font-weight: 600; margin: 0 0 10px; color: #000; line-height: 1.4; }
.bz-faq__a { font-size: 14px; line-height: 1.65; color: rgba(0,0,0,.8); }
.bz-faq__a p { margin: 0 0 10px; }
.bz-faq__a p:last-child { margin: 0; }
</style>

{%- endif -%}
