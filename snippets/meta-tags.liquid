{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- assign _pt_lower = page_title | downcase -%}
  {%- assign _sn_lower = shop.name | downcase -%}
  {%- unless _pt_lower contains _sn_lower %} &ndash; {{ shop.name }}{% endunless -%}
</title>

{%- liquid
  # Canonical-Fallback: nie leer rendern, nie Filter-/Query-Parameter in den
  # Canonical schreiben. Reihenfolge:
  #   1. Shopify-canonical_url (bereinigt, ohne Query)
  #   2. request.origin + request.path  (sicherer Fallback ohne Query)
  assign _canonical = canonical_url | default: ''
  if _canonical contains '?'
    assign _canonical = _canonical | split: '?' | first
  endif
  if _canonical == blank
    assign _canonical = request.origin | append: request.path
  endif

  # Noindex fuer System-/Funktionsseiten, damit kein Index-Bloat entsteht.
  # WICHTIG: /policies/* (Refund, Privacy, Legal Notice, AGB-Shopify) sind
  # rechtliche Pflichtseiten und MUESSEN indexierbar bleiben — nicht ausschliessen.
  assign _noindex_page = false
  if request.page_type == 'search' or request.page_type == 'cart'
    assign _noindex_page = true
  endif
  if request.path contains '/account' or request.path contains '/challenge'
    assign _noindex_page = true
  endif
-%}

{%- if _noindex_page -%}
  <meta name="robots" content="noindex, follow">
{%- endif -%}

<link
  rel="canonical"
  href="{{ _canonical }}"
>

{%- comment -%}
  hreflang: Aktuell DE-only. Solange nur eine Locale publiziert ist, geben wir
  hreflang="de" + x-default auf den Canonical aus — kein Verweis auf nicht
  veroeffentlichte Sprachen, keine 404-Risiken. Sobald shop.published_locales
  weitere Sprachen enthaelt, rendern wir dynamisch je Locale.
{%- endcomment -%}
{%- if shop.published_locales.size > 1 -%}
  {%- for loc in shop.published_locales -%}
    <link rel="alternate" hreflang="{{ loc.iso_code }}" href="{{ request.origin }}{% if loc.primary == false %}/{{ loc.iso_code }}{% endif %}{{ request.path }}">
  {%- endfor -%}
  <link rel="alternate" hreflang="x-default" href="{{ _canonical }}">
{%- else -%}
  <link rel="alternate" hreflang="de" href="{{ _canonical }}">
  <link rel="alternate" hreflang="x-default" href="{{ _canonical }}">
{%- endif -%}

{% if page_description %}
  <meta
    name="description"
    content="{{ page_description | escape }}"
  >
{% endif %}
