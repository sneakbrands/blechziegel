{% comment %}
  ============================================================
  BLECHZIEGEL.DE — Ziegel Finder
  Snippet: blechziegel-ziegel-finder.liquid
  Layout-DNA: Gewerbe-Seite (hp-* Navy/Orange, Montserrat/Open Sans)
  Eingebunden via sections/main-page.liquid wenn page.handle == 'ziegel-finder'

  DATEN-ARCHITEKTUR (metafield-only):
    Quelle: collections.pv-dachziegel.products
    Produkt-Metafields:
      - custom.laenge              (number_integer, mm)
      - custom.breite              (number_integer, mm)
      - custom.passende_hersteller (list.single_line_text_field,
                                    Format "Profil (Hersteller)")
    Der Finder leitet SHOPIFY_PRODUCTS → MFR_MAP ab.
    Keine hartcodierten Hersteller-, Profil- oder Maß-Stammdaten.
    Ergebnis basiert ausschließlich auf echten Produktdaten.
    Nicht abgedeckte Hersteller → Beratungs-CTA (/pages/ziegel-anfrage).
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
.hp {
  --bz-navy:#0a2240; --bz-navy-light:#0d2d54;
  --bz-orange:#ffa500; --bz-orange-dark:#e69400; --bz-orange-bg:rgba(255,165,0,.12);
  --bz-white:#fff; --bz-gray:#f5f5f5; --bz-gray-mid:#e8eaed;
  --bz-text:#333; --bz-text-light:#666; --bz-border:#e5e7eb;
  --bz-green:#16a34a; --bz-green-bg:#f0fdf4;
  --bz-head:'Montserrat',sans-serif; --bz-body:'Open Sans',sans-serif;
  --bz-radius:8px; --bz-radius-lg:14px; --bz-max:1200px;
  --bz-shadow:0 4px 20px rgba(10,34,64,.10);
  --bz-shadow-lg:0 12px 40px rgba(10,34,64,.18);
  font-family:var(--bz-body); color:var(--bz-text);
}
.hp *, .hp *::before, .hp *::after { box-sizing:border-box; margin:0; padding:0; }
.hp a { text-decoration:none; color:inherit; }
.hp img { max-width:100%; display:block; }
.hp ul { list-style:none; }
.hp-wrap { max-width:var(--bz-max); margin:0 auto; padding:0 20px; }

/* HERO */
.hp-hero { background:var(--bz-navy);
  color:var(--bz-white); padding:64px 20px 56px; position:relative; overflow:hidden;
  min-height:450px; }
.hp-hero__media { position:absolute; inset:0; z-index:0; }
.hp-hero__media img { width:100%; height:100%; object-fit:cover; object-position:center; display:block; }
.hp-hero::before { content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
  background:rgba(13,30,53,0.55); }
.hp-hero__inner { position:relative; z-index:2; max-width:var(--bz-max); margin:0 auto; }
.hp-kicker { display:inline-flex; align-items:center; gap:8px;
  background:var(--bz-orange-bg); border:1px solid rgba(255,165,0,.35);
  color:var(--bz-orange); font-family:var(--bz-head);
  font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  padding:5px 13px; border-radius:20px; margin-bottom:18px; }
.hp-kicker svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-hero h1 { font-family:var(--bz-head); font-size:clamp(28px,4vw,46px);
  font-weight:800; line-height:1.15; margin-bottom:16px; color:var(--bz-white); max-width:820px; }
.hp-hero h1 span { color:var(--bz-orange); }
.hp-hero__sub { font-size:0.875rem; line-height:1.7; color:rgba(255,255,255,.85); margin-bottom:24px; max-width:720px; }
.hp-hero__cta { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:28px; }
.hp-hero__trust { display:flex; flex-wrap:wrap; gap:18px; }
.hp-hero__trust-item { display:flex; align-items:center; gap:7px;
  font-size:12.5px; color:rgba(255,255,255,.78); font-weight:600; }
.hp-hero__trust-item svg { width:14px; height:14px; fill:var(--bz-green); flex-shrink:0; }

.hp-btn { display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:14px 26px; border-radius:var(--bz-radius);
  font-family:var(--bz-head); font-size:14px; font-weight:700;
  cursor:pointer; transition:all .2s; border:2px solid transparent; white-space:nowrap; }
.hp-btn svg { width:16px; height:16px; fill:currentColor; flex-shrink:0; }
.hp-btn--primary { background:var(--bz-orange); color:var(--bz-navy); border-color:var(--bz-orange); }
.hp-btn--primary:hover { background:var(--bz-orange-dark); border-color:var(--bz-orange-dark); transform:translateY(-1px); box-shadow:0 6px 20px rgba(255,165,0,.3); }
.hp-btn--outline { background:transparent; color:var(--bz-white); border-color:rgba(255,255,255,.4); }
.hp-btn--outline:hover { border-color:var(--bz-white); background:rgba(255,255,255,.08); }

.hp-section { padding:56px 0; }
.hp-section--gray { background:var(--bz-gray); }
.hp-section--white { background:var(--bz-white); }
.hp-section--navy { background:var(--bz-navy); color:var(--bz-white); }
.hp-section-label { font-family:var(--bz-head); font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.12em; color:var(--bz-orange); margin-bottom:8px; display:block; }
.hp-section-title { font-family:var(--bz-head); font-size:clamp(22px,2.8vw,32px);
  font-weight:800; color:var(--bz-navy); line-height:1.25; margin-bottom:10px; }
.hp-section--navy .hp-section-title { color:var(--bz-white); }
.hp-section-sub { font-size:15px; line-height:1.7; color:var(--bz-text-light); max-width:680px; margin-bottom:32px; }
.hp-section--navy .hp-section-sub { color:rgba(255,255,255,.72); max-width:640px; margin:0 auto 28px; }

/* ═══ FINDER-SHELL ═══ */
.zf { scroll-margin-top:20px; }
.zf-shell { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); box-shadow:var(--bz-shadow-lg); overflow:hidden; }
.zf-steps { display:flex; gap:2px; background:var(--bz-gray-mid); padding:2px; }
.zf-step { flex:1; padding:14px 12px; background:var(--bz-white); text-align:center;
  display:flex; flex-direction:column; align-items:center; gap:4px;
  transition:background .2s, color .2s; font-family:var(--bz-head); cursor:default; }
.zf-step--active { background:var(--bz-navy); color:var(--bz-white); }
.zf-step--done { background:var(--bz-orange-bg); }
.zf-step--done.zf-step--clickable { cursor:pointer; }
.zf-step--done.zf-step--clickable:hover { background:rgba(255,165,0,.2); }
.zf-step__num { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.08em;
  color:var(--bz-orange); display:inline-flex; align-items:center; gap:5px; }
.zf-step--active .zf-step__num { color:var(--bz-orange); }
.zf-step__label { font-size:13px; font-weight:700; color:inherit; }
.zf-step__val { font-size:11.5px; color:var(--bz-text-light); font-weight:600; line-height:1.2; min-height:14px; }
.zf-step--active .zf-step__val { color:rgba(255,255,255,.7); }
.zf-step--done .zf-step__val { color:var(--bz-orange-dark); }

.zf-body { padding:36px 32px; }
.zf-body__head { text-align:center; margin-bottom:28px; }
.zf-body__head h2 { font-family:var(--bz-head); font-size:22px; font-weight:800; color:var(--bz-navy); margin-bottom:6px; }
.zf-body__head p { font-size:14.5px; color:var(--bz-text-light); max-width:520px; margin:0 auto; line-height:1.6; }

/* Options-Grid (Cards / Chips) */
.zf-options { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:12px; }
.zf-option { display:flex; flex-direction:column; align-items:flex-start; gap:6px;
  padding:18px 18px; background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); cursor:pointer; text-align:left;
  transition:all .18s; font-family:var(--bz-body); position:relative; }
.zf-option:hover,
.zf-option:focus-visible { border-color:var(--bz-orange); box-shadow:0 6px 20px rgba(255,165,0,.18); transform:translateY(-2px); }
.zf-option:focus-visible { outline:2px solid var(--bz-orange); outline-offset:2px; }
.zf-option__name { font-family:var(--bz-head); font-size:15px; font-weight:800; color:var(--bz-navy); line-height:1.3; }
.zf-option__meta { font-size:12.5px; color:var(--bz-text-light); font-weight:500; }
.zf-option__badge { position:absolute; top:10px; right:10px;
  font-family:var(--bz-head); font-size:9.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.08em;
  padding:3px 7px; border-radius:10px; }
.zf-option__badge--stock { background:var(--bz-green-bg); color:#166534; border:1px solid #bbf7d0; }
.zf-option__badge--request { background:#f3f4f6; color:#4b5563; border:1px solid #e5e7eb; }

.zf-options--measure .zf-option { align-items:center; text-align:center; padding:22px 16px; }
.zf-options--measure .zf-option__name { font-size:22px; }
.zf-options--measure .zf-option__meta { text-align:center; }

/* Back-Button */
.zf-back { display:inline-flex; align-items:center; gap:6px;
  background:none; border:none; padding:8px 0; margin-bottom:16px;
  font-family:var(--bz-head); font-size:12.5px; font-weight:700;
  text-transform:uppercase; letter-spacing:.06em; color:var(--bz-text-light);
  cursor:pointer; transition:color .15s; }
.zf-back:hover { color:var(--bz-orange); }
.zf-back svg { width:14px; height:14px; }

/* ══ ERGEBNIS ══ */
.zf-result { }
.zf-result-card { display:grid; grid-template-columns:260px 1fr; gap:28px;
  background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:28px; margin-bottom:16px;
  box-shadow:var(--bz-shadow); align-items:stretch; }
.zf-result-card__img { border-radius:var(--bz-radius); overflow:hidden;
  background:var(--bz-gray); display:flex; align-items:center; justify-content:center;
  min-height:220px; }
.zf-result-card__img img { width:100%; height:100%; object-fit:cover; display:block; }
.zf-result-card__body { display:flex; flex-direction:column; gap:10px; }
.zf-result-card__pills { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:4px; }
.zf-result-card__pill { display:inline-flex; align-items:center; gap:5px;
  padding:4px 10px; background:var(--bz-orange-bg); color:var(--bz-orange-dark);
  font-family:var(--bz-head); font-size:11.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.06em; border-radius:14px; }
.zf-result-card__title { font-family:var(--bz-head); font-size:22px; font-weight:800;
  color:var(--bz-navy); line-height:1.25; }
.zf-result-card__desc { font-size:14.5px; line-height:1.65; color:var(--bz-text); }
.zf-result-card__specs { display:flex; flex-wrap:wrap; gap:6px 18px;
  padding:10px 0; border-top:1px solid var(--bz-border); border-bottom:1px solid var(--bz-border);
  margin:6px 0; font-size:13px; color:var(--bz-text-light); }
.zf-result-card__specs strong { color:var(--bz-navy); font-weight:700; }
.zf-result-card__price { font-family:var(--bz-head); font-size:20px; font-weight:800; color:var(--bz-navy); }
.zf-result-card__price span { font-size:12.5px; font-weight:600; color:var(--bz-text-light); margin-left:4px; }
.zf-result-card__actions { display:flex; gap:10px; flex-wrap:wrap; margin-top:auto; padding-top:6px; }
.zf-result-card__actions .hp-btn { flex:0 0 auto; }
.zf-result-card__actions .hp-btn--secondary {
  background:transparent; color:var(--bz-navy); border-color:var(--bz-border); }
.zf-result-card__actions .hp-btn--secondary:hover { border-color:var(--bz-navy); background:var(--bz-gray); }

/* Beratung / Kein-Treffer */
.zf-help { background:var(--bz-navy); color:var(--bz-white);
  border-radius:var(--bz-radius-lg); padding:28px 32px; display:grid;
  grid-template-columns:48px 1fr auto; gap:18px; align-items:center; margin-top:18px; }
.zf-help__icon { width:48px; height:48px; background:var(--bz-orange); border-radius:50%;
  display:flex; align-items:center; justify-content:center; }
.zf-help__icon svg { width:24px; height:24px; fill:var(--bz-navy); }
.zf-help__title { font-family:var(--bz-head); font-size:16px; font-weight:800; margin-bottom:4px; }
.zf-help__sub { font-size:13.5px; line-height:1.55; color:rgba(255,255,255,.72); }
.zf-help__cta { display:inline-flex; align-items:center; gap:6px;
  background:var(--bz-orange); color:var(--bz-navy); padding:12px 20px;
  border-radius:var(--bz-radius); font-family:var(--bz-head); font-size:13.5px; font-weight:800; }
.zf-help__cta:hover { background:var(--bz-orange-dark); }

/* Tipps über Finder */
.zf-tips { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:28px; }
.zf-tip { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:22px 22px; transition:all .2s; }
.zf-tip:hover { border-color:var(--bz-orange); transform:translateY(-2px); box-shadow:var(--bz-shadow); }
.zf-tip__icon { width:36px; height:36px; background:var(--bz-orange-bg); border-radius:10px;
  display:flex; align-items:center; justify-content:center; margin-bottom:12px; }
.zf-tip__icon svg { width:18px; height:18px; fill:var(--bz-orange); }
.zf-tip__title { font-family:var(--bz-head); font-size:14.5px; font-weight:800; color:var(--bz-navy); margin-bottom:6px; }
.zf-tip__text { font-size:13px; line-height:1.6; color:var(--bz-text-light); }

/* Empty/Loading States */
.zf-empty { text-align:center; padding:44px 20px; color:var(--bz-text-light); font-size:14px; }

/* Tiles-Only-View (Manufacturer Tiles) */
.zf-mfr-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px; }

/* Beratungs-Sektion am Ende */
.zf-consult-section .zf-help { background:linear-gradient(135deg,#163660 0%,#0a2240 100%); }

@media (max-width:900px) {
  .zf-body { padding:26px 20px; }
  .zf-steps { overflow-x:auto; -webkit-overflow-scrolling:touch; }
  .zf-step { min-width:112px; padding:10px 8px; }
  .zf-step__label { font-size:12px; }
  .zf-step__val { font-size:10.5px; }
  .zf-options { grid-template-columns:repeat(2, 1fr); }
  .zf-options--measure { grid-template-columns:repeat(3, 1fr); }
  .zf-result-card { grid-template-columns:1fr; padding:22px; }
  .zf-result-card__img { min-height:200px; }
  .zf-help { grid-template-columns:1fr; text-align:center; padding:22px; }
  .zf-help__icon { margin:0 auto; }
  .zf-help__cta { justify-self:center; }
  .zf-tips { grid-template-columns:1fr; }
}
@media (max-width:480px) {
  .zf-options { grid-template-columns:1fr; }
  .zf-options--measure { grid-template-columns:repeat(2, 1fr); }
  .zf-options--measure .zf-option__name { font-size:18px; }
}
@media (max-width:640px) {
  .hp-hero { min-height:300px; padding:44px 16px 48px; }
  .hp-hero__media img { object-position:right center; }
}
</style>

{%- liquid
  assign anfrage_url = '/pages/ziegel-anfrage'
  assign hersteller_url = '/pages/hersteller'
  assign canonical = shop.url | append: '/pages/ziegel-finder'
-%}

<div class="hp">

  <!-- HERO -->
  <section class="hp-hero" aria-labelledby="zf-hero-title">
    <div class="hp-hero__media" aria-hidden="true">
      <picture>
        <source
          type="image/webp"
          srcset="{{ 'blechziegel-ziegel-finder-hero-1024.webp' | asset_url }} 1024w,
                  {{ 'blechziegel-ziegel-finder-hero-1440.webp' | asset_url }} 1440w,
                  {{ 'blechziegel-ziegel-finder-hero-1920.webp' | asset_url }} 1920w"
          sizes="100vw">
        <img
          src="{{ 'blechziegel-ziegel-finder-hero-1920.jpg' | asset_url }}"
          srcset="{{ 'blechziegel-ziegel-finder-hero-1024.jpg' | asset_url }} 1024w,
                  {{ 'blechziegel-ziegel-finder-hero-1440.jpg' | asset_url }} 1440w,
                  {{ 'blechziegel-ziegel-finder-hero-1920.jpg' | asset_url }} 1920w"
          sizes="100vw"
          alt="Dachziegel-Unterseite mit Herstellerprägung wird mit Aluminium-Blechziegel-Profilen auf Werkbank verglichen – Ziegel Finder bei blechziegel.de"
          title="Ziegel Finder – Passenden Blechziegel nach Hersteller und Ziegeltyp finden"
          width="1920" height="814"
          loading="eager" fetchpriority="high" decoding="async">
      </picture>
    </div>
    <div class="hp-wrap hp-hero__inner">
      <div class="hp-kicker">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 5 1.5-1.5-5-5zm-6 0a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/></svg>
        Ziegel Finder
      </div>
      <h1 id="zf-hero-title">Passenden <span>Blechziegel finden.</span><br>In drei Schritten zum richtigen Produkt.</h1>
      <p class="hp-hero__sub">
        Wählen Sie Hersteller und Ziegeltyp/Modell Ihres Dachziegels — beides steht meistens auf der Unterseite eingeprägt. Der Finder führt Sie zum passenden Aluminium-Blechziegel.
      </p>
      <div class="hp-hero__cta">
        <a href="#zf-app" class="hp-btn hp-btn--primary">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 5 1.5-1.5-5-5zm-6 0a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/></svg>
          Finder starten
        </a>
        <a href="{{ anfrage_url }}" class="hp-btn hp-btn--outline">
          Foto schicken statt Finder
        </a>
      </div>
      <div class="hp-hero__trust">
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Passendes Produkt direkt finden</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Auswahl nach Hersteller &amp; Ziegeltyp</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Sonderanfertigungen möglich</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Rückmeldung in der Regel in 24 Std. (Werktage)</div>
      </div>
    </div>
  </section>

  <!-- FINDER -->
  <section id="zf-app" class="hp-section hp-section--gray zf" aria-labelledby="zf-finder-title">
    <div class="hp-wrap">
      <span class="hp-section-label">Schritt für Schritt</span>
      <h2 class="hp-section-title" id="zf-finder-title">Ihren Blechziegel finden</h2>
      <p class="hp-section-sub">Hersteller und Modell stehen meistens auf der Unterseite eines Dachziegels. Der Finder zeigt Hersteller und Ziegeltypen/Modelle, die aus unseren aktuell gepflegten Produktdaten ableitbar sind. Für nicht gelistete Profile: Beratung per Foto-Anfrage.</p>

      <div class="zf-shell" role="region" aria-label="Ziegel Finder">
        <nav class="zf-steps" aria-label="Finder-Fortschritt">
          <div class="zf-step zf-step--active" data-step-ind="1" role="button" tabindex="-1">
            <span class="zf-step__num">01</span>
            <span class="zf-step__label">Hersteller</span>
            <span class="zf-step__val" data-val="1"></span>
          </div>
          <div class="zf-step" data-step-ind="2" role="button" tabindex="-1">
            <span class="zf-step__num">02</span>
            <span class="zf-step__label">Ziegeltyp / Modell</span>
            <span class="zf-step__val" data-val="2"></span>
          </div>
          <div class="zf-step" data-step-ind="3" role="button" tabindex="-1">
            <span class="zf-step__num">03</span>
            <span class="zf-step__label">Ergebnis</span>
            <span class="zf-step__val" data-val="3"></span>
          </div>
        </nav>

        <div class="zf-body" id="zf-body">
          <div class="zf-empty">Finder wird geladen…</div>
        </div>
      </div>

      <!-- Tipps unter dem Finder -->
      <div class="zf-tips">
        <div class="zf-tip">
          <div class="zf-tip__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 5 1.5-1.5-5-5zm-6 0a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/></svg></div>
          <div class="zf-tip__title">Hersteller identifizieren</div>
          <div class="zf-tip__text">Auf der Unterseite fast jedes Dachziegels sind Hersteller und Modellname eingeprägt.</div>
        </div>
        <div class="zf-tip">
          <div class="zf-tip__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H6V4h12v16zM8 9h8v2H8zm0 4h8v2H8z"/></svg></div>
          <div class="zf-tip__title">Modell ablesen</div>
          <div class="zf-tip__text">Direkt unter dem Hersteller steht meistens der Ziegeltyp, z.&nbsp;B. „Harzer Pfanne", „Frankfurter Pfanne" oder „Rubin 13".</div>
        </div>
        <div class="zf-tip">
          <div class="zf-tip__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 2L7.2 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.2L15 2H9zm3 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/></svg></div>
          <div class="zf-tip__title">Unsicher? Foto senden</div>
          <div class="zf-tip__text">Foto von Ober- und Unterseite per <a href="{{ anfrage_url }}" style="color:var(--bz-orange-dark);font-weight:700;">Anfrage-Formular</a> — Rückmeldung in der Regel innerhalb von 24 Stunden (Werktage).</div>
        </div>
      </div>

    </div>
  </section>

  <!-- BERATUNG / UNSICHER -->
  <section class="hp-section hp-section--white zf-consult-section" aria-labelledby="zf-consult-title">
    <div class="hp-wrap">
      <span class="hp-section-label">Unsicher?</span>
      <h2 class="hp-section-title" id="zf-consult-title">Persönliche Beratung statt Finder</h2>
      <p class="hp-section-sub">Sie haben einen Ziegel, den Sie nicht eindeutig zuordnen können? Kein Problem — wir identifizieren das Profil anhand eines Fotos und melden uns in der Regel innerhalb von 24 Stunden (Werktage).</p>
      <div class="zf-help">
        <div class="zf-help__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
        <div>
          <div class="zf-help__title">Ihr Ziegel per Foto identifizieren lassen</div>
          <div class="zf-help__sub">Foto von Ober- und Unterseite genügt. Wir nennen Ihnen Hersteller, Ziegeltyp/Modell und den passenden Blechziegel.</div>
        </div>
        <a class="zf-help__cta" href="{{ anfrage_url }}">
          Anfrage starten
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="currentColor"><path d="M13 6l6 6-6 6M5 12h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  {%- if page.content != blank -%}
  <!-- PAGE-CONTENT (Intro + FAQ, multilang-ready via page.body_html) -->
  <section class="hp-section hp-section--white zf-pagecontent" aria-label="Ziegel-Finder FAQ">
    <div class="hp-wrap" style="max-width:820px;">
      <div class="zf-pagecontent__inner" style="font-size:16px;line-height:1.65;color:var(--bz-text);">
        {{ page.content }}
      </div>
    </div>
  </section>
  {%- endif -%}

</div>

<script>
  (function(){
    /* ══ DATEN ══
       SHOPIFY_PRODUCTS: aus assets/ziegel-finder-data.json (per Admin-API-Build).
       Umgeht das 50-Produkt-Limit von Liquid-collections und liefert alle 143
       aktiv gepflegten Ziegel-Produkte.
    */
    var DATA_URL = {{ 'ziegel-finder-data.json' | asset_url | json }};
    var SHOPIFY_PRODUCTS = [];

    /* ══ MFR_MAP ══
       Abgeleitet aus SHOPIFY_PRODUCTS (Asset ziegel-finder-data.json).
       Datenquelle ist `matches` pro Produkt — bereits normalisiert auf
       {profil, hersteller}-Paare im Build-Skript.

       Zielstruktur (3-Schritt-Flow):
         MFR_MAP[hersteller] = [ { profil, products: [product, ...] }, ... ]
         — gruppiert nach Hersteller + Profil, dedupliziert per product.handle.
    */
    var MFR_MAP = {};
    function buildMfrMap(){
      MFR_MAP = {};
      // tmp: hersteller -> profil -> { profil, productsByHandle:{} }
      var tmp = {};
      SHOPIFY_PRODUCTS.forEach(function(p){
        if (!p || !p.handle) return;
        if (!Array.isArray(p.matches)) return;
        // Dedupliziere matches pro Produkt nach hersteller|profil
        var seenPair = {};
        p.matches.forEach(function(m){
          if (!m || !m.hersteller || !m.profil) return;
          var hersteller = String(m.hersteller).trim();
          var profil = String(m.profil).trim();
          if (!hersteller || !profil) return;
          var pairKey = hersteller + '|' + profil;
          if (seenPair[pairKey]) return;
          seenPair[pairKey] = true;

          if (!tmp[hersteller]) tmp[hersteller] = {};
          if (!tmp[hersteller][profil]) tmp[hersteller][profil] = { profil: profil, productsByHandle: {} };
          tmp[hersteller][profil].productsByHandle[p.handle] = p;
        });
      });

      Object.keys(tmp).forEach(function(h){
        var profiles = Object.keys(tmp[h]).sort(function(a,b){ return a.localeCompare(b, 'de'); });
        MFR_MAP[h] = profiles.map(function(profName){
          var entry = tmp[h][profName];
          var products = Object.keys(entry.productsByHandle).map(function(k){ return entry.productsByHandle[k]; });
          return { profil: entry.profil, products: products };
        });
      });
    }

    var body = document.getElementById('zf-body');
    var stepsEls = document.querySelectorAll('.zf-step');
    var state = { step:1, mfrName:null, profil:null };

    function updateStepper() {
      stepsEls.forEach(function(el, i){
        var idx = i + 1;
        el.classList.remove('zf-step--active','zf-step--done','zf-step--clickable');
        if (idx < state.step) { el.classList.add('zf-step--done'); el.classList.add('zf-step--clickable'); }
        if (idx === state.step) el.classList.add('zf-step--active');
      });
      var v1 = document.querySelector('[data-val="1"]'); if (v1) v1.textContent = state.mfrName || '';
      var v2 = document.querySelector('[data-val="2"]'); if (v2) v2.textContent = state.profil || '';
      var v3 = document.querySelector('[data-val="3"]'); if (v3) v3.textContent = '';
    }

    function goto(step) {
      // Reset deeper state when jumping back
      if (step <= 1) { state.mfrName = null; state.profil = null; }
      if (step <= 2) { state.profil = null; }
      state.step = step;
      updateStepper();
      render();
      var shell = document.querySelector('.zf-shell');
      if (shell) {
        var r = shell.getBoundingClientRect();
        if (r.top < 0 || r.top > window.innerHeight - 200) {
          shell.scrollIntoView({ behavior:'smooth', block:'start' });
        }
      }
      if (typeof window.dataLayer !== 'undefined') {
        window.dataLayer.push({ event:'ziegel_finder_step', step: step, mfrName: state.mfrName, profil: state.profil });
      }
    }

    stepsEls.forEach(function(el){
      el.addEventListener('click', function(){
        var target = parseInt(el.dataset.stepInd, 10);
        if (target < state.step) goto(target);
      });
    });

    /* ══ RENDER ══ */
    function esc(s){ return String(s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }

    // Suchnormalisierung: lowercase, Umlaute, ß, diakritische Zeichen
    function normalize(s) {
      if (!s) return '';
      var v = String(s).toLowerCase();
      v = v.replace(/ä/g,'ae').replace(/ö/g,'oe').replace(/ü/g,'ue').replace(/ß/g,'ss');
      try { v = v.normalize('NFD').replace(/[̀-ͯ]/g, ''); } catch (e) {}
      return v.replace(/\s+/g,' ').trim();
    }

    function backBtn(toStep, label) {
      return '<button type="button" class="zf-back" data-goto="' + toStep + '">'+
        '<svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M11.67 3.87L9.9 2.1 0 12l9.9 9.9 1.77-1.77L3.54 12z"/></svg>'+
        esc(label) + '</button>';
    }

    function formatPrice(n) {
      if (typeof n !== 'number' || !isFinite(n)) return null;
      return 'ab ' + n.toFixed(2).replace('.', ',') + ' €';
    }

    function consultBlock() {
      return '<div class="zf-help">'+
        '<div class="zf-help__icon"><svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div>'+
        '<div>'+
          '<div class="zf-help__title">Unsicher, ob das Profil wirklich passt?</div>'+
          '<div class="zf-help__sub">Foto von Ober- und Unterseite reicht uns — Rückmeldung in der Regel innerhalb von 24 Stunden (Werktage).</div>'+
        '</div>'+
        '<a class="zf-help__cta" href="{{ anfrage_url }}">Foto senden</a>'+
      '</div>';
    }

    function renderStep1() {
      var names = Object.keys(MFR_MAP).sort(function(a,b){ return a.localeCompare(b, 'de'); });

      if (names.length === 0) {
        body.innerHTML =
          '<div class="zf-body__head">'+
            '<h2>1. Hersteller wählen</h2>'+
          '</div>'+
          '<article class="zf-result-card" style="grid-template-columns:1fr;">'+
            '<div class="zf-result-card__body">'+
              '<div class="zf-result-card__title">Noch keine Blechziegel-Produkte gepflegt</div>'+
              '<div class="zf-result-card__desc">Sobald Produkte mit passenden Hersteller-Profilen im Shop sind, erscheinen sie hier automatisch. Bis dahin: Beratung anfragen — wir identifizieren Ihr Profil per Foto.</div>'+
              '<div class="zf-result-card__actions">'+
                '<a class="hp-btn hp-btn--primary" href="{{ anfrage_url }}">Beratung anfragen</a>'+
              '</div>'+
            '</div>'+
          '</article>';
        return;
      }

      var html = '<div class="zf-body__head">'+
        '<h2>1. Hersteller wählen</h2>'+
        '<p>Welcher Hersteller steht auf Ihrem Dachziegel? Der Name ist häufig auf der Unterseite eingeprägt.</p></div>'+
        '<div class="zf-options zf-mfr-grid" role="radiogroup" aria-label="Hersteller auswählen">';
      names.forEach(function(n){
        var count = MFR_MAP[n].length;
        var label = count === 1 ? '1 Ziegeltyp' : count + ' Ziegeltypen';
        html += '<button type="button" class="zf-option" role="radio" data-mfr="'+ esc(n) +'">'+
          '<span class="zf-option__name">' + esc(n) + '</span>'+
          '<span class="zf-option__meta">' + label + '</span>'+
          '<span class="zf-option__badge zf-option__badge--stock">Ab Lager</span>'+
          '</button>';
      });
      html += '</div>';

      html += '<div style="text-align:center; margin-top:22px; padding-top:18px; border-top:1px solid var(--bz-border);">'+
        '<a href="{{ anfrage_url }}" class="hp-btn hp-btn--primary" style="background:transparent; color:var(--bz-navy); border-color:var(--bz-border);">'+
          'Mein Hersteller ist nicht dabei? Foto senden / Beratung anfragen →'+
        '</a></div>';

      body.innerHTML = html;
      body.querySelectorAll('[data-mfr]').forEach(function(btn){
        btn.addEventListener('click', function(){
          state.mfrName = btn.dataset.mfr;
          goto(2);
        });
      });
    }

    function renderStep2() {
      var profiles = MFR_MAP[state.mfrName] || [];

      var html = backBtn(1, 'Hersteller ändern') +
        '<div class="zf-body__head">'+
        '<h2>2. Ziegeltyp / Modell wählen — ' + esc(state.mfrName) + '</h2>'+
        '<p>Wählen Sie den Ziegeltyp, der auf Ihrem Dachziegel steht, z.&nbsp;B. Harzer Pfanne, Rubin 13 oder Frankfurter Pfanne.</p></div>';

      // Empty-State: Hersteller hat keine Profile
      if (profiles.length === 0) {
        html += '<div class="zf-empty" data-zf-empty>Für <strong>' + esc(state.mfrName) + '</strong> sind aktuell keine Ziegeltypen hinterlegt.</div>';
        html += consultBlock();
        body.innerHTML = html;
        attachBack();
        return;
      }

      // Suchfeld
      html += '<div style="margin-bottom:18px;">'+
        '<label for="zf-profil-search" class="visually-hidden" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);">Ziegeltyp suchen</label>'+
        '<input id="zf-profil-search" type="search" autocomplete="off" '+
          'placeholder="Modell suchen, z. B. Harzer Pfanne" '+
          'aria-label="Ziegeltyp suchen" '+
          'style="width:100%;padding:12px 16px;border:1.5px solid var(--bz-border);border-radius:var(--bz-radius);font:inherit;font-size:15px;background:var(--bz-white);color:var(--bz-text);">'+
        '</div>';

      html += '<div class="zf-options zf-mfr-grid" role="radiogroup" aria-label="Ziegeltyp auswählen" data-zf-profil-list>';
      profiles.forEach(function(entry){
        var count = entry.products.length;
        var meta = count === 1 ? '1 passendes Produkt' : count + ' passende Produkte';
        // Such-Haystack: profil + alle Produkt-Titel
        var haystack = entry.profil;
        entry.products.forEach(function(p){ if (p && p.title) haystack += ' ' + p.title; });
        html += '<button type="button" class="zf-option" role="radio" data-profil="'+ esc(entry.profil) +'" data-haystack="'+ esc(normalize(haystack)) +'">'+
          '<span class="zf-option__name">' + esc(entry.profil) + '</span>'+
          '<span class="zf-option__meta">' + meta + '</span>'+
          '<span class="zf-option__meta" style="font-size:11.5px;opacity:.75;">Maße werden im Ergebnis angezeigt</span>'+
          '</button>';
      });
      html += '</div>';

      html += '<div data-zf-no-match style="display:none;">'+
        '<div class="zf-empty">Kein passender Ziegeltyp gefunden.</div>'+
        consultBlock() +
      '</div>';

      body.innerHTML = html;

      // Such-Filter
      var input = document.getElementById('zf-profil-search');
      var list = body.querySelector('[data-zf-profil-list]');
      var noMatch = body.querySelector('[data-zf-no-match]');
      function applyFilter() {
        var q = normalize(input.value);
        var visible = 0;
        list.querySelectorAll('[data-haystack]').forEach(function(el){
          var hit = !q || el.dataset.haystack.indexOf(q) !== -1;
          el.style.display = hit ? '' : 'none';
          if (hit) visible++;
        });
        if (noMatch) noMatch.style.display = visible === 0 ? '' : 'none';
        if (list) list.style.display = visible === 0 ? 'none' : '';
      }
      input.addEventListener('input', applyFilter);

      body.querySelectorAll('[data-profil]').forEach(function(btn){
        btn.addEventListener('click', function(){
          state.profil = btn.dataset.profil;
          goto(3);
        });
      });
      attachBack();

      // Autofocus auf Suchfeld auf Desktop (nicht auf Mobile, damit kein Keyboard aufpoppt)
      if (window.matchMedia && window.matchMedia('(min-width: 901px)').matches) {
        try { input.focus({ preventScroll: true }); } catch(e) { input.focus(); }
      }
    }

    function renderResult() {
      var profiles = MFR_MAP[state.mfrName] || [];
      var entry = null;
      for (var i = 0; i < profiles.length; i++) {
        if (profiles[i].profil === state.profil) { entry = profiles[i]; break; }
      }
      var products = entry ? entry.products.slice() : [];

      var html = backBtn(2, 'Ziegeltyp ändern');
      html += '<div class="zf-body__head">'+
        '<h2>Ihr passender Blechziegel</h2>'+
        '<p>' + esc(state.mfrName) + ' · ' + esc(state.profil || '') + '</p></div>'+
        '<div class="zf-result">';

      if (products.length === 0) {
        html += '<div class="zf-empty">Für diesen Ziegeltyp ist aktuell kein Produkt hinterlegt.</div>';
      }

      // Sortierung: stabil nach Titel (deutsch)
      products.sort(function(a,b){ return String(a.title||'').localeCompare(String(b.title||''), 'de'); });

      var seen = {};
      var productCards = 0;
      products.forEach(function(p){
        if (!p || !p.handle || seen[p.handle]) return;
        seen[p.handle] = true;
        productCards++;
        var priceLabel = formatPrice(p.price_min);
        var hasDims = (typeof p.laenge === 'number' && p.laenge > 0 && typeof p.breite === 'number' && p.breite > 0);
        html += '<article class="zf-result-card">'+
          '<div class="zf-result-card__img">' + (p.image ? '<img src="' + esc(p.image) + '" alt="' + esc(p.title) + '" loading="lazy">' : '') + '</div>'+
          '<div class="zf-result-card__body">'+
            '<div class="zf-result-card__pills">'+
              '<span class="zf-result-card__pill">Ab Lager</span>'+
              '<span class="zf-result-card__pill" style="background:#dbeafe;color:#1e3a8a">' + esc(state.mfrName) + '</span>'+
              '<span class="zf-result-card__pill" style="background:#f3f4f6;color:#374151">' + esc(state.profil) + '</span>'+
            '</div>'+
            '<div class="zf-result-card__title">' + esc(p.title || '') + '</div>'+
            '<div class="zf-result-card__desc">' + esc(p.desc || '') + '</div>'+
            '<div class="zf-result-card__specs">'+
              '<span>Ziegeltyp: <strong>' + esc(state.profil) + '</strong></span>'+
              (hasDims ? '<span>Technische Maße: <strong>' + p.laenge + ' × ' + p.breite + ' mm</strong></span>' : '') +
            '</div>'+
            (priceLabel
              ? '<div class="zf-result-card__price">' + priceLabel + '<span>pro Stück</span></div>'
              : '<div class="zf-result-card__price" style="font-size:14px;color:var(--bz-text-light);font-weight:600;">Preis im Produkt</div>') +
            '<div class="zf-result-card__actions">'+
              (p.url ? '<a class="hp-btn hp-btn--primary" href="' + esc(p.url) + '">Zum Produkt</a>' : '') +
              '<a class="hp-btn hp-btn--secondary" href="{{ anfrage_url }}">Beratung anfragen</a>'+
            '</div>'+
          '</div>'+
        '</article>';
      });

      html += consultBlock();
      html += '</div>';

      html += '<div style="margin-top:18px; text-align:center;">'+
        '<button type="button" class="zf-back" data-goto="1" style="display:inline-flex;">'+
          '<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>'+
          'Neu starten'+
        '</button></div>';

      body.innerHTML = html;
      attachBack();

      if (typeof window.dataLayer !== 'undefined') {
        window.dataLayer.push({
          event: 'ziegel_finder_result',
          mfrName: state.mfrName,
          profil: state.profil,
          product_matches: productCards
        });
      }
    }

    function attachBack() {
      body.querySelectorAll('[data-goto]').forEach(function(el){
        el.addEventListener('click', function(){ goto(parseInt(el.dataset.goto, 10)); });
      });
    }

    function render() {
      if (state.step === 1) renderStep1();
      else if (state.step === 2) renderStep2();
      else if (state.step === 3) renderResult();
    }

    updateStepper();

    fetch(DATA_URL, { credentials: 'omit' })
      .then(function(r){ if (!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
      .then(function(data){
        SHOPIFY_PRODUCTS = Array.isArray(data) ? data.filter(function(p){ return p && p.handle; }) : [];
        buildMfrMap();
        render();
      })
      .catch(function(err){
        body.innerHTML = '<div class="zf-empty">Finder-Daten konnten nicht geladen werden. Bitte Seite neu laden oder <a href="{{ anfrage_url }}" style="color:var(--bz-orange-dark);font-weight:700;">Beratung anfragen</a>.</div>';
        if (window.console) console.error('[ziegel-finder]', err);
      });
  })();
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "{{ shop.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "Ziegel Finder", "item": "{{ canonical }}" }
    ]},
    { "@type": "WebPage", "@id": "{{ canonical }}#webpage", "url": "{{ canonical }}",
      "name": "Ziegel Finder — Passenden Blechziegel für Ihr Dach finden",
      "description": "Finden Sie den passenden Aluminium-Blechziegel nach Hersteller und Ziegeltyp / Modell. Der Finder basiert auf den aktuell gepflegten Produktdaten im Shop. Für nicht gelistete Profile bieten wir Beratung per Foto-Anfrage.",
      "inLanguage": "de-DE",
      "isPartOf": { "@type": "WebSite", "url": "{{ shop.url }}/", "name": "{{ shop.name | escape }}" },
      "potentialAction": { "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "{{ shop.url }}/pages/ziegel-finder" },
        "query-input": "required name=search_term_string" }
    }
  ]
}
</script>
