                <div class="hp-form__group">
                  <label class="hp-form__label" for="pa-nachricht">Projektbeschreibung<span class="hp-opt">(optional, aber hilfreich)</span></label>
                  <textarea class="hp-form__textarea" id="pa-nachricht" name="Projektbeschreibung" placeholder="Dachfläche, Ziegel-Hersteller/-Profil (falls bekannt), Maße, gewünschter Liefertermin, Rahmenvertrag-Interesse, sonstige Hinweise …"></textarea>
