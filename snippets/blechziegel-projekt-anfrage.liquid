<script>
  (function(){
    var drop  = document.getElementById('pa-file-drop');
    var input = document.getElementById('pa-files');
    var list  = document.getElementById('pa-file-list');
    var form  = document.getElementById('pa-anfrage-form');
    var status= document.getElementById('pa-form-status');
    var submit= document.getElementById('pa-form-submit');
    if (!form) return;

    var MAX_TOTAL = 12 * 1024 * 1024;

    function fmt(b){
      if (b < 1024) return b + ' B';
      if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
      return (b/1048576).toFixed(1) + ' MB';
    }
    function showError(msg){
      status.className = 'hp-form-status hp-form-status--error is-visible';
      status.textContent = msg;
      status.scrollIntoView({ behavior:'smooth', block:'center' });
    }
    function clearStatus(){ status.className = 'hp-form-status'; status.textContent = ''; }

    var meter = document.getElementById('pa-file-meter');
    var used  = document.getElementById('pa-file-used');
    var fill  = document.getElementById('pa-file-fill');

    function renderList(){
      list.innerHTML = '';
      var files = input.files ? Array.from(input.files) : [];
      var total = 0;
      files.forEach(function(f){
        total += f.size;
        var row = document.createElement('div');
        row.className = 'hp-file-multi__item';
        row.innerHTML = '<span class="hp-file-multi__item-name"></span><span class="hp-file-multi__item-size"></span>';
        row.querySelector('.hp-file-multi__item-name').textContent = f.name;
        row.querySelector('.hp-file-multi__item-size').textContent = fmt(f.size);
        list.appendChild(row);
      });
      if (used) used.textContent = fmt(total);
      if (fill) fill.style.width = Math.min(100, Math.round((total / MAX_TOTAL) * 100)) + '%';
      if (meter) meter.classList.toggle('is-over', total > MAX_TOTAL);
      if (total > MAX_TOTAL) {
        showError('Summe der Anhänge ist zu groß (' + fmt(total) + '). Maximal 12 MB.');
      } else {
        clearStatus();
      }
    }

    // Sonstiges-Follow-up: Freitextfeld ein-/ausblenden
    var projektartEl = document.getElementById('pa-projektart');
    var sonstigesWrap = document.getElementById('pa-projektart-sonstiges-wrap');
    var sonstigesInput = document.getElementById('pa-projektart-sonstiges');
    function syncProjektartFollowup(){
      if (!projektartEl || !sonstigesWrap) return;
      var on = projektartEl.value === 'Sonstiges';
      sonstigesWrap.hidden = !on;
      if (sonstigesInput && !on) sonstigesInput.value = '';
    }
    if (projektartEl) {
      projektartEl.addEventListener('change', syncProjektartFollowup);
      syncProjektartFollowup();
    }

    // CC-Sync: Nutzer erhält Kopie seiner Projektanfrage (FormSubmit _cc)
    var emailEl = document.getElementById('pa-email');
    var ccEl    = document.getElementById('pa-cc');
    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    function syncCcFromEmail(){
      if (!emailEl || !ccEl) return;
      var v = (emailEl.value || '').trim();
      ccEl.value = EMAIL_RE.test(v) ? v : '';
    }
    if (emailEl) {
      emailEl.addEventListener('input', syncCcFromEmail);
      emailEl.addEventListener('change', syncCcFromEmail);
    }

    input.addEventListener('change', renderList);

    ['dragover','dragenter'].forEach(function(ev){
      drop.addEventListener(ev, function(e){ e.preventDefault(); drop.classList.add('is-drag'); });
    });
    ['dragleave','dragend','drop'].forEach(function(ev){
      drop.addEventListener(ev, function(e){ e.preventDefault(); drop.classList.remove('is-drag'); });
    });
    drop.addEventListener('drop', function(e){
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length) {
        input.files = e.dataTransfer.files;
        renderList();
      }
    });

    form.addEventListener('submit', function(e){
      clearStatus();
      syncCcFromEmail();
      if (!form.checkValidity()) {
        e.preventDefault();
        showError('Bitte alle Pflichtfelder ausfüllen und Datenschutz bestätigen.');
        var inv = form.querySelector(':invalid'); if (inv) inv.focus();
        return;
      }
      var total = 0;
      if (input.files) Array.from(input.files).forEach(function(f){ total += f.size; });
      if (total > MAX_TOTAL) {
        e.preventDefault();
        showError('Summe der Anhänge überschreitet 12 MB.');
        return;
      }
      submit.disabled = true;
      submit.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v4m0 12v4M6 12H2m20 0h-4m-2.81-6.36l-2.83 2.83m-5.66 5.66l-2.83 2.83m11.32 0l-2.83-2.83m-5.66-5.66L5.64 5.64" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg> Wird gesendet …';
    });
  })();
</script>

