{% comment %}
  ============================================================
  BLECHZIEGEL.DE — Projekt-Anfrage (B2B-Funnel)
  Snippet: blechziegel-projekt-anfrage.liquid
  Zielgruppe: Dachdecker, PV-Installateure, Betriebe, Großmengen, Sonderprofile
  Layout-DNA: hp-* Klassen (Gewerbe/Anfrage-Stil)
  Backend: FormSubmit.co (E-Mail an web@blechziegel.de)
  Eingebunden via sections/main-page.liquid wenn page.handle == 'projekt-anfrage'
  ============================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
.hp {
  --bz-navy:#0a2240; --bz-navy-light:#0d2d54;
  --bz-orange:#ffa500; --bz-orange-dark:#e69400; --bz-orange-bg:rgba(255,165,0,.12);
  --bz-white:#fff; --bz-gray:#f5f5f5; --bz-gray-mid:#e8eaed;
  --bz-text:#333; --bz-text-light:#666; --bz-border:#e5e7eb;
  --bz-green:#16a34a; --bz-red:#dc2626;
  --bz-head:'Montserrat',sans-serif; --bz-body:'Open Sans',sans-serif;
  --bz-radius:8px; --bz-radius-lg:14px; --bz-max:1200px;
  --bz-shadow:0 4px 20px rgba(10,34,64,.10);
  --bz-shadow-lg:0 12px 40px rgba(10,34,64,.18);
  font-family:var(--bz-body); color:var(--bz-text);
}
.hp *, .hp *::before, .hp *::after { box-sizing:border-box; margin:0; padding:0; }
.hp a { text-decoration:none; color:inherit; }
.hp img { max-width:100%; display:block; }
.hp-wrap { max-width:var(--bz-max); margin:0 auto; padding:0 20px; }

.hp-hero { background:var(--bz-navy);
  color:var(--bz-white); padding:64px 20px 56px; position:relative; overflow:hidden;
  min-height:400px; }
.hp-hero__media { position:absolute; inset:0; z-index:0; }
.hp-hero__media img { width:100%; height:100%; object-fit:cover; object-position:center; display:block; }
.hp-hero::before { content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
  background:rgba(13,30,53,0.55); }
.hp-hero__inner { position:relative; z-index:2; max-width:var(--bz-max); margin:0 auto; }
.hp-kicker { display:inline-flex; align-items:center; gap:8px;
  background:var(--bz-orange-bg); border:1px solid rgba(255,165,0,.35);
  color:var(--bz-orange); font-family:var(--bz-head);
  font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em;
  padding:5px 13px; border-radius:20px; margin-bottom:18px; }
.hp-kicker svg { width:12px; height:12px; fill:var(--bz-orange); }
.hp-hero h1 { font-family:var(--bz-head); font-size:clamp(26px,3.8vw,42px);
  font-weight:800; line-height:1.2; margin-bottom:16px; color:var(--bz-white); max-width:820px; }
.hp-hero h1 span { color:var(--bz-orange); }
.hp-hero__sub { font-size:16px; line-height:1.7; color:rgba(255,255,255,.85); margin-bottom:24px; max-width:680px; }
.hp-hero__trust { display:flex; flex-wrap:wrap; gap:18px; }
.hp-hero__trust-item { display:flex; align-items:center; gap:7px;
  font-size:12.5px; color:rgba(255,255,255,.78); font-weight:600; }
.hp-hero__trust-item svg { width:14px; height:14px; fill:var(--bz-green); flex-shrink:0; }

.hp-section { padding:64px 0; }
.hp-section--gray { background:var(--bz-gray); }
.hp-section--white { background:var(--bz-white); }
.hp-section--navy { background:var(--bz-navy); color:var(--bz-white); }
.hp-section-label { font-family:var(--bz-head); font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.12em; color:var(--bz-orange); margin-bottom:8px; display:block; }
.hp-section-title { font-family:var(--bz-head); font-size:clamp(22px,2.8vw,32px);
  font-weight:800; color:var(--bz-navy); line-height:1.25; margin-bottom:10px; }
.hp-section--navy .hp-section-title { color:var(--bz-white); }
.hp-section-sub { font-size:15px; line-height:1.7; color:var(--bz-text-light); max-width:680px; margin-bottom:32px; }
.hp-section--navy .hp-section-sub { color:rgba(255,255,255,.72); max-width:640px; margin:0 auto 28px; }

.hp-form-layout { display:grid; grid-template-columns:1.4fr .6fr; gap:40px; align-items:start; }
.hp-form-card { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); box-shadow:var(--bz-shadow); overflow:hidden; }
.hp-form-card__head { background:linear-gradient(135deg,var(--bz-navy) 0%,#163660 100%);
  color:var(--bz-white); padding:22px 28px; }
.hp-form-card__head h3 { font-family:var(--bz-head); font-size:18px; font-weight:800; margin-bottom:2px; }
.hp-form-card__head p { font-size:13.5px; color:rgba(255,255,255,.75); }
.hp-form-card__body { padding:32px 32px 28px; }

.hp-form__block { margin-bottom:26px; padding-top:14px; }
.hp-form__block:first-of-type { padding-top:0; }
.hp-form__block + .hp-form__block { border-top:1px solid var(--bz-border); }
.hp-form__block-label { display:flex; align-items:center; gap:10px;
  font-family:var(--bz-head); font-size:11.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.09em; color:var(--bz-orange);
  margin-bottom:16px; }
.hp-form__block-label-num {
  width:22px; height:22px; border-radius:50%;
  background:var(--bz-orange); color:var(--bz-navy);
  font-size:11px; font-weight:800;
  display:inline-flex; align-items:center; justify-content:center; }

.hp-form__group { margin-bottom:20px; }
.hp-form__group:last-child { margin-bottom:0; }
.hp-form__grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:0; }
.hp-form__label { display:block; font-family:var(--bz-head); font-size:12px; font-weight:700;
  text-transform:uppercase; letter-spacing:.06em; color:var(--bz-navy); margin-bottom:6px; }
.hp-form__label .hp-req { color:var(--bz-orange); margin-left:2px; }
.hp-form__label .hp-opt { color:var(--bz-text-light); font-weight:600; text-transform:none; letter-spacing:0; margin-left:6px; font-size:11px; }
.hp-form__input,
.hp-form__textarea,
.hp-form__select {
  width:100%; padding:11px 14px; border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius); font-family:var(--bz-body); font-size:14.5px;
  color:var(--bz-text); background:var(--bz-white);
  transition:border-color .15s, box-shadow .15s; min-height:44px;
}
.hp-form__input:focus,
.hp-form__textarea:focus,
.hp-form__select:focus {
  outline:none; border-color:var(--bz-orange);
  box-shadow:0 0 0 3px rgba(255,165,0,.15);
}
.hp-form__textarea { resize:vertical; min-height:110px; line-height:1.6; }
.hp-form__hint { font-size:12.5px; color:var(--bz-text-light); margin-top:5px; line-height:1.5; }

/* Radio-Gruppe (Sonderprofil) als Segmented Control */
.hp-form__radio-group { display:grid; grid-template-columns:repeat(3,1fr); gap:8px;
  background:var(--bz-gray); border:1px solid var(--bz-border);
  border-radius:var(--bz-radius); padding:4px; }
.hp-form__radio-input { position:absolute; opacity:0; pointer-events:none; }
.hp-form__radio-label { display:flex; align-items:center; justify-content:center;
  padding:9px 10px; font-size:13.5px; font-weight:600; color:var(--bz-text-light);
  border-radius:calc(var(--bz-radius) - 2px); cursor:pointer;
  transition:background .15s, color .15s, box-shadow .15s; text-align:center; }
.hp-form__radio-input:checked + .hp-form__radio-label {
  background:var(--bz-white); color:var(--bz-navy);
  box-shadow:0 1px 3px rgba(10,34,64,.08); }

/* OPTIONAL FILE UPLOAD (mehrfach) */
.hp-file-multi { border:2px dashed var(--bz-border); border-radius:var(--bz-radius-lg);
  padding:22px 20px; text-align:center; background:var(--bz-gray);
  cursor:pointer; position:relative; transition:all .2s; }
.hp-file-multi:hover, .hp-file-multi.is-drag { border-color:var(--bz-orange); background:var(--bz-orange-bg); }
.hp-file-multi input[type="file"] { position:absolute; inset:0; opacity:0; cursor:pointer; }
.hp-file-multi__title { font-family:var(--bz-head); font-size:13.5px; font-weight:800;
  color:var(--bz-navy); margin-bottom:4px; }
.hp-file-multi__hint { font-size:12px; color:var(--bz-text-light); line-height:1.45; }
.hp-file-multi__list { margin-top:12px; display:flex; flex-direction:column; gap:6px; }
.hp-file-multi__item { display:flex; align-items:center; gap:10px; padding:8px 12px;
  background:var(--bz-white); border:1px solid var(--bz-border); border-radius:var(--bz-radius);
  font-size:13px; color:var(--bz-text); }
.hp-file-multi__item-name { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-weight:600; }
.hp-file-multi__item-size { color:var(--bz-text-light); font-size:12px; }
.hp-file-multi__meter { display:flex; align-items:center; gap:12px; margin-top:10px; font-size:12.5px; color:var(--bz-text-light); }
.hp-file-multi__meter-text { white-space:nowrap; }
.hp-file-multi__meter-text strong { color:var(--bz-navy); font-weight:700; }
.hp-file-multi__meter-bar { flex:1; height:6px; background:var(--bz-gray-mid); border-radius:4px; overflow:hidden; }
.hp-file-multi__meter-fill { display:block; height:100%; width:0%; background:var(--bz-orange); transition:width .2s, background .2s; }
.hp-file-multi__meter.is-over .hp-file-multi__meter-fill { background:var(--bz-red); }

.hp-form__check { display:flex; align-items:flex-start; gap:10px; font-size:13.5px;
  line-height:1.6; color:var(--bz-text); }
.hp-form__check input[type="checkbox"] {
  width:18px; height:18px; margin-top:2px; accent-color:var(--bz-orange); flex-shrink:0;
}
.hp-form__check a { color:var(--bz-orange-dark); font-weight:700; text-decoration:underline; }

.hp-btn { display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:14px 28px; border-radius:var(--bz-radius);
  font-family:var(--bz-head); font-size:14.5px; font-weight:700;
  cursor:pointer; transition:all .2s; border:2px solid transparent; white-space:nowrap;
  min-height:48px; }
.hp-btn svg { width:16px; height:16px; fill:currentColor; flex-shrink:0; }
.hp-btn--primary { background:var(--bz-orange); color:var(--bz-navy); border-color:var(--bz-orange); width:100%; }
.hp-btn--primary:hover { background:var(--bz-orange-dark); border-color:var(--bz-orange-dark); transform:translateY(-1px); box-shadow:0 6px 20px rgba(255,165,0,.3); }
.hp-btn--outline { background:transparent; color:var(--bz-white); border-color:rgba(255,255,255,.4); }
.hp-btn--outline:hover { border-color:var(--bz-white); background:rgba(255,255,255,.08); }

.hp-info-stack { display:flex; flex-direction:column; gap:16px; position:sticky; top:24px; }
.hp-info-box { background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-left:4px solid var(--bz-orange); border-radius:var(--bz-radius-lg);
  padding:22px 24px; box-shadow:var(--bz-shadow); }
.hp-info-box__label { font-family:var(--bz-head); font-size:10.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.1em; color:var(--bz-orange); margin-bottom:6px; }
.hp-info-box__title { font-family:var(--bz-head); font-size:15px; font-weight:800;
  color:var(--bz-navy); margin-bottom:6px; }
.hp-info-box__text { font-size:13.5px; line-height:1.6; color:var(--bz-text-light); }
.hp-info-box__text strong { color:var(--bz-navy); font-weight:700; }
.hp-info-list { display:flex; flex-direction:column; gap:10px; margin-top:10px; }
.hp-info-list li { display:flex; align-items:flex-start; gap:9px; font-size:13.5px; line-height:1.55; color:var(--bz-text); }
.hp-info-list li svg { width:16px; height:16px; fill:var(--bz-orange); flex-shrink:0; margin-top:2px; }
.hp-info-box--xlink { border-left-color:var(--bz-navy); }
.hp-info-box--xlink .hp-info-box__label { color:var(--bz-navy); }
.hp-info-box--xlink a { color:var(--bz-orange-dark); font-weight:700; text-decoration:underline; }

.hp-form-status { display:none; margin-bottom:20px; padding:14px 18px; border-radius:var(--bz-radius);
  font-size:14px; font-weight:600; line-height:1.5; }
.hp-form-status.is-visible { display:block; }
.hp-form-status--error { background:#fef2f2; border:1.5px solid #fca5a5; color:#7f1d1d; }

.hp-cta-final { text-align:center; }
.hp-cta-final__buttons { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:24px; }

/* So läuft die Projektanfrage (3 Steps) */
.hp-process { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; margin-top:28px; list-style:none; padding:0; }
.hp-process__step { position:relative; background:var(--bz-white); border:1.5px solid var(--bz-border);
  border-radius:var(--bz-radius-lg); padding:30px 24px 24px; transition:border-color .2s, box-shadow .2s; }
.hp-process__step:hover { border-color:var(--bz-orange); box-shadow:var(--bz-shadow); }
.hp-process__num { position:absolute; top:-14px; left:24px;
  width:32px; height:32px; border-radius:50%;
  background:var(--bz-orange); color:var(--bz-navy);
  font-family:var(--bz-head); font-size:14px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 12px rgba(255,165,0,.3); }
.hp-process__title { font-family:var(--bz-head); font-size:15.5px; font-weight:800;
  color:var(--bz-navy); margin-bottom:8px; line-height:1.3; }
.hp-process__text { font-size:13.5px; line-height:1.6; color:var(--bz-text-light); }

@media (max-width:1024px) {
  .hp-form-layout { grid-template-columns:1fr; gap:28px; }
  .hp-info-stack { position:static; }
}
@media (max-width:640px) {
  .hp-hero { padding:40px 16px 44px; min-height:300px; }
  .hp-hero__media img { object-position:left center; }
  .hp-hero h1 { font-size:24px; line-height:1.2; }
  .hp-hero__sub { font-size:14.5px; }
  .hp-hero__trust { gap:10px 14px; }
  .hp-hero__trust-item { font-size:12px; }
  .hp-section { padding:36px 0; }
  .hp-section-title { font-size:22px; }
  .hp-wrap { padding:0 16px; }
  .hp-form-card__head { padding:18px 20px; }
  .hp-form-card__body { padding:22px 20px 20px; }
  .hp-form__grid-2 { grid-template-columns:1fr; gap:20px; }
  .hp-form__radio-group { grid-template-columns:1fr; }
  .hp-info-box { padding:18px 20px; }
  .hp-cta-final__buttons .hp-btn { width:100%; }
  .hp-process { grid-template-columns:1fr; gap:28px; }
}
</style>

{%- liquid
  assign email_raw = 'web@blechziegel.de'
  assign agb_url = '/pages/agb'
  assign datenschutz_url = '/pages/datenschutz'
  assign canonical = shop.url | append: '/pages/projekt-anfrage'
-%}

<div class="hp">

  <section class="hp-hero" aria-labelledby="pa-hero-title">
    <div class="hp-hero__media" aria-hidden="true">
      <picture>
        <source
          type="image/webp"
          srcset="{{ 'blechziegel-projekt-anfrage-hero-1024.webp' | asset_url }} 1024w,
                  {{ 'blechziegel-projekt-anfrage-hero-1440.webp' | asset_url }} 1440w,
                  {{ 'blechziegel-projekt-anfrage-hero-1920.webp' | asset_url }} 1920w"
          sizes="100vw">
        <img
          src="{{ 'blechziegel-projekt-anfrage-hero-1920.jpg' | asset_url }}"
          srcset="{{ 'blechziegel-projekt-anfrage-hero-1024.jpg' | asset_url }} 1024w,
                  {{ 'blechziegel-projekt-anfrage-hero-1440.jpg' | asset_url }} 1440w,
                  {{ 'blechziegel-projekt-anfrage-hero-1920.jpg' | asset_url }} 1920w"
          sizes="100vw"
          alt="Dachdecker mit Tablet auf Blechziegeldach plant PV-Projekt – Projekt-Anfrage bei blechziegel.de"
          title="Projekt-Anfrage für Dachdecker und PV-Installateure – blechziegel.de"
          width="1920" height="814"
          loading="eager" fetchpriority="high" decoding="async">
      </picture>
    </div>
    <div class="hp-wrap hp-hero__inner">
      <div class="hp-kicker">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 2 7l10 5 10-5-10-5zm0 13L2 10v7l10 5 10-5v-7l-10 5z"/></svg>
        Projekt-Anfrage
      </div>
      <h1 id="pa-hero-title">Projekt-Anfrage für <span>Dachdecker, PV-Installateure</span> und Betriebe.</h1>
      <p class="hp-hero__sub">
        Mengen, Sonderprofile und Rahmenverträge — individuelle Konditionen auf Basis
        Ihrer Projektangaben. Persönlicher Ansprechpartner statt Standardformular.
      </p>
      <div class="hp-hero__trust">
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Persönlicher Ansprechpartner</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Rahmenverträge möglich</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Netto-Preise für Gewerbe</div>
        <div class="hp-hero__trust-item"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2l-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>Sonderprofile kalkulierbar</div>
      </div>
    </div>
  </section>

  <section class="hp-section hp-section--gray" aria-labelledby="pa-form-title">
    <div class="hp-wrap">
      <span class="hp-section-label">Projekt-Formular</span>
      <h2 class="hp-section-title" id="pa-form-title">Projektangaben senden — wir melden uns mit Kalkulation.</h2>
      <p class="hp-section-sub">Pflichtfelder sind mit <span style="color:var(--bz-orange);font-weight:700;">*</span> markiert. Uploads sind optional und helfen bei Sonderprofilen (Foto, Zeichnung, Datenblatt, PDF, bis 12&nbsp;MB gesamt).</p>

      <div class="hp-form-layout">

        <div class="hp-form-card">
          <div class="hp-form-card__head">
            <h3>Projekt-Anfrage · B2B</h3>
            <p>Ihre Angaben werden ausschließlich zur Kalkulation dieses Projekts verwendet.</p>
          </div>
          <div class="hp-form-card__body">

            <div id="pa-form-status" class="hp-form-status" role="status" aria-live="polite"></div>

            <form
              id="pa-anfrage-form"
              action="https://formsubmit.co/{{ email_raw }}"
              method="POST"
              enctype="multipart/form-data"
              novalidate
            >
              <input type="hidden" name="_subject" value="Neue Projekt-Anfrage (B2B) via Website">
              <input type="hidden" name="_captcha" value="false">
              <input type="hidden" name="_template" value="table">
              <input type="hidden" name="_next" value="{{ shop.url }}/pages/anfrage-erfolg">
              <input type="text" name="_honey" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;">
              <input type="hidden" name="_cc" id="pa-cc" value="">

              <!-- Block 1: Projekt / Menge -->
              <div class="hp-form__block">
                <div class="hp-form__block-label"><span class="hp-form__block-label-num">1</span> Projekt &amp; Menge</div>

                <div class="hp-form__group">
                  <label class="hp-form__label" for="pa-projektart">Projektart / Einsatz<span class="hp-req">*</span></label>
                  <select class="hp-form__select" id="pa-projektart" name="Projektart" required>
                    <option value="">Bitte wählen …</option>
                    <option>PV-Montage (Neubau)</option>
                    <option>PV-Montage (Bestand / Nachrüstung)</option>
                    <option>Dachsanierung</option>
                    <option>Solarthermie</option>
                    <option>Sonstige Dachdurchdringung</option>
                    <option>Sonstiges</option>
                  </select>
                </div>

                <div class="hp-form__group" id="pa-projektart-sonstiges-wrap" hidden>
                  <label class="hp-form__label" for="pa-projektart-sonstiges">Projektart — bitte kurz beschreiben<span class="hp-opt">(nur bei „Sonstiges")</span></label>
                  <input class="hp-form__input" id="pa-projektart-sonstiges" name="Projektart_Sonstiges" type="text" placeholder="z. B. Dachbegrünung, gewerbliche Dachdurchführung, Sonderkonstruktion …">
                </div>

                <div class="hp-form__group hp-form__grid-2">
                  <div>
                    <label class="hp-form__label" for="pa-menge">Bedarfsmenge (ungefähr)<span class="hp-req">*</span></label>
                    <select class="hp-form__select" id="pa-menge" name="Bedarfsmenge" required>
                      <option value="">Bitte wählen …</option>
                      <option>bis 25 Stück</option>
                      <option>25 – 100 Stück</option>
                      <option>100 – 500 Stück</option>
                      <option>500 – 2.000 Stück</option>
                      <option>2.000+ Stück</option>
                      <option>noch unklar</option>
                    </select>
                  </div>
                  <div>
                    <label class="hp-form__label" for="pa-dachflaeche">Dachfläche in m²<span class="hp-opt">(optional)</span></label>
