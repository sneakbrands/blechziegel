<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
  <!-- ===== CCM19 Consent Banner ===== -->
<script src="https://cloud.ccm19.de/app.js?apiKey=461acb720b72199ce173b27e0f6a8a7828d24ba5adc85e62&amp;domain=6a02ebd285be33f45800c902" referrerpolicy="origin"></script>
<!-- ===== Google Consent Mode v2 Default ===== -->
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'analytics_storage': 'denied',
    'functionality_storage': 'granted',
    'security_storage': 'granted',
    'wait_for_update': 500
  });
  gtag('set', 'ads_data_redaction', true);
  gtag('set', 'url_passthrough', true);
</script>

<!-- ===== Google Tag Manager ===== -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5LBDKJKD');</script>
<!-- End Google Tag Manager -->
  <meta name="google-site-verification" content="miXYq8tqN3e1Q6WcNRVcyl6hAG_GjhzIKILKiflsHIA" />
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    {%- comment -%}
      EN-Locale ist publiziert, aber inhaltlich noch nicht uebersetzt
      (Translate & Adapt liefert deutsche Quelltexte unter /en/*).
      Bis zur echten EN-Umsetzung: noindex fuer alle /en/*-Routen, damit
      Google keine halbfertigen EN-Seiten in den Index nimmt und keine
      Duplicate-Content-Probleme entstehen. Folge-Links bleiben crawlbar.
      Entfernen, sobald EN-Inhalte real uebersetzt sind.
    {%- endcomment -%}
    {%- if request.locale.iso_code == 'en' -%}
      <meta name="robots" content="noindex, follow">
    {%- endif -%}

    {%- comment -%}
      Fallback Meta-Description fuer Collection-Seiten ohne admin-gepflegte
      collection.description. Erzeugt eine sachliche, brand-spezifische
      Beschreibung aus dem im Theme gepflegten hersteller_blurb.
      Schreibt nur, wenn content_for_header noch keine description enthaelt.
    {%- endcomment -%}
    {%- if request.page_type == 'collection' and collection.handle != blank -%}
      {%- assign __coll_desc = collection.metafields.global.description_tag | default: collection.description -%}
      {%- if __coll_desc == blank -%}
        {%- case collection.handle -%}
          {%- when 'braas' -%}
            {%- assign __coll_meta = 'PV-Dachziegel passgenau für Braas-Profile (Frankfurter Pfanne, Harzer Pfanne). Aluminium-Ersatzziegel für die sichere PV-Montage — kein Bohren, kein Bruchrisiko. In Deutschland gefertigt.' -%}
          {%- when 'bramac' -%}
            {%- assign __coll_meta = 'PV-Dachziegel passgenau für Bramac-Profile (Bramac Montero, Classic). Aluminium-Ersatzziegel für die sichere PV-Montage — kein Bohren, kein Bruchrisiko. In Deutschland gefertigt.' -%}
          {%- when 'creaton' -%}
            {%- assign __coll_meta = 'PV-Dachziegel passgenau für Creaton-Profile (Heidelberger u. a.). Aluminium-Ersatzziegel für die sichere PV-Montage — kein Bohren, kein Bruchrisiko. In Deutschland gefertigt.' -%}
          {%- when 'nelskamp' -%}
            {%- assign __coll_meta = 'PV-Dachziegel passgenau für Nelskamp-Profile (Sigma Pfanne, Finkenberger). Aluminium-Ersatzziegel für die sichere PV-Montage — kein Bohren, kein Bruchrisiko. In Deutschland gefertigt.' -%}
          {%- when 'pv-dachziegel' -%}
            {%- assign __coll_meta = 'Aluminium-Blechziegel für die sichere PV-Montage — passgenau für alle gängigen Dachziegeltypen. Kein Bohren, kein Bruchrisiko. Lieferzeit 1–3 Werktage, Made in Germany.' -%}
        {%- endcase -%}
        {%- comment -%}
          Nur meta name="description" emittieren. og:description liefert Shopify
          bereits (mit Shop-Fallback) — Doppel-Tags sonst.
        {%- endcomment -%}
        {%- if __coll_meta != blank -%}
          <meta name="description" content="{{ __coll_meta | escape }}">
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Tidio Chat-Widget oberhalb des Ziegel-Finder-Launchers (rechts unten) {%- endcomment -%}
    <style id="bz-tidio-pos">
      /* CSS-Override fuer alle bekannten Tidio-Iframe-Varianten. Tidio setzt
         haeufig inline-styles mit hoher Spezifitaet — daher !important. */
      iframe#tidio-chat-iframe,
      iframe[id^="tidio-chat-iframe"],
      iframe[title="Tidio Chat"],
      iframe[title*="tidio" i],
      #tidio-chat iframe,
      #tidio-chat-iframe-wrapper iframe {
        bottom: 92px !important;
      }
      /* Cart-Drawer offen: Tidio ausblenden, sonst ueberlagert er das Cart-Panel */
      body.bz-cart-open iframe#tidio-chat-iframe,
      body.bz-cart-open iframe[id^="tidio-chat-iframe"],
      body.bz-cart-open iframe[title="Tidio Chat"],
      body.bz-cart-open #tidio-chat iframe { display: none !important; }
      @media (max-width: 640px) {
        iframe#tidio-chat-iframe,
        iframe[id^="tidio-chat-iframe"],
        iframe[title="Tidio Chat"],
        #tidio-chat iframe {
          bottom: 78px !important;
        }
        iframe#tidio-chat-iframe[style*="height: 100%"],
        iframe#tidio-chat-iframe[style*="height:100%"] {
          bottom: 0 !important;
        }
      }
    </style>
    <script>
      // Failsafe: Tidio setzt sein bottom oft inline NACH Page-Load und
      // ueberschreibt CSS-only-Versuche. MutationObserver auf <body> erwartet
      // den Tidio-Iframe und setzt ein inline bottom mit !important via cssText.
      (function () {
        var DESKTOP = 92, MOBILE = 78;
        function applyPos(el) {
          if (!el || el.dataset.bzPos === '1') return;
          var isFullscreen = (el.style.height === '100%' || el.style.height === '100vh');
          var isMobile = window.matchMedia('(max-width: 640px)').matches;
          if (isMobile && isFullscreen) return;
          var px = isMobile ? MOBILE : DESKTOP;
          // setProperty mit important ueberschreibt inline-style ohne diesen
          // komplett zu zerstoeren (Tidio liest seine eigenen Inline-Werte zurueck).
          el.style.setProperty('bottom', px + 'px', 'important');
          el.dataset.bzPos = '1';
        }
        function scan() {
          var els = document.querySelectorAll(
            'iframe#tidio-chat-iframe, iframe[id^="tidio-chat-iframe"], iframe[title="Tidio Chat"]'
          );
          els.forEach(applyPos);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scan);
        } else { scan(); }
        var mo = new MutationObserver(function () { scan(); });
        mo.observe(document.documentElement, { childList: true, subtree: true });
        // Auch periodisch fuer den Fall, dass Tidio das style-Attribut
        // nach Initialisierung erneut setzt.
        var t = 0;
        var iv = setInterval(function () {
          scan();
          if (++t > 30) clearInterval(iv); // 30 * 1s = 30s
        }, 1000);
      })();
    </script>
    {% render 'ultimate-datalayer' %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ request.page_type | handle }}{% if page.handle %} page-{{ page.handle }}{% endif %}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    {%- render 'bz-cart-drawer' -%}
    {%- render 'bz-nav-premium' -%}
    {%- render 'bz-cookie-banner' -%}
    {%- render 'bz-finder-launcher' -%}
    {%- comment -%} Express-Countdown deaktiviert — Express-Versand wurde aus dem Sortiment entfernt. {%- endcomment -%}
  </body>
</html>
