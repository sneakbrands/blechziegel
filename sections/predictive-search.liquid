

{%- if predictive_search.performed or search.performed -%}
  <style data-bz-predictive-search-polish>
    /* ═══ BZ Predictive-Search CI-Polish (hohe Spezifität gegen Horizon) ═══ */
    body #predictive-search-results.predictive-search-dropdown {
      font-family: var(--font-body--family, 'Inter', sans-serif);
      color: var(--color-foreground, #0d1e35);
    }

    /* Section-Titles („Zuletzt angesehen", „Produkte") */
    body #predictive-search-results .predictive-search-results__title,
    body #predictive-search-results h4.predictive-search-results__title {
      font-family: var(--font-heading--family, 'Montserrat', sans-serif) !important;
      font-size: 11px !important;
      font-weight: 700 !important;
      letter-spacing: 0.14em !important;
      text-transform: uppercase !important;
      color: var(--color-foreground, #0d1e35) !important;
      margin: 4px 0 12px !important;
      padding-bottom: 8px !important;
      border-bottom: 1px solid var(--color-border, #DFDFDF) !important;
      display: flex !important;
      align-items: center !important;
      justify-content: space-between !important;
      gap: 10px !important;
    }
    body #predictive-search-results .predictive-search-results__clear {
      font-family: var(--font-body--family, 'Inter', sans-serif) !important;
      font-size: 11px !important;
      font-weight: 600 !important;
      letter-spacing: 0.02em !important;
      color: var(--bz-orange-dark, var(--bz-orange, #f39200)) !important;
      text-transform: none !important;
      padding: 3px 8px !important;
      border-radius: 999px !important;
      background: transparent !important;
      transition: background .15s !important;
    }
    body #predictive-search-results .predictive-search-results__clear:hover {
      background: var(--bz-orange-light, #fff4e0) !important;
    }

    /* Grid — zwingen auf 4 Spalten Desktop / 2 Mobile, Horizon-Container-Query überstimmen */
    body #predictive-search-results .predictive-search-results__wrapper-products {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 14px !important;
      padding: 0 !important;
    }
    @media (min-width: 640px) {
      body #predictive-search-results .predictive-search-results__wrapper-products {
        grid-template-columns: repeat(4, 1fr) !important;
        gap: 16px !important;
      }
    }

    /* Card = das <li>. Border + Radius gehen AUF DAS li, nicht auf die innere resource-card */
    body #predictive-search-results .predictive-search-results__card--product,
    body #predictive-search-results .recently-viewed-wrapper .predictive-search-results__card--product {
      list-style: none !important;
      background: #fff !important;
      border: 1px solid var(--color-border, #DFDFDF) !important;
      border-radius: 10px !important;
      overflow: hidden !important;
      padding: 0 !important;
      margin: 0 !important;
      transition: border-color .18s ease, box-shadow .18s ease !important;
      animation: none !important;
      opacity: 1 !important;
    }
    /* Horizon-Hover-Padding-Trick deaktivieren */
    body #predictive-search-results .predictive-search-results__card--product:hover,
    body #predictive-search-results .recently-viewed-wrapper .predictive-search-results__card--product:hover {
      background: #fff !important;
      border-color: var(--color-foreground, #0d1e35) !important;
      border-radius: 10px !important;
      padding: 0 !important;
      margin: 0 !important;
      box-shadow: 0 4px 14px rgba(13,30,53,0.06) !important;
      outline: none !important;
    }
    body #predictive-search-results .predictive-search-results__card--product:active,
    body #predictive-search-results .predictive-search-results__card--product.keyboard-focus,
    body #predictive-search-results .predictive-search-results__card--product:focus-within {
      transform: none !important;
      outline: 2px solid var(--bz-orange, #f39200) !important;
      outline-offset: -2px !important;
      border-radius: 10px !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    /* Resource-Card Flex-Struktur */
    body #predictive-search-results .predictive-search-results__card--product .resource-card {
      display: flex !important;
      flex-direction: column !important;
      height: 100% !important;
      row-gap: 0 !important;
      animation: none !important;
      opacity: 1 !important;
    }

    /* Bild-Container: 4:3 über CSS-Var von Horizon überschreiben */
    body #predictive-search-results .predictive-search-results__card--product .resource-card__media {
      --resource-card-aspect-ratio: 4 / 3 !important;
      aspect-ratio: 4 / 3 !important;
      width: 100% !important;
      background: var(--bz-surface, #f8f7f4) !important;
      border-bottom: 1px solid var(--color-border, #DFDFDF) !important;
      overflow: hidden !important;
      position: relative !important;
      margin: 0 !important;
      border-radius: 0 !important;
    }
    body #predictive-search-results .predictive-search-results__card--product .resource-card__image,
    body #predictive-search-results .predictive-search-results__card--product .resource-card__media img {
      width: 100% !important;
      height: 100% !important;
      object-fit: contain !important;
      padding: 10px !important;
      transition: transform .3s ease !important;
      border-radius: 0 !important;
    }
    body #predictive-search-results .predictive-search-results__card--product:hover .resource-card__image {
      transform: scale(1.02) !important;
    }

    /* Content-Bereich */
    body #predictive-search-results .predictive-search-results__card--product .resource-card__content {
      padding: 10px 12px 12px !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 4px !important;
      flex: 1 !important;
    }
    body #predictive-search-results .predictive-search-results__card--product .resource-card__title,
    body #predictive-search-results .predictive-search-results__card--product p.resource-card__title {
      font-family: var(--font-body--family, 'Inter', sans-serif) !important;
      font-size: 12.5px !important;
      font-weight: 600 !important;
      line-height: 1.35 !important;
      color: var(--color-foreground, #0d1e35) !important;
      letter-spacing: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      display: -webkit-box !important;
      -webkit-line-clamp: 2 !important;
      -webkit-box-orient: vertical !important;
      overflow: hidden !important;
      min-height: 2.7em !important;
    }

    /* Preis — prominent, tabular-nums */
    body #predictive-search-results .predictive-search-results__card--product .price {
      font-family: var(--font-body--family, 'Inter', sans-serif) !important;
      font-size: 14px !important;
      font-weight: 700 !important;
      color: var(--color-foreground, #0d1e35) !important;
      letter-spacing: 0 !important;
      font-variant-numeric: tabular-nums !important;
      margin: 2px 0 0 !important;
      padding: 0 !important;
      display: flex !important;
      flex-wrap: wrap !important;
      align-items: baseline !important;
      gap: 6px !important;
    }
    body #predictive-search-results .predictive-search-results__card--product .price *:not(s):not(.price__compare):not(.price__regular--compare) {
      font-size: 14px !important;
      font-weight: 700 !important;
      color: var(--color-foreground, #0d1e35) !important;
    }
    /* Vergleichspreis dezent + durchgestrichen */
    body #predictive-search-results .predictive-search-results__card--product .price s,
    body #predictive-search-results .predictive-search-results__card--product .price .price__compare,
    body #predictive-search-results .predictive-search-results__card--product .price .price__regular--compare {
      font-size: 11.5px !important;
      font-weight: 400 !important;
      color: rgba(0,0,0,0.45) !important;
      text-decoration: line-through !important;
      order: -1 !important;
    }
    /* Steuerhinweis */
    body #predictive-search-results .predictive-search-results__card--product .price::after {
      content: "inkl. MwSt." !important;
      display: block !important;
      width: 100% !important;
      margin-top: 1px !important;
      font-size: 10.5px !important;
      font-weight: 400 !important;
      color: rgba(0,0,0,0.5) !important;
      letter-spacing: 0 !important;
      font-variant-numeric: normal !important;
    }

    /* Query-Pills */
    body #predictive-search-results .predictive-search-results__wrapper-queries {
      display: flex !important;
      flex-wrap: wrap !important;
      gap: 6px !important;
      margin-bottom: 14px !important;
      padding: 0 0 12px !important;
      border-bottom: 1px solid var(--color-border, #DFDFDF) !important;
    }
    body #predictive-search-results .predictive-search-results__pill {
      padding: 6px 12px !important;
      font-size: 12px !important;
      font-weight: 500 !important;
      color: var(--color-foreground, #0d1e35) !important;
      background: #fff !important;
      border: 1px solid var(--color-border, #DFDFDF) !important;
      border-radius: 999px !important;
      text-decoration: none !important;
      transition: border-color .15s, background .15s !important;
    }
    body #predictive-search-results .predictive-search-results__pill:hover {
      border-color: var(--bz-orange, #f39200) !important;
      background: var(--bz-orange-light, #fff4e0) !important;
    }

    /* No-results */
    body #predictive-search-results .predictive-search-results__no-results {
      font-size: 13px !important;
      color: rgba(0,0,0,0.6) !important;
      padding: 20px 0 !important;
      text-align: center !important;
    }

    /* Skip-Animation & Placeholder-Noise */
    body #predictive-search-results .resource-card__image-placeholder {
      background: var(--bz-surface, #f8f7f4) !important;
      color: rgba(0,0,0,0.4) !important;
      font-size: 11px !important;
      padding: 10px !important;
      text-align: center !important;
    }
  </style>
  <div
    id="predictive-search-results"
    class="predictive-search-dropdown"
    role="listbox"
    aria-label="{{ 'content.search_results_label' | t }}"
    data-transition-container
    style="--color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));"
  >
    <div
      class="predictive-search-results__inner"
      data-search-results
    >
      {% if predictive_search.performed %}
        {% assign search_results_count = predictive_search.resources.products.size
          | plus: predictive_search.resources.pages.size
          | plus: predictive_search.resources.articles.size
          | plus: predictive_search.resources.collections.size
        %}
      {% else %}
        {% assign search_results_count = search.results_count %}
      {% endif %}

      <div
        class="visually-hidden"
        role="status"
      >
        {%- if predictive_search.performed and search_results_count > 0 -%}
          {{ 'accessibility.search_results_count' | t: count: search_results_count, query: predictive_search.terms }}
        {%- elsif predictive_search.performed and predictive_search.resources.queries.size > 0 -%}
          {{- 'accessibility.search_suggestions_available' | t: query: predictive_search.terms -}}
        {%- elsif predictive_search.performed -%}
          {{ 'accessibility.search_results_no_results' | t: query: predictive_search.terms }}
        {%- endif -%}
      </div>

      {% if predictive_search.performed %}
        {% if predictive_search.resources.queries.size > 0 %}
          <ul
            class="predictive-search-results__list predictive-search-results__wrapper predictive-search-results__wrapper-queries list-unstyled"
          >
            {%- for resource in predictive_search.resources.queries -%}
              <li
                class="predictive-search-results__card--query"
                ref="resultsItems[]"
                on:keydown="/onSearchKeyDown"
              >
                <a
                  class="pills__pill predictive-search-results__pill"
                  href="{{ resource.url }}"
                  aria-label="{{ resource.text }}"
                >
                  <span>
                    {{ resource.styled_text }}
                  </span>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {%- if search_results_count > 0 -%}
          {% if predictive_search.resources.products.size > 0 %}
            {%- liquid
              assign title = 'content.search_results_resource_products' | t
              assign products = predictive_search.resources.products
              render 'predictive-search-products-list', title: title, products: products
            -%}
          {% endif %}

          {% if predictive_search.resources.collections.size > 0 %}
            {% assign resource_title = 'content.search_results_resource_collections' | t %}

            {% render 'predictive-search-resource-carousel',
              title: resource_title,
              resource_type: 'collection',
              resources: predictive_search.resources.collections
            %}
          {% endif %}

          {% if predictive_search.resources.pages.size > 0 %}
            {% assign resource_title = 'content.search_results_resource_pages' | t %}

            {% render 'predictive-search-resource-carousel',
              title: resource_title,
              resource_type: 'page',
              resources: predictive_search.resources.pages
            %}
          {% endif %}

          {% if predictive_search.resources.articles.size > 0 %}
            {% assign resource_title = 'content.search_results_resource_articles' | t %}

            {% render 'predictive-search-resource-carousel',
              title: resource_title,
              resource_type: 'article',
              resources: predictive_search.resources.articles
            %}
          {% endif %}
        {%- elsif predictive_search.resources.queries.size == 0 -%}
          <p class="predictive-search-results__no-results">
            {{ 'content.search_results_no_results' | t: terms: predictive_search.terms }}
          </p>
        {% endif %}
      {% else %}
        {%- liquid
          assign title = 'content.recently_viewed_products' | t
          assign products = search.results

          comment
            Searching for recently viewed products by id doesn't preserve the order of the products.
            To work around this, we get the product ids into an array then use that to reorder them.
          endcomment
          if search.terms contains 'id:'
            assign new_products_ids = search.terms | replace: 'id:', '' | split: ' OR '
          endif
          render 'predictive-search-products-list', title: title, products: products, order_ids: new_products_ids, limit: 4
        -%}
      {% endif %}

      {% if predictive_search.performed %}
        {%- if search_results_count > 0 -%}
          {% assign total_results = predictive_search.resources.products.size
            | plus: predictive_search.resources.collections.size
            | plus: predictive_search.resources.pages.size
            | plus: predictive_search.resources.articles.size
          %}
          {% assign single_result_url = null %}
          {% if total_results == 1 %}
            {% if predictive_search.resources.products.size == 1 %}
              {% assign single_result_url = predictive_search.resources.products.first.url %}
            {% elsif predictive_search.resources.collections.size == 1 %}
              {% assign single_result_url = predictive_search.resources.collections.first.url %}
            {% elsif predictive_search.resources.pages.size == 1 %}
              {% assign single_result_url = predictive_search.resources.pages.first.url %}
            {% elsif predictive_search.resources.articles.size == 1 %}
              {% assign single_result_url = predictive_search.resources.articles.first.url %}
            {% endif %}
          {% endif %}

          {% if single_result_url %}
            <div data-single-result-url="{{ single_result_url }}"></div>
          {% endif %}
        {% endif %}
      {% endif %}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:names.predictive_search",
  "settings": [],
  "blocks": [
    {
      "type": "@theme"
    }
  ]
}
{% endschema %}
