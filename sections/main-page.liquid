{%- if page.handle == 'hersteller' or request.path contains '/pages/hersteller' -%}
  {% render 'blechziegel-hersteller' %}
{%- elsif page.handle == 'gewerbe' or request.path contains '/pages/gewerbe' -%}
  {% render 'blechziegel-gewerbe' %}
{%- elsif page.handle == 'solar-installateure' or request.path contains '/pages/solar-installateure' -%}
  {% render 'blechziegel-solar-installateure' %}
{%- elsif page.handle == 'ratgeber' or request.path contains '/pages/ratgeber' -%}
  {% render 'blechziegel-ratgeber' %}
{%- elsif page.handle == 'montageanleitung-mit-dachhaken' or page.handle == 'montageanleitung-ohne-dachhaken' or request.path contains '/pages/montageanleitung-' -%}
  {% render 'blechziegel-montage' %}
{%- elsif page.handle == 'agb' or request.path contains '/pages/agb' -%}
  {% render 'blechziegel-agb' %}
{%- elsif page.handle == 'haendler' or request.path contains '/pages/haendler' -%}
  {% render 'blechziegel-haendler' %}
{%- else -%}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section page-width-content color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "t:names.page",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
