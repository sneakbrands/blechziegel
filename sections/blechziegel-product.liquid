                  <div class="bz-inline-zubehoer__price">{{ _zp.price | money }}</div>
                </div>
                <div class="bz-inline-zubehoer__actions">
                  <div class="bz-inline-zubehoer__qty">
                    <button type="button" onclick="bzZubQty(this,-1)" aria-label="Weniger">&#8722;</button>
                    <input type="number" value="1" min="1" max="999" class="bz-inline-zubehoer__qty-input">
