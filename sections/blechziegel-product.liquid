              <tr><td>Gewicht</td><td>ca. 0,8 kg</td></tr>
              <tr><td>Farben</td><td>Aluminium blank · Anthrazit RAL 7016 · Ziegelrot RAL 8004</td></tr>
              <tr><td>Ausführung</td><td>Mit integriertem Dachhaken / Ohne Haken</td></tr>
              <tr><td>Herkunft</td><td>{{ cf_origin | default: 'Made in Germany' }}</td></tr>
              <tr><td>Lieferumfang</td><td>1 Stück PV-Blechziegel</td></tr>
              <tr><td>Einsatzbereich</td><td>PV-Montage, Solarthermie, Dachsanierung</td></tr>
