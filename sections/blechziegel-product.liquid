    },
    {
      "type": "text",
      "id": "cf_lead_time",
      "label": "Lieferzeit-Text",
      "default": "1–3 Werktage"
    },
    {
      "type": "number",
      "id": "cf_cutoff_hour",
      "label": "Cutoff-Stunde (Same-Day-Versand bis ... Uhr)",
      "default": 13
    },
    {
      "type": "text",
      "id": "cf_carrier",
      "label": "Versanddienstleister",
      "default": "DHL"
    },
    {
      "type": "text",
      "id": "cf_origin",
      "label": "Herkunfts-/Fertigungs-Label",
      "default": "Made in Germany"
    },
    {
      "type": "text",
      "id": "cf_free_threshold",
      "label": "Versandkostenfrei ab (z. B. '100 €' oder leer lassen)",
      "info": "Leer lassen, falls nicht verifiziert."
    }
  ],
  "presets": [
    {
      "name": "Blechziegel Produktseite"
    }
  ]
}
{% endschema %}
