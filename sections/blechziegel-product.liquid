{{ 'bz-customer-type.js' | asset_url | script_tag }}

<script>
  // Galerie
  function bzSetImg(src, thumb) {
    document.getElementById('bz-main-img-tag').src = src;
    document.querySelectorAll('.bz-gallery-thumb').forEach(function(t) {
      t.classList.remove('active');
      t.setAttribute('aria-current', 'false');
    });
    thumb.classList.add('active');
    thumb.setAttribute('aria-current', 'true');
  }

  // Thumbnail-Klick via Delegation (ersetzt Inline onclick)
  document.querySelectorAll('.bz-gallery-thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var src = thumb.dataset.src;
      if (src) bzSetImg(src, thumb);
    });
  });

  // Menge
  function bzQty(delta) {
    var inp = document.getElementById('bz-qty-input');
    var val = parseInt(inp.value) + delta;
    if (val < 1) val = 1;
    inp.value = val;
  }

  // Zubehör Kundentyp-Sync — hält Variante/Preis in .bz-inline-zubehoer__item
  // synchron mit der aktuell auf der PDP gewählten "Bestellung als"-Option.
  function bzFormatEuro(cents) {
    var euros = (cents / 100).toFixed(2).replace('.', ',');
    return euros + ' €';
  }
  function bzGetCurrentCustomerType() {
    var seg = document.querySelector('.bz-segment-input:checked');
    return seg ? seg.value : '';
  }
  function bzSyncInlineZubehoer() {
    var ct = bzGetCurrentCustomerType();
    if (!ct) return;
    document.querySelectorAll('.bz-inline-zubehoer__item[data-has-customer-type="true"]').forEach(function(item) {
      var raw = item.getAttribute('data-variants');
      if (!raw) return;
      var variants;
      try { variants = JSON.parse(raw); } catch (_) { return; }
      var match = variants.find(function(v) {
        return v.option1 === ct || v.option2 === ct || v.option3 === ct;
      });
      if (!match) return;
      item.dataset.variantId = match.id;
      var priceEl = item.querySelector('.bz-inline-zubehoer__price');
      if (priceEl) priceEl.textContent = bzFormatEuro(match.price);
      var atc = item.querySelector('.bz-inline-zubehoer__atc');
      if (atc) {
        if (match.available) {
          atc.disabled = false;
          atc.removeAttribute('aria-disabled');
        } else {
          atc.disabled = true;
          atc.setAttribute('aria-disabled', 'true');
        }
      }
    });
  }
  document.addEventListener('change', function(e) {
    if (e.target && e.target.classList && e.target.classList.contains('bz-segment-input')) {
      bzSyncInlineZubehoer();
    }
  });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bzSyncInlineZubehoer);
  } else {
    bzSyncInlineZubehoer();
  }

  // Länge Pill-Auswahl (z.B. Schrauben Länge)
  function bzSelectLength(btn) {
    var pos = btn.dataset.option;
    document.querySelectorAll('.bz-length-pill[data-option="' + pos + '"]').forEach(function(c) {
      c.classList.remove('active');
      c.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');
    var sel = document.querySelector('select[data-length-sync="' + pos + '"]');
    if (sel) { sel.value = btn.dataset.value; }
    bzUpdateVariant();
  }

  // Ausführung Card-Auswahl
  function bzSelectAusfuehrung(btn) {
    var pos = btn.dataset.option;
    document.querySelectorAll('.bz-ausfuehrung-card[data-option="' + pos + '"]').forEach(function(c) {
      c.classList.remove('active');
      c.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');
    var sel = document.getElementById('bz-ausfuehrung-select');
    if (sel) { sel.value = btn.dataset.value; }
    bzUpdateVariant();
  }

  // Zubehör Menge +/-
  function bzZubQty(btn, delta) {
    var inp = btn.parentElement.querySelector('.bz-inline-zubehoer__qty-input');
    var val = parseInt(inp.value) + delta;
    if (val < 1) val = 1;
    inp.value = val;
  }

  // Zubehör in den Warenkorb (AJAX)
  function bzAddZubehoer(btn) {
    var item = btn.closest('.bz-inline-zubehoer__item');
    var variantId = parseInt(item.dataset.variantId);
    var qty = parseInt(item.querySelector('.bz-inline-zubehoer__qty-input').value) || 1;
    var origText = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = '...';

    function bzZubShowError(msg) {
      btn.innerHTML = origText;
      btn.disabled = false;
      btn.classList.remove('added');
      var existing = item.querySelector('.bz-inline-zubehoer__error');
      if (existing) existing.remove();
      var err = document.createElement('div');
      err.className = 'bz-inline-zubehoer__error';
      err.setAttribute('role', 'alert');
      err.textContent = msg;
      item.appendChild(err);
      setTimeout(function() { if (err.parentNode) err.remove(); }, 5000);
    }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: qty }] })
    })
    .then(function(r) {
      return r.json().then(function(data) { return { ok: r.ok, status: r.status, data: data }; });
    })
    .then(function(res) {
      if (!res.ok) {
        var msg = (res.data && (res.data.description || res.data.message)) || 'Dieser Artikel konnte nicht hinzugefügt werden.';
        bzZubShowError(msg);
        return;
      }
      // Horizon-Theme Cart-Icon synchronisieren: cart:update auf document dispatchen
      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          document.dispatchEvent(new CustomEvent('cart:update', {
            bubbles: true,
            detail: { data: { itemCount: cart.item_count, source: 'bz-inline-zubehoer' } }
          }));
        })
        .catch(function() {});

      btn.classList.add('added');
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> Hinzugefügt';
      setTimeout(function() {
        btn.classList.remove('added');
        btn.innerHTML = origText;
        btn.disabled = false;
      }, 2000);
    })
    .catch(function() {
      bzZubShowError('Netzwerk-Fehler — bitte erneut versuchen.');
    });
  }

  // Farb-Swatches
  function bzSelectSwatch(el) {
    var pos = el.dataset.option;
    document.querySelectorAll('.bz-swatch[data-option="' + pos + '"]').forEach(function(s) {
      s.classList.remove('active');
      s.setAttribute('aria-pressed', 'false');
    });
    el.classList.add('active');
    el.setAttribute('aria-pressed', 'true');
    bzUpdateVariant();
  }

  // Swatch-Klick via Delegation (ersetzt Inline onclick)
  document.querySelectorAll('.bz-swatch').forEach(function(swatch) {
    swatch.addEventListener('click', function() { bzSelectSwatch(swatch); });
  });

  // Sticky-Kontext bauen — kurz, hochwertig, B2B-tauglich
  var BZ_PRODUCT_TITLE = {{ product.title | json }};
  var BZ_DACHTYPEN = ['Frankfurter Pfanne','Biberschwanz','Hohlfalzziegel','Flachdachziegel','Krempziegel'];

  function bzNormalizeOption(value) {
    if (!value) return '';
    var v = String(value).trim();
    var lower = v.toLowerCase();
    // Kundengruppe ausblenden
    if (lower.indexOf('privatkunde') !== -1 || lower.indexOf('gewerbekunde') !== -1) return '';
    // Ausführung kurz halten
    if (lower === 'mit haken') return 'Mit Haken';
    if (lower === 'ohne haken') return 'Ohne Haken';
    if (lower.indexOf('mit integriertem dachhaken') !== -1) return 'Mit Haken';
    if (lower.indexOf('ohne haken') !== -1) return 'Ohne Haken';
    return v;
  }

  function bzBuildStickyContext(opts) {
    // Dachtyp aus Titel ableiten
    var dachtyp = '';
    for (var i = 0; i < BZ_DACHTYPEN.length; i++) {
      if (BZ_PRODUCT_TITLE.indexOf(BZ_DACHTYPEN[i]) !== -1) { dachtyp = BZ_DACHTYPEN[i]; break; }
    }
    if (!dachtyp) {
      dachtyp = BZ_PRODUCT_TITLE.length > 32 ? BZ_PRODUCT_TITLE.substring(0, 32) + '…' : BZ_PRODUCT_TITLE;
    }

    var parts = [];
    Object.keys(opts).sort(function(a,b){return a-b;}).forEach(function(pos) {
      var clean = bzNormalizeOption(opts[pos]);
      if (clean) parts.push(clean);
    });

    var ctx = dachtyp;
    if (parts.length) ctx += ' • ' + parts.slice(0, 2).join(' • ');
    // Wenn zu lang, auf 1 Zusatz reduzieren; immer noch zu lang → nur Dachtyp
    if (ctx.length > 42 && parts.length > 1) ctx = dachtyp + ' • ' + parts[0];
    if (ctx.length > 42) ctx = dachtyp;
    return ctx;
  }

  // Steuerhinweis-Toggle lebt jetzt in assets/bz-customer-type.js (datengetrieben).
  // Hook: window.bzSyncCustomerTypeNote() — wird von bzUpdateVariant aufgerufen.

  // Variante aktualisieren
  function bzUpdateVariant() {
    var opts = {};
    document.querySelectorAll('.bz-swatch.active').forEach(s => {
      opts[parseInt(s.dataset.option)] = s.dataset.value;
    });
    document.querySelectorAll('.bz-select').forEach(sel => {
      var match = sel.name.match(/option(\d+)/);
      if (match) opts[parseInt(match[1])] = sel.value;
    });
    document.querySelectorAll('.bz-segment-input:checked').forEach(r => {
      var m = r.name.match(/option(\d+)/);
      if (m) opts[parseInt(m[1])] = r.value;
    });

    var variants = {{ product.variants | json }};
    var matched = variants.find(function(v) {
      return Object.keys(opts).every(function(pos) {
        return v['option' + pos] === opts[pos];
      });
    });

    // Sticky-Kontext immer aktualisieren (auch wenn keine Variante matcht)
    var ctxEl = document.getElementById('bz-sticky-context');
    if (ctxEl) ctxEl.textContent = bzBuildStickyContext(opts);

    // Dynamischer Steuerhinweis kommt aus assets/bz-customer-type.js
    if (typeof window.bzSyncCustomerTypeNote === 'function') {
      window.bzSyncCustomerTypeNote();
    }

    // Stock-Line an gematchte Variante binden
    var stockLine = document.getElementById('bz-stock-line');
    var stockLabel = document.getElementById('bz-stock-label');
    if (stockLine && stockLabel && matched) {
      var isAvail = matched.available === true;
      stockLine.dataset.available = isAvail ? 'true' : 'false';
      stockLabel.textContent = isAvail ? (stockLabel.dataset.labelAvailable || 'Auf Lager') : 'Derzeit nicht verfügbar';
    }

    if (matched) {
      document.getElementById('bz-variant-id').value = matched.id;
      var price = (matched.price / 100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });
      document.getElementById('bz-price').textContent = price;
      document.getElementById('bz-sticky-price').textContent = price;

      // Bild wechseln wenn vorhanden
      if (matched.featured_image) {
        var mainImg = document.getElementById('bz-main-img-tag');
        if (mainImg) mainImg.src = 'https:' + matched.featured_image.src + '&width=800';
        var stickyImg = document.getElementById('bz-sticky-image');
        if (stickyImg) stickyImg.src = 'https:' + matched.featured_image.src + '&width=120';
      }

      // ATC Status (Haupt + Sticky synchron)
      var btn = document.getElementById('bz-atc');
      var stickyBtn = document.getElementById('bz-sticky-btn');
      if (matched.available) {
        btn.disabled = false;
        btn.removeAttribute('aria-disabled');
        btn.style.opacity = '1';
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> In den Warenkorb';
        if (stickyBtn) { stickyBtn.disabled = false; stickyBtn.removeAttribute('aria-disabled'); stickyBtn.textContent = 'In den Warenkorb'; }
      } else {
        btn.disabled = true;
        btn.setAttribute('aria-disabled', 'true');
        btn.style.opacity = '.5';
        btn.innerHTML = 'Nicht verfügbar';
        if (stickyBtn) { stickyBtn.disabled = true; stickyBtn.setAttribute('aria-disabled', 'true'); stickyBtn.textContent = 'Nicht verfügbar'; }
      }
    } else {
      // Kombi nicht verfügbar (z.B. ausverkauft oder ungültige Optionsmischung)
      var atc = document.getElementById('bz-atc');
      var stickyBtnFb = document.getElementById('bz-sticky-btn');
      if (atc) {
        atc.disabled = true;
        atc.setAttribute('aria-disabled', 'true');
        atc.style.opacity = '.5';
        atc.innerHTML = 'Nicht verfügbar';
      }
      if (stickyBtnFb) {
        stickyBtnFb.disabled = true;
        stickyBtnFb.setAttribute('aria-disabled', 'true');
        stickyBtnFb.textContent = 'Nicht verfügbar';
      }
      var stickyPriceEl = document.getElementById('bz-sticky-price');
      if (stickyPriceEl) stickyPriceEl.textContent = '–';
    }
  }

  // Tabs
  function bzTab(id, btn) {
    document.querySelectorAll('.bz-tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.bz-tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
  }

  // FAQ
  document.querySelectorAll('.bz-faq-q').forEach(function(b) {
    b.addEventListener('click', function() {
      var i = b.parentElement, o = i.classList.contains('open');
      document.querySelectorAll('.bz-faq-item').forEach(function(x) { x.classList.remove('open'); });
      if (!o) i.classList.add('open');
    });
  });

  // Sticky ATC: nur auf Mobile anzeigen wenn ATC out of view
  var atcBtn = document.getElementById('bz-atc');
  if (atcBtn && window.innerWidth <= 900) {
    var observer = new IntersectionObserver(function(entries) {
      document.getElementById('bz-sticky').style.display = entries[0].isIntersecting ? 'none' : 'block';
    }, { threshold: 0 });
    observer.observe(atcBtn);
  }

  // Zubehör: Add-to-Cart via AJAX (H6)
  function bzAddonAdd(btn) {
    if (!btn || btn.disabled) return;
    var vid = btn.getAttribute('data-variant-id');
    var title = btn.getAttribute('data-title') || 'Produkt';
    var labelEl = btn.querySelector('.bz-addon-btn-label');
    if (!vid) return;
    btn.disabled = true;
    var originalLabel = labelEl ? labelEl.textContent : 'Hinzufügen';
    if (labelEl) labelEl.textContent = 'Wird hinzugefügt …';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
    })
    .then(function(r){ return r.ok ? r.json() : Promise.reject(r); })
    .then(function(){
      btn.setAttribute('data-added', '1');
      if (labelEl) labelEl.textContent = 'Im Warenkorb';
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      if (typeof window.dataLayer !== 'undefined') {
        window.dataLayer.push({ event: 'addon_added', addon_title: title, addon_variant_id: vid });
      }
      setTimeout(function(){
        btn.disabled = false;
        btn.removeAttribute('data-added');
        if (labelEl) labelEl.textContent = originalLabel;
      }, 2400);
    })
    .catch(function(){
      btn.disabled = false;
      if (labelEl) labelEl.textContent = 'Fehler – erneut versuchen';
      setTimeout(function(){ if (labelEl) labelEl.textContent = originalLabel; }, 2400);
    });
  }

  // Init
  bzUpdateVariant();
</script>

{%- comment -%}══ SEO: Product JSON-LD (erweitert + metafield-aware) ══{%- endcomment -%}
{%- liquid
  assign seo_variant = product.selected_or_first_available_variant
  assign mf_typ = product.metafields.custom.dachziegel_typ
  assign mf_laenge = product.metafields.custom.laenge
  assign mf_breite = product.metafields.custom.breite
  assign mf_hersteller = product.metafields.custom.passende_hersteller
  assign mf_material = product.metafields.shopify['shingle-tile-material']
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": {{ shop.url | append: product.url | json }},
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "image": [
    {%- for img in product.images limit: 6 -%}
      {{ img | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  "sku": {{ seo_variant.sku | default: product.id | json }},
  "mpn": {{ product.id | append: '-' | append: seo_variant.id | json }},
  "url": {{ shop.url | append: product.url | json }},
  "brand": { "@type": "Brand", "name": "Blechziegel.de" },
  "manufacturer": { "@type": "Organization", "name": "TiWi Trade GmbH", "url": {{ shop.url | json }} },
  {%- if mf_typ != blank -%}
  "category": {{ mf_typ.value | json }},
  {%- endif -%}
  {%- if mf_laenge != blank and mf_breite != blank -%}
  "additionalProperty": [
    {"@type":"PropertyValue","name":"Länge","value":{{ mf_laenge.value | json }},"unitCode":"MMT"},
    {"@type":"PropertyValue","name":"Breite","value":{{ mf_breite.value | json }},"unitCode":"MMT"}
    {%- if mf_material != blank -%},
    {"@type":"PropertyValue","name":"Material","value":"Aluminium"}
    {%- endif -%}
  ],
  {%- endif -%}
  {%- if mf_hersteller != blank -%}
  "isRelatedTo": [
    {%- for h in mf_hersteller.value -%}
      { "@type": "Product", "name": {{ h | json }} }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  {%- endif -%}
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": {{ shop.currency | json }},
    "lowPrice": "{{ product.price_min | divided_by: 100.0 }}",
    "highPrice": "{{ product.price_max | divided_by: 100.0 }}",
    "offerCount": {{ product.variants.size }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "url": {{ shop.url | append: product.url | json }},
    "seller": { "@type": "Organization", "name": "TiWi Trade GmbH" },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0.00", "currency": "EUR" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "DE" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 1, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 3, "unitCode": "DAY" }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "DE",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  }
}
</script>

{%- comment -%}══ SEO: BreadcrumbList (Hersteller-Achse) ══{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": {{ shop.url | append: '/' | json }} },
    {%- if brand_handle != blank -%}
    { "@type": "ListItem", "position": 2, "name": "Hersteller", "item": {{ shop.url | append: '/pages/hersteller' | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ brand_name | json }}, "item": {{ shop.url | append: '/collections/' | append: brand_handle | json }} },
    { "@type": "ListItem", "position": 4, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
    {%- else -%}
    { "@type": "ListItem", "position": 2, "name": "Produkte", "item": {{ shop.url | append: '/collections/pv-dachziegel' | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
    {%- endif -%}
  ]
}
</script>

