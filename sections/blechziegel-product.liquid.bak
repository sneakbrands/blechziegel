{%- comment -%}══ STICKY ATC MOBILE ══{%- endcomment -%}
<div class="bz-sticky-atc" id="bz-sticky">
  <div class="bz-sticky-atc-inner">
    <div class="bz-sticky-atc-info">
      <div class="bz-sticky-atc-name">{{ product.title | truncate: 30 }}</div>
      <div class="bz-sticky-atc-price" id="bz-sticky-price">{{ product.price_min | money }}</div>
    </div>
    <button class="bz-sticky-atc-btn" onclick="document.getElementById('bz-atc').click()">
      In den Warenkorb
    </button>
  </div>
</div>

<script>
  // Galerie
  function bzSetImg(src, thumb) {
    document.getElementById('bz-main-img-tag').src = src;
    document.querySelectorAll('.bz-gallery-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  // Menge
  function bzQty(delta) {
    var inp = document.getElementById('bz-qty-input');
    var val = parseInt(inp.value) + delta;
    if (val < 1) val = 1;
    inp.value = val;
  }

  // Farb-Swatches
  function bzSelectSwatch(el) {
    var pos = el.dataset.option;
    document.querySelectorAll('.bz-swatch[data-option="' + pos + '"]').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    bzUpdateVariant();
  }

  // Variante aktualisieren
  function bzUpdateVariant() {
    var opts = {};
    document.querySelectorAll('.bz-swatch.active').forEach(s => {
      opts[parseInt(s.dataset.option)] = s.dataset.value;
    });
    document.querySelectorAll('.bz-select').forEach(sel => {
      var match = sel.name.match(/option(\d+)/);
      if (match) opts[parseInt(match[1])] = sel.value;
    });

    var variants = {{ product.variants | json }};
    var matched = variants.find(function(v) {
      return Object.keys(opts).every(function(pos) {
        return v['option' + pos] === opts[pos];
      });
    });

    if (matched) {
      document.getElementById('bz-variant-id').value = matched.id;
      var price = (matched.price / 100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });
      document.getElementById('bz-price').textContent = price;
      document.getElementById('bz-sticky-price').textContent = price;

      // Bild wechseln wenn vorhanden
      if (matched.featured_image) {
        var imgSrc = matched.featured_image.src.replace(/(\.[^.]+)$/, '_800x800$1');
        document.getElementById('bz-main-img-tag').src = 'https:' + matched.featured_image.src + '&width=800';
      }

      // ATC Status
      var btn = document.getElementById('bz-atc');
      if (matched.available) {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> In den Warenkorb';
      } else {
        btn.disabled = true;
        btn.style.opacity = '.5';
        btn.innerHTML = 'Nicht verfügbar';
      }
    }
  }

  // Tabs
  function bzTab(id, btn) {
    document.querySelectorAll('.bz-tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.bz-tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
  }

  // FAQ
  document.querySelectorAll('.bz-faq-q').forEach(function(b) {
    b.addEventListener('click', function() {
      var i = b.parentElement, o = i.classList.contains('open');
      document.querySelectorAll('.bz-faq-item').forEach(function(x) { x.classList.remove('open'); });
      if (!o) i.classList.add('open');
    });
  });

  // Sticky ATC: nur auf Mobile anzeigen wenn ATC out of view
  var atcBtn = document.getElementById('bz-atc');
  if (atcBtn && window.innerWidth <= 900) {
    var observer = new IntersectionObserver(function(entries) {
      document.getElementById('bz-sticky').style.display = entries[0].isIntersecting ? 'none' : 'block';
    }, { threshold: 0 });
    observer.observe(atcBtn);
  }

  // Init
  bzUpdateVariant();
</script>

{% schema %}
{
  "name": "Blechziegel Produktseite",
  "tag": "section",
  "class": "bz-main-product",
  "settings": [],
  "presets": [
    {
      "name": "Blechziegel Produktseite"
    }
  ]
}
{% endschema %}
