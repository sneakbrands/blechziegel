{%- comment -%}══ 6. JSON-LD · CollectionPage + BreadcrumbList (vereinheitlicht) ══{%- endcomment -%}
{%- liquid
  assign coll_url = shop.url | append: collection.url
  if is_hersteller
    assign coll_name = 'PV-Dachziegel ' | append: hersteller_name
    assign coll_desc_fallback = 'Aluminium-Blechziegel für die PV-Montage auf Dächern mit ' | append: hersteller_name | append: '-Dachziegeln.'
  else
    assign coll_name = collection.title
    assign coll_desc_fallback = 'Aluminium-Blechziegel für die sichere PV-Montage — passgenau für alle gängigen Dachziegeltypen.'
  endif
  assign coll_desc = collection.description | strip_html | strip_newlines | default: coll_desc_fallback
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": {{ coll_name | json }},
      "description": {{ coll_desc | json }},
      "url": {{ coll_url | json }},
      "isPartOf": { "@type": "WebSite", "name": {{ shop.name | json }}, "url": {{ shop.url | json }} }{%- if is_hersteller %},
      "about": { "@type": "Brand", "name": {{ hersteller_name | json }} }{%- endif %}
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": {{ shop.url | append: '/' | json }} },
        {%- if is_hersteller -%}
        { "@type": "ListItem", "position": 2, "name": "Hersteller", "item": {{ shop.url | append: '/pages/hersteller' | json }} },
        {%- else -%}
        { "@type": "ListItem", "position": 2, "name": "Produkte", "item": {{ shop.url | append: '/collections/pv-dachziegel' | json }} },
        {%- endif -%}
        { "@type": "ListItem", "position": 3, "name": {{ collection.title | json }}, "item": {{ coll_url | json }} }
      ]
    }
  ]
}
</script>

<script>
  function bzSort(val) {
    var url = new URL(window.location.href);
    url.searchParams.set('sort_by', val);
    window.location.href = url.toString();
  }

  function bzApplyFilter(checkbox) {
    var url = new URL(window.location.href);
    var name = checkbox.name;
    var value = checkbox.value;
    if (checkbox.checked) {
      url.searchParams.append(name, value);
    } else {
      var params = url.searchParams.getAll(name).filter(function(v) { return v !== value; });
      url.searchParams.delete(name);
      params.forEach(function(v) { url.searchParams.append(name, v); });
    }
    window.location.href = url.toString();
  }

  function bzResetDachtyp() {
    window.location.href = '{{ collection.url }}';
  }

  // Reset-Button anzeigen wenn Filter aktiv
  var hasFilter = window.location.search.length > 1;
  if (hasFilter) {
    var resetBtn = document.getElementById('bz-reset-filter');
    if (resetBtn) resetBtn.classList.add('visible');
  }

  // Details schließen bei Klick außerhalb
  document.addEventListener('click', function(e) {
    document.querySelectorAll('.bz-filter-bar details[open]').forEach(function(d) {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });
</script>

