{% comment %}
  blechziegel.de – Startseite
  Optimiert für: Shopify Horizon Theme
  Datei: sections/blechziegel-home.liquid
  Bilder: Shopify Admin → Inhalte → Dateien → hochladen
{% endcomment %}

{%- liquid
  assign hero_image = section.settings.hero_image
  assign hero_image_mobile = section.settings.hero_image_mobile
  assign bestseller_collection = collections[section.settings.bestseller_collection] | default: collections['all']
-%}

{% style %}
  /* ═══════════════════════════════════════════════
     Horizon-kompatible CSS Custom Properties
     Nutzt Horizon's --color-* und --font-* Variablen
  ═══════════════════════════════════════════════ */
  #shopify-section-{{ section.id }} {
    --bz-orange: #f5a623;
    --bz-orange-dark: #d4891a;
    --bz-orange-light: #fff4e0;
    --bz-navy: #0d1e35;
    --bz-navy-mid: #152840;
    --bz-r: 6px;
    --bz-r-lg: 12px;
  }

  /* Typografie greift auf Horizon-Fonts zurück */
  .bz-wrap { max-width: 1160px; margin: 0 auto; padding: 0 20px; }
  .bz-section { padding: 72px 0; }
  .bz-label {
    font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--bz-orange);
    margin-bottom: 10px; display: block;
  }
  .bz h1, .bz h2, .bz h3 {
    font-family: var(--font-heading-family, var(--font-body-family, inherit));
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.15;
  }
  .bz h1 { font-size: clamp(1.9rem, 4.5vw, 3rem); }
  .bz h2 { font-size: clamp(1.4rem, 3vw, 2.1rem); }
  .bz h3 { font-size: 1.05rem; font-weight: 600; }
  .bz p, .bz li, .bz span {
    font-family: var(--font-body-family, inherit);
  }

  /* ── BUTTONS ── */
  .bz-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 24px; border-radius: var(--bz-r);
    font-size: 15px; font-weight: 600; cursor: pointer;
    text-decoration: none; transition: all .18s; border: 2px solid transparent;
    white-space: nowrap; font-family: var(--font-body-family, inherit);
  }
  .bz-btn-primary { background: var(--bz-orange); color: var(--bz-navy); border-color: var(--bz-orange); }
  .bz-btn-primary:hover { background: var(--bz-orange-dark); border-color: var(--bz-orange-dark); }
  .bz-btn-ghost { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .bz-btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,.08); }
  .bz-btn-navy { background: var(--bz-navy); color: #fff; border-color: var(--bz-navy); }
  .bz-btn-navy:hover { background: var(--bz-navy-mid); }
  .bz-btn-outline { background: transparent; color: var(--bz-navy); border-color: rgba(13,30,53,.3); }
  .bz-btn-outline:hover { background: var(--bz-navy); color: #fff; }

  /* ── 1. HERO ── */
  .bz-hero { background: var(--bz-navy); position: relative; overflow: hidden; }
  .bz-hero-img {
    width: 100%; display: block;
    max-height: 580px; object-fit: cover; object-position: center;
  }
  .bz-hero-img-placeholder {
    width: 100%; height: 500px;
    background: linear-gradient(135deg, #0d1e35 0%, #1e3a56 100%);
  }
  .bz-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(13,30,53,.9) 0%, rgba(13,30,53,.6) 50%, rgba(13,30,53,.15) 100%);
    pointer-events: none;
  }
  .bz-hero-overlay-mobile {
    display: none;
  }
  .bz-hero-content {
    position: absolute; inset: 0; display: flex; align-items: center; padding: 0 20px;
  }
  .bz-hero-content-inner {
    max-width: 1160px; margin: 0 auto; width: 100%; padding: 48px 0;
  }
  .bz-hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(245,166,35,.18); border: 1px solid rgba(245,166,35,.4);
    color: var(--bz-orange); font-size: 11.5px; font-weight: 600;
    padding: 5px 14px; border-radius: 20px; margin-bottom: 18px; letter-spacing: .04em;
  }
  .bz-hero h1 { color: #fff; margin-bottom: 16px; max-width: 560px; }
  .bz-hero h1 em { font-style: normal; color: var(--bz-orange); }
  .bz-hero-sub {
    font-size: 16px; color: rgba(255,255,255,.72);
    margin-bottom: 28px; max-width: 480px; line-height: 1.7;
  }
  .bz-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px; }
  .bz-hero-trust { display: flex; flex-wrap: wrap; gap: 18px; }
  .bz-hero-trust-item { display: flex; align-items: center; gap: 7px; font-size: 13px; color: rgba(255,255,255,.65); }
  .bz-hero-trust-item svg { color: var(--bz-orange); flex-shrink: 0; }

  /* ── 1b. ZIEGEL-FINDER-TEASER ── */
  .bz-finder-teaser { background: #fff; border-top: 1px solid #e9ecef;
    border-bottom: 1px solid #e9ecef; padding: 44px 0; }
  .bz-finder-teaser__inner { display: grid; grid-template-columns: 1fr; gap: 28px;
    max-width: 1120px; margin: 0 auto; }
  .bz-finder-teaser__head { max-width: 640px; }
  .bz-finder-teaser__title { color: var(--bz-navy); margin: 8px 0 10px;
    font-size: clamp(22px, 2.4vw, 28px); font-weight: 800; line-height: 1.22; }
  .bz-finder-teaser__title em { font-style: normal; color: var(--bz-orange); }
  .bz-finder-teaser__sub { color: #5a5955; font-size: 15px; line-height: 1.65; margin: 0; }
  .bz-finder-teaser__steps { list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .bz-finder-teaser__step { display: flex; gap: 14px; align-items: flex-start;
    padding: 18px 20px; background: #f8f9fb; border: 1px solid #e9ecef;
    border-radius: 10px; border-left: 3px solid var(--bz-orange);
    transition: background .18s, transform .18s; }
  .bz-finder-teaser__step:hover { background: #fff; transform: translateY(-1px); }
  .bz-finder-teaser__num { display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    background: var(--bz-orange); color: var(--bz-navy);
    font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 800; }
  .bz-finder-teaser__step-title { font-family: 'Montserrat', sans-serif;
    font-size: 14.5px; font-weight: 800; color: var(--bz-navy); margin-bottom: 3px; }
  .bz-finder-teaser__step-desc { font-size: 13px; line-height: 1.55; color: #5a5955; }
  .bz-finder-teaser__ctas { display: flex; gap: 18px; flex-wrap: wrap;
    align-items: center; margin-top: 6px; }
  .bz-finder-teaser__help { font-family: 'Montserrat', sans-serif; font-size: 13.5px;
    font-weight: 600; color: var(--bz-navy); text-decoration: none;
    transition: color .15s; }
  .bz-finder-teaser__help span { color: var(--bz-orange); font-weight: 700;
    text-decoration: underline; text-underline-offset: 2px; }
  .bz-finder-teaser__help:hover span { color: var(--bz-navy); }
  @media (max-width: 820px) {
    .bz-finder-teaser { padding: 32px 0; }
    .bz-finder-teaser__steps { grid-template-columns: 1fr; gap: 10px; }
    .bz-finder-teaser__step { padding: 14px 16px; }
    .bz-finder-teaser__ctas { gap: 14px; }
    .bz-finder-teaser__help { font-size: 13px; }
  }

  /* ── 2. DACHTYPEN ── */
  .bz-dachtypen { background: #f8f8f6; }
  .bz-dach-intro { max-width: 620px; margin-bottom: 44px; }
  .bz-dach-intro h2 { color: var(--bz-navy); margin-top: 8px; }
  .bz-dach-intro p { margin-top: 12px; color: #5a5955; font-size: 15px; }
  .bz-dach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .bz-dach-card {
    background: #fff; border: 1.5px solid #e2e0d8;
    border-radius: var(--bz-r-lg); padding: 22px 18px;
    display: flex; flex-direction: column; gap: 10px;
    transition: all .18s; color: inherit; text-decoration: none;
  }
  .bz-dach-card:hover { border-color: var(--bz-orange); box-shadow: 0 4px 20px rgba(245,166,35,.12); transform: translateY(-2px); }
  .bz-dach-icon { width: 42px; height: 42px; background: var(--bz-orange-light); border-radius: var(--bz-r); display: flex; align-items: center; justify-content: center; }
  .bz-dach-icon svg { color: var(--bz-orange); }
  .bz-dach-name { font-weight: 700; font-size: 14px; color: var(--bz-navy); }
  .bz-dach-desc { font-size: 13px; color: #5a5955; line-height: 1.55; }
  .bz-dach-link { font-size: 13px; color: var(--bz-orange); font-weight: 600; margin-top: auto; display: flex; align-items: center; gap: 4px; }

  /* ── 3. USPS ── */
  .bz-usp-head { max-width: 600px; margin-bottom: 44px; }
  .bz-usp-head h2 { color: var(--bz-navy); margin-top: 8px; }
  .bz-usp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .bz-usp-card { padding: 26px 22px; border: 1.5px solid #e2e0d8; border-radius: var(--bz-r-lg); background: #fff; transition: border-color .18s; }
  .bz-usp-card:hover { border-color: var(--bz-orange); }
  .bz-usp-icon { width: 46px; height: 46px; border-radius: var(--bz-r); background: var(--bz-orange-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; color: var(--bz-orange); }
  .bz-usp-card h3 { color: var(--bz-navy); margin-bottom: 7px; }
  .bz-usp-card p { font-size: 14px; color: #5a5955; line-height: 1.6; }

  /* ── 4. BESTSELLER ── */
  .bz-bestseller { background: #f8f8f6; }
  .bz-bestseller-head { max-width: 600px; margin-bottom: 44px; }
  .bz-bestseller-head h2 { color: var(--bz-navy); margin-top: 8px; }
  .bz-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

  /* Premium Produktkarte */
  .bz-product-card {
    background: #ffffff;
    border: 1px solid rgba(13, 30, 53, 0.08);
    border-radius: 22px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
    box-shadow: 0 8px 24px rgba(13, 30, 53, 0.05);
  }
  .bz-product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 42px rgba(13, 30, 53, 0.12);
    border-color: rgba(245, 166, 35, 0.32);
  }

  /* Bildbereich hochwertiger und größer */
  .bz-product-img {
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background:
      radial-gradient(circle at top left, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0) 32%),
      linear-gradient(180deg, #f8f7f4 0%, #efede8 100%);
    border-bottom: 1px solid rgba(13, 30, 53, 0.05);
  }
  .bz-product-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0) 45%);
    pointer-events: none;
  }
  .bz-product-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 16px 24px rgba(0, 0, 0, 0.08));
    transition: transform .28s ease, filter .28s ease;
  }
  .bz-product-card:hover .bz-product-img img {
    transform: scale(1.045);
    filter: drop-shadow(0 18px 28px rgba(0, 0, 0, 0.12));
  }

  /* Klickbare Bild- und Titel-Wrapper */
  .bz-product-img-link,
  .bz-product-name-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }
  .bz-product-name-link:hover .bz-product-name,
  .bz-product-name-link:focus-visible .bz-product-name {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .bz-product-img-link:focus-visible,
  .bz-product-name-link:focus-visible {
    outline: 2px solid var(--bz-navy);
    outline-offset: 2px;
    border-radius: 8px;
  }

  /* Badge hochwertiger */
  .bz-product-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(245, 166, 35, 0.96);
    color: var(--bz-navy);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .02em;
    box-shadow: 0 6px 14px rgba(245, 166, 35, 0.22);
  }

  /* Inhaltsbereich ruhiger und edler */
  .bz-product-body {
    padding: 20px 18px 18px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bz-product-name {
    color: var(--bz-navy);
    font-weight: 700;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0;
  }
  .bz-product-desc {
    font-size: 13px;
    color: #5a5955;
    flex: 1;
    line-height: 1.55;
  }

  /* Preisblock mehr Fokus */
  .bz-product-price {
    color: var(--bz-navy);
    font-size: clamp(1.55rem, 2vw, 1.9rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    font-family: var(--font-heading-family, inherit);
  }
  .bz-product-price-sub { font-size: 11.5px; color: #9a9890; margin-top: 4px; }

  /* Trust-Line unter dem Preis */
  .bz-product-trustline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    padding: 10px 12px;
    background: #f8f7f4;
    border: 1px solid rgba(13, 30, 53, 0.06);
    border-radius: 12px;
    cursor: default;
    transition: background .15s ease, border-color .15s ease;
  }
  .bz-product-card:hover .bz-product-trustline {
    background: #f5f4f1;
    border-color: rgba(13, 30, 53, 0.08);
  }
  .bz-product-trustitem {
    color: var(--bz-navy);
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1.4;
  }
  .bz-product-trustitem:first-child {
    font-weight: 700;
  }
  .bz-product-trustdot {
    color: rgba(245, 166, 35, 0.9);
    font-weight: 700;
    line-height: 1;
  }

  .bz-product-cta { margin-top: 2px; }

  /* CTA stärker, aber markenkonform — nur innerhalb der Karte */
  .bz-product-card .bz-btn-primary {
    width: 100%;
    justify-content: center;
    min-height: 54px;
    border-radius: 14px;
    background: linear-gradient(180deg, #f5a623 0%, #eb9d1e 100%);
    color: var(--bz-navy);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    box-shadow: 0 10px 20px rgba(245, 166, 35, 0.18);
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
  }
  .bz-product-card .bz-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(245, 166, 35, 0.24);
    background: linear-gradient(180deg, #f7ad34 0%, #eea225 100%);
  }
  .bz-products-more { text-align: center; margin-top: 36px; }

  /* ── 5. PROBLEM / LÖSUNG ── */
  .bz-pvl { background: var(--bz-navy); }
  .bz-pvl-head { margin-bottom: 44px; }
  .bz-pvl-head h2 { color: #fff; margin-top: 8px; }
  .bz-pvl-head p { color: rgba(255,255,255,.6); margin-top: 12px; max-width: 560px; font-size: 15px; }
  .bz-pvl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .bz-pvl-col { border-radius: var(--bz-r-lg); padding: 28px 24px; }
  .bz-pvl-col.problem { background: rgba(220,53,53,.1); border: 1.5px solid rgba(220,53,53,.2); }
  .bz-pvl-col.solution { background: rgba(245,166,35,.08); border: 1.5px solid rgba(245,166,35,.25); }
  .bz-pvl-col-head { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
  .bz-pvl-col-label { font-size: 12px; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; }
  .bz-pvl-col.problem .bz-pvl-col-label { color: #f08080; }
  .bz-pvl-col.solution .bz-pvl-col-label { color: var(--bz-orange); }
  .bz-pvl-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .bz-pvl-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,.8); line-height: 1.5; }
  .bz-pvl-list li .ico { flex-shrink: 0; margin-top: 1px; }

  /* ── 6. SOCIAL PROOF ── */
  .bz-proof-nums { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 36px; }
  .bz-proof-num { text-align: center; padding: 24px; background: #f8f8f6; border-radius: var(--bz-r-lg); border: 1.5px solid #e2e0d8; }
  .bz-proof-num-big { font-size: 2.2rem; font-weight: 700; color: var(--bz-orange); font-family: var(--font-heading-family, inherit); }
  .bz-proof-num-label { font-size: 13px; color: #5a5955; margin-top: 4px; }
  .bz-reviews-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .bz-review-card { border: 1.5px solid #e2e0d8; border-radius: var(--bz-r-lg); padding: 22px; background: #fff; }
  .bz-review-stars { color: var(--bz-orange); font-size: 16px; letter-spacing: 2px; margin-bottom: 10px; }
  .bz-review-text { font-size: 14px; color: #5a5955; line-height: 1.6; margin-bottom: 14px; }
  .bz-review-author { font-size: 13px; font-weight: 700; color: var(--bz-navy); }
  .bz-review-role { font-size: 12px; color: #9a9890; }

  /* ── 7. SO FUNKTIONIERT'S ── */
  .bz-how { background: #f8f8f6; }
  .bz-how-head { max-width: 600px; margin-bottom: 48px; }
  .bz-how-head h2 { color: var(--bz-navy); margin-top: 8px; }
  .bz-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; position: relative; }
  .bz-steps::before { content: ''; position: absolute; top: 27px; left: calc(12.5% + 4px); right: calc(12.5% + 4px); height: 2px; background: #e2e0d8; z-index: 0; }
  .bz-step { position: relative; z-index: 1; text-align: center; }
  .bz-step-num { width: 54px; height: 54px; border-radius: 50%; background: var(--bz-orange); color: var(--bz-navy); font-size: 20px; font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto 18px; border: 3px solid #f8f8f6; font-family: var(--font-heading-family, inherit); }
  .bz-step h3 { color: var(--bz-navy); margin-bottom: 8px; font-size: 14px; }
  .bz-step p { font-size: 13px; color: #5a5955; line-height: 1.55; }

  /* ── 8. FAQ ── */
  .bz-faq-wrap { max-width: 780px; }
  .bz-faq-wrap h2 { color: var(--bz-navy); margin-top: 8px; margin-bottom: 36px; }
  .bz-faq-item { border-bottom: 1px solid #e2e0d8; }
  .bz-faq-q {
    width: 100%; text-align: left; background: none; border: none;
    padding: 18px 0; font-size: 15px; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    line-height: 1.4; color: #1a1a18;
    font-family: var(--font-body-family, inherit);
  }
  .bz-faq-q:hover { color: var(--bz-orange); }
  .bz-faq-icon { min-width: 20px; height: 20px; transition: transform .2s; color: var(--bz-orange); }
  .bz-faq-item.open .bz-faq-icon { transform: rotate(45deg); }
  .bz-faq-a { display: none; padding-bottom: 18px; font-size: 14.5px; color: #5a5955; line-height: 1.7; }
  .bz-faq-item.open .bz-faq-a { display: block; }

  /* ── 8.5 SERVICE BOXEN ── */
  .bz-svc-head { text-align: center; margin-bottom: 40px; }
  .bz-svc-head h2 { color: var(--bz-navy); margin-top: 8px; }
  .bz-svc-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .bz-svc-card {
    background: linear-gradient(180deg, var(--bz-navy) 0%, var(--bz-navy-mid) 100%);
    border-radius: var(--bz-r-lg);
    padding: 32px 28px;
    color: #fff;
    border: 1px solid rgba(255,255,255,.06);
    box-shadow: 0 10px 30px rgba(13,30,53,.12);
  }
  .bz-svc-num {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: .14em;
    text-transform: uppercase; color: var(--bz-navy);
    background: var(--bz-orange);
    padding: 5px 10px; border-radius: 4px;
    margin-bottom: 20px;
  }
  .bz-svc-card h3 {
    font-size: 1.55rem; font-weight: 700; line-height: 1.2;
    margin-bottom: 18px; color: #fff;
  }
  .bz-svc-card h3 .accent { color: var(--bz-orange); }
  .bz-svc-list { list-style: none; padding: 0; margin: 0; }
  .bz-svc-list li {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 7px 0;
    font-size: 15px; line-height: 1.45;
    color: rgba(255,255,255,.92);
  }
  .bz-svc-list li svg { flex: 0 0 auto; margin-top: 3px; color: var(--bz-orange); }

