{% comment %}
  blechziegel.de – Announcement Bar
  Datei: sections/announcement-bar.liquid
  Horizon Theme kompatibel
{% endcomment %}

{% style %}
  .bz-announcement-bar {
    background-color: #0d1e35;
    padding: 9px 20px;
  }
  .bz-announcement-bar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }
  .bz-announcement-bar li {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.85);
    padding: 3px 18px;
    white-space: nowrap;
    font-family: var(--font-body-family, sans-serif);
  }
  .bz-announcement-bar li + li {
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }
  .bz-announcement-bar li svg {
    color: #f5a623;
    flex-shrink: 0;
  }
  .bz-announcement-bar .bz-stars {
    color: #f5c542;
    font-size: 12px;
    margin-right: 2px;
    letter-spacing: 1px;
  }
  .bz-countdown { color: #ffe8b8 !important; font-weight: 600; }
  .bz-countdown svg { color: #f5a623; }
  .bz-countdown__time { color: #ffffff; font-variant-numeric: tabular-nums; }
  .bz-countdown__star { color: #f5a623; margin-left: 2px; font-weight: 700; }
  .bz-announcement-note {
    text-align: center;
    font-size: 10.5px;
    color: rgba(255,255,255,.55);
    padding: 2px 20px 6px;
    letter-spacing: .01em;
    font-family: var(--font-body-family, sans-serif);
  }
  @media (max-width: 640px) {
    .bz-announcement-bar li {
      padding: 3px 10px;
      font-size: 11.5px;
    }
    .bz-announcement-bar li:last-child {
      display: none;
    }
    .bz-announcement-note { font-size: 10px; padding: 2px 10px 5px; }
  }
{% endstyle %}

<div class="bz-announcement-bar">
  <ul>
    <li class="bz-countdown" data-bz-countdown hidden>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 6v6l4 2"/>
      </svg>
      <span>Noch <span class="bz-countdown__time" data-bz-countdown-time>--</span> bis Versand heute<span class="bz-countdown__star">*</span></span>
    </li>
    <li>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="1" y="3" width="15" height="13" rx="1"/>
        <path d="M16 8h4l3 5v3h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      {{ section.settings.item_1 | default: 'Kostenloser Versand ab 100 €' }}
    </li>
    <li>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
      </svg>
      {{ section.settings.item_2 | default: 'Lieferzeit 1–3 Werktage' }}
    </li>
    <li>
      <span class="bz-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      {{ section.settings.item_3 | default: 'Trusted Shops · 4,9 / 5' }}
    </li>
  </ul>
  <div class="bz-announcement-note" data-bz-countdown-note hidden>* garantiert bei Bestellungen unter 100 Ziegeln</div>
</div>

<script>
  (function () {
    var item = document.querySelector('[data-bz-countdown]');
    var timeEl = document.querySelector('[data-bz-countdown-time]');
    var noteEl = document.querySelector('[data-bz-countdown-note]');
    if (!item || !timeEl) return;

    function berlinNow() {
      var parts = new Intl.DateTimeFormat('en-GB', {
        timeZone: 'Europe/Berlin',
        hour12: false,
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        weekday: 'short'
      }).formatToParts(new Date());
      var p = {};
      parts.forEach(function (x) { p[x.type] = x.value; });
      return {
        h: parseInt(p.hour, 10),
        m: parseInt(p.minute, 10),
        s: parseInt(p.second, 10),
        weekday: p.weekday
      };
    }

    function update() {
      var t = berlinNow();
      var isWeekend = t.weekday === 'Sat' || t.weekday === 'Sun';
      var cutoffMin = 12 * 60;
      var nowMin = t.h * 60 + t.m;
      if (isWeekend || nowMin >= cutoffMin) {
        item.hidden = true;
        if (noteEl) noteEl.hidden = true;
        return;
      }
      var remaining = cutoffMin - nowMin;
      var hh = Math.floor(remaining / 60);
      var mm = remaining % 60;
      var label = hh > 0 ? hh + ' Std ' + mm + ' Min' : mm + ' Min';
      timeEl.textContent = label;
      item.hidden = false;
      if (noteEl) noteEl.hidden = false;
    }

    update();
    setInterval(update, 30000);
  })();
</script>

{% schema %}
{
  "name": "Ankündigungsleiste",
  "tag": "section",
  "class": "bz-announcement-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Trust-Punkte"
    },
    {
      "type": "text",
      "id": "item_1",
      "label": "Punkt 1",
      "default": "Kostenloser Versand ab 100 €"
    },
    {
      "type": "text",
      "id": "item_2",
      "label": "Punkt 2",
      "default": "Lieferzeit 1–3 Werktage"
    },
    {
      "type": "text",
      "id": "item_3",
      "label": "Punkt 3",
      "default": "Trusted Shops · 4,9 / 5"
    }
  ],
  "presets": [
    {
      "name": "Ankündigungsleiste"
    }
  ]
}
{% endschema %}
