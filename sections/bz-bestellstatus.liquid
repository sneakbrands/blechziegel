{% comment %}
  Bestellstatus-Section
  Endkunde gibt Order-Nr + E-Mail → Backend (scripts/bestellstatus) → Status + Tracking
  Backend-URL ist als Theme-Setting konfigurierbar.
{% endcomment %}

<section class="bz-bestellstatus" aria-labelledby="bz-bestellstatus-heading">
  <div class="bz-bestellstatus__wrap">
    <h1 id="bz-bestellstatus-heading" class="bz-bestellstatus__title">{{ section.settings.heading | default: 'Bestellstatus einsehen' }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="bz-bestellstatus__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <form class="bz-bestellstatus__form" id="bz-bestellstatus-form" novalidate>
      <label class="bz-bestellstatus__field">
        <span>Bestellnummer</span>
        <input type="text" name="order_number" required autocomplete="off" inputmode="numeric" placeholder="z. B. 1234">
      </label>
      <label class="bz-bestellstatus__field">
        <span>E-Mail-Adresse aus Ihrer Bestellung</span>
        <input type="email" name="email" required autocomplete="email" placeholder="name@example.de">
      </label>
      <button type="submit" class="bz-bestellstatus__submit">Status abrufen</button>
      <p class="bz-bestellstatus__hint">Wir prüfen anhand beider Angaben, ob die Bestellung Ihnen gehört. Ihre E-Mail wird nicht gespeichert.</p>
    </form>

    <div class="bz-bestellstatus__result" id="bz-bestellstatus-result" aria-live="polite" hidden></div>
  </div>
</section>

<style>
  .bz-bestellstatus { padding: 48px 20px; background: #f6f5f1; }
  .bz-bestellstatus__wrap { max-width: 640px; margin: 0 auto; }
  .bz-bestellstatus__title { font-size: clamp(24px, 4vw, 36px); color: #0e2a4a; margin: 0 0 12px; }
  .bz-bestellstatus__intro { color: #4a5a72; margin: 0 0 24px; }
  .bz-bestellstatus__form { display: grid; gap: 16px; padding: 24px; background: #fff; border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,.04); }
  .bz-bestellstatus__field { display: grid; gap: 6px; font-size: 14px; color: #0e2a4a; }
  .bz-bestellstatus__field input { padding: 12px 14px; border: 1px solid #d0d4dc; border-radius: 6px; font-size: 16px; background: #fff; }
  .bz-bestellstatus__field input:focus { outline: 2px solid #e87722; outline-offset: 1px; border-color: #e87722; }
  .bz-bestellstatus__submit { padding: 14px 20px; background: #e87722; color: #fff; border: 0; border-radius: 6px; font-size: 16px; font-weight: 600; cursor: pointer; }
  .bz-bestellstatus__submit:hover { background: #d16917; }
  .bz-bestellstatus__submit:disabled { background: #b2b8c2; cursor: not-allowed; }
  .bz-bestellstatus__hint { font-size: 12px; color: #6b7480; margin: 4px 0 0; }

  .bz-bestellstatus__result { margin-top: 24px; padding: 24px; background: #fff; border-radius: 8px; border-left: 4px solid #0e2a4a; }
  .bz-bestellstatus__result[data-kind="error"] { border-left-color: #c43b2b; }
  .bz-bestellstatus__result[data-kind="ok"] { border-left-color: #2a8a4a; }
  .bz-bestellstatus__result h2 { font-size: 20px; color: #0e2a4a; margin: 0 0 8px; }
  .bz-bestellstatus__result p { margin: 0 0 8px; color: #0e2a4a; }
  .bz-bestellstatus__result .muted { color: #6b7480; font-size: 14px; }
  .bz-bestellstatus__result .items { margin: 16px 0 0; padding: 0; list-style: none; }
  .bz-bestellstatus__result .items li { padding: 8px 0; border-top: 1px solid #eee; font-size: 14px; }
  .bz-bestellstatus__result .items li:first-child { border-top: 0; }
  .bz-bestellstatus__result a.track { display: inline-block; margin-top: 8px; padding: 10px 16px; background: #0e2a4a; color: #fff; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; }
  .bz-bestellstatus__result a.track:hover { background: #15365e; }
</style>

<script>
(function(){
  var API = {{ section.settings.api_url | json }};
  var form = document.getElementById('bz-bestellstatus-form');
  var result = document.getElementById('bz-bestellstatus-result');
  var btn = form.querySelector('button[type="submit"]');

  function esc(s){ return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function fmtDate(iso){ if(!iso) return ''; try { return new Date(iso).toLocaleDateString('de-DE', { day:'2-digit', month:'2-digit', year:'numeric' }); } catch(e){ return ''; } }

  function showError(msg){
    result.setAttribute('data-kind','error');
    result.hidden = false;
    result.innerHTML = '<h2>Hinweis</h2><p>' + esc(msg) + '</p>';
  }

  function showOk(d){
    result.setAttribute('data-kind','ok');
    result.hidden = false;
    var html = '<h2>Bestellung ' + esc(d.order_name) + '</h2>';
    html += '<p><strong>' + esc(d.status_label) + '</strong> — ' + esc(d.status_detail) + '</p>';
    html += '<p class="muted">Bestellt am ' + esc(fmtDate(d.bestellt_am)) + (d.versand_nach ? ' · Versand nach ' + esc(d.versand_nach.ort) + ' (' + esc(d.versand_nach.plz) + ')' : '') + '</p>';
    if (d.tracking && d.tracking.url) {
      html += '<a class="track" href="' + esc(d.tracking.url) + '" target="_blank" rel="noopener">Sendung verfolgen';
      if (d.tracking.versender) html += ' (' + esc(d.tracking.versender) + ')';
      html += '</a>';
    } else if (d.tracking && d.tracking.nummer) {
      html += '<p class="muted">Tracking-Nr: ' + esc(d.tracking.nummer) + (d.tracking.versender ? ' (' + esc(d.tracking.versender) + ')' : '') + '</p>';
    }
    if (d.artikel && d.artikel.length) {
      html += '<ul class="items">';
      for (var i = 0; i < d.artikel.length; i++) {
        var a = d.artikel[i];
        html += '<li>' + esc(a.menge) + '× ' + esc(a.titel) + (a.variante ? ' — ' + esc(a.variante) : '') + '</li>';
      }
      html += '</ul>';
    }
    result.innerHTML = html;
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    if (!API) { showError('Backend-URL nicht konfiguriert. Bitte im Theme-Editor eintragen.'); return; }
    var fd = new FormData(form);
    var payload = { order_number: fd.get('order_number'), email: fd.get('email') };
    btn.disabled = true;
    result.hidden = true;
    try {
      var r = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type':'application/json', 'Accept':'application/json' },
        body: JSON.stringify(payload),
      });
      var j = await r.json().catch(function(){ return { error:'Unerwartete Antwort.' }; });
      if (!r.ok) { showError(j.error || 'Fehler ' + r.status); return; }
      showOk(j);
    } catch (err) {
      showError('Verbindung zum Shop nicht möglich. Bitte später erneut versuchen oder info@blechziegel.de kontaktieren.');
    } finally {
      btn.disabled = false;
    }
  });
})();
</script>

{% schema %}
{
  "name": "Bestellstatus",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Bestellstatus einsehen"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext",
      "default": "Geben Sie Ihre Bestellnummer und die E-Mail-Adresse ein, mit der Sie bestellt haben. Wir zeigen Ihnen den aktuellen Status inklusive Sendungsverfolgung."
    },
    {
      "type": "url",
      "id": "api_url",
      "label": "Backend-API-URL",
      "info": "Öffentliche URL der Bestellstatus-API (z. B. https://api.blechziegel.de/api/bestellstatus)"
    }
  ],
  "presets": [
    {
      "name": "Bestellstatus"
    }
  ]
}
{% endschema %}
