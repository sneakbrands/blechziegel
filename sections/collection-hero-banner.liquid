<style>
  .collection-hero-banner {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 0;
    margin-bottom: 24px;
    padding: 0;
    overflow: hidden;
    line-height: 0;
  }
  .collection-hero-banner picture,
  .collection-hero-banner img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
  @media (max-width: 767px) {
    .collection-hero-banner { margin-bottom: 16px; }
  }
</style>

<section class="collection-hero-banner" aria-label="{{ section.settings.alt_text | escape }}">
  {%- if section.settings.desktop_image != blank or section.settings.mobile_image != blank -%}
    <picture>
      {%- if section.settings.desktop_image != blank -%}
        <source media="(min-width: 768px)" srcset="{{ section.settings.desktop_image | image_url: width: 2400 }}" width="2400" height="800">
      {%- endif -%}
      {%- if section.settings.mobile_image != blank -%}
        <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 750 }}" width="750" height="1000">
      {%- endif -%}
      {%- assign _fallback = section.settings.desktop_image | default: section.settings.mobile_image -%}
      <img
        src="{{ _fallback | image_url: width: 2400 }}"
        alt="{{ section.settings.alt_text | escape }}"
        loading="lazy"
        decoding="async"
        width="2400"
        height="800"
        style="width:100%;height:auto;display:block;"
      >
    </picture>
  {%- else -%}
    {%- comment -%} Kein Bild gepflegt → Platzhalter nur im Editor {%- endcomment -%}
    {%- if request.design_mode -%}
      <div style="padding:40px;text-align:center;background:#f4f4f4;color:#666;font-family:Inter,sans-serif;">
        Collection Hero Banner — Desktop- und Mobile-Bild im Theme-Editor auswählen.
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Collection Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner (2400 × 800)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner (750 × 1000)"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt-Text",
      "default": "PV-Dachziegel & Blechziegel – passend für Ihren Dachtyp"
    }
  ],
  "presets": [
    {
      "name": "Collection Hero Banner",
      "category": "Bild"
    }
  ]
}
{% endschema %}
