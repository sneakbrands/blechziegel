<style>
  .collection-hero-banner {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 0;
    margin-bottom: 24px;
    padding: 0;
    overflow: hidden;
    line-height: 0;
  }
  .collection-hero-banner picture,
  .collection-hero-banner img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
  @media (max-width: 767px) {
    .collection-hero-banner { margin-bottom: 16px; }
  }
</style>

{%- comment -%}
  Desktop + Mobile-URL: Theme-Editor-Override, sonst CDN-Default (nach fileCreate-Upload).
{%- endcomment -%}
{%- assign _desktop_default = 'https://cdn.shopify.com/s/files/1/0986/5986/0864/files/blechziegel-hero-produkt-desktop-2400x800.webp' -%}
{%- assign _mobile_default = 'https://cdn.shopify.com/s/files/1/0986/5986/0864/files/blechziegel-hero-montage-mobile-750x1000.webp' -%}
{%- if section.settings.desktop_image != blank -%}
  {%- assign _desktop_src = section.settings.desktop_image | image_url: width: 2400 -%}
{%- else -%}
  {%- assign _desktop_src = _desktop_default -%}
{%- endif -%}
{%- if section.settings.mobile_image != blank -%}
  {%- assign _mobile_src = section.settings.mobile_image | image_url: width: 750 -%}
{%- else -%}
  {%- assign _mobile_src = _mobile_default -%}
{%- endif -%}

{%- comment -%} Nur auf /collections/all rendern, sonst still {%- endcomment -%}
{%- assign _handle = collection.handle | default: '' -%}
{%- assign _limit_handle = section.settings.limit_handle | default: 'all' -%}
{%- if section.settings.limit_to_handle and _handle != _limit_handle -%}
  {%- comment -%} Handle passt nicht → nichts rendern {%- endcomment -%}
{%- else -%}
<section class="collection-hero-banner" aria-label="{{ section.settings.alt_text | escape }}">
  <picture>
    <source media="(min-width: 768px)" srcset="{{ _desktop_src }}" width="2400" height="800">
    <source media="(max-width: 767px)" srcset="{{ _mobile_src }}" width="750" height="1000">
    <img
      src="{{ _desktop_src }}"
      alt="{{ section.settings.alt_text | escape }}"
      loading="lazy"
      decoding="async"
      width="2400"
      height="800"
      style="width:100%;height:auto;display:block;"
    >
  </picture>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Collection Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner (2400 × 800)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner (750 × 1000)"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt-Text",
      "default": "PV-Dachziegel & Blechziegel – passend für Ihren Dachtyp"
    },
    {
      "type": "checkbox",
      "id": "limit_to_handle",
      "label": "Nur auf einer bestimmten Collection zeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "limit_handle",
      "label": "Collection-Handle (z. B. 'all')",
      "default": "all"
    }
  ],
  "presets": [
    {
      "name": "Collection Hero Banner",
      "category": "Bild"
    }
  ]
}
{% endschema %}
