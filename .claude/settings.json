{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npx playwright *)",
      "Bash(node scripts/*)"
    ]
  },
  "autoMemoryEnabled": false,
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[console]::beep(1000,300)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"if (Get-Command prettier -ErrorAction SilentlyContinue) { exit 0 } else { exit 0 }\""
          }
        ]
      }
    ]
  }
}
